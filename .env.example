# ── Analytics (선택) ───────────────────────────────────────────────────
# Cloudflare 대시보드 → Analytics → Web Analytics → 사이트 추가 후 토큰
PUBLIC_CF_ANALYTICS_TOKEN=
# Google Analytics 4 측정 ID (예: G-XXXXXXXXXX)
PUBLIC_GA_MEASUREMENT_ID=

# ── Supabase ──────────────────────────────────────────────────────────
# 독자 OAuth(Google/Kakao): 키는 대시보드 Provider 설정에만 넣고, Redirect URL은 README 참고
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Pages Function `/api/delete-account` — GoTrue `auth/v1/user` 검증용(값은 보통 anon 키와 동일)
SUPABASE_ANON_KEY=your-anon-key

# ── GitHub (콘텐츠 파이프라인) ──────────────────────────────────────
GITHUB_TOKEN=your-github-token
GITHUB_REPO=your-username/s-reborn-clinic
GITHUB_BRANCH=main
WEBHOOK_SECRET=your-webhook-secret

# ── Claude AI (상담 위자드 AI 분석) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── 알림: 이메일 (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_...
# 쉼표로 여러 수신자 지정 가능
ADMIN_EMAIL=doctor@clinic.com,staff@clinic.com

# ── 알림: Slack ────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── 알림: Telegram ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=-100123456789

# ── 알림: 카카오 알림톡 (Phase 2 — 비즈채널 심사 후 활성화) ──────────
# KAKAO_BIZ_KEY=your-kakao-biz-key
# KAKAO_PLUS_FRIEND_KEY=your-kakao-channel-id
# KAKAO_SENDER_PHONE=01012345678

# ── 알림: SMS 솔라피 (Phase 2) ────────────────────────────────────────
# SOLAPI_API_KEY=your-solapi-key
# SOLAPI_API_SECRET=your-solapi-secret
# SOLAPI_SENDER_PHONE=01012345678

# ── 알림: WhatsApp Business (Phase 3) ────────────────────────────────
# WHATSAPP_PHONE_ID=your-phone-id
# WHATSAPP_TOKEN=your-token

# ── 알림: LINE (Phase 3 — 일본 환자) ─────────────────────────────────
# LINE_CHANNEL_ACCESS_TOKEN=your-line-token

# ── 알림: 위챗 (Phase 3 — 중국 환자) ────────────────────────────────
# WECHAT_APP_ID=your-wechat-appid
# WECHAT_APP_SECRET=your-wechat-secret

# ── 알림: 노션 (Phase 2) ─────────────────────────────────────────────
# NOTION_TOKEN=secret_...
# NOTION_DATABASE_ID=your-database-id
