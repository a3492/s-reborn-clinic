---
import Layout from '../layouts/Layout.astro';
---

<Layout title="오프라인" description="인터넷 연결을 확인해 주세요." noindex>
  <section
    class="offline-notice"
    style="max-width: 38rem; margin: 3rem auto; padding: 0 1.25rem; text-align: center;"
  >
    <h1 class="title" style="font-size: 1.5rem; margin-bottom: 0.75rem;">연결을 확인해 주세요</h1>
    <p style="color: var(--t2); line-height: 1.65; margin: 0;">
      인터넷 연결을 확인해 주세요. 이전에 방문한 글은 계속 읽을 수 있습니다.
    </p>
  </section>
</Layout>
