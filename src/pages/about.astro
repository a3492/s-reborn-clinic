---
import Layout from '../layouts/Layout.astro';
import NaverMapCta from '../components/NaverMapCta.astro';
import { CLINIC_INFO } from '../consts';
import { t, type Locale } from '../i18n';
import { buildBreadcrumbJsonLd, mergeJsonLd } from '../lib/structured-data';

const locale: Locale = Astro.currentLocale === 'en' ? 'en' : 'ko';

const aboutJsonLd = mergeJsonLd(
  buildBreadcrumbJsonLd(Astro.site, [
    { name: '홈', path: '/' },
    { name: '클리닉 소개', path: '/about/' },
  ])
);
---

<Layout title={t(locale, 'about.pageTitle')} description={t(locale, 'about.pageDesc')} jsonLd={aboutJsonLd}>
  <div class="about-wrap">
    <section class="about-hero">
      <div class="about-hero-badge">{t(locale, 'about.badge')}</div>
      <h1 class="about-hero-title">{t(locale, 'about.title')}</h1>
      <p class="about-hero-subtitle">{t(locale, 'about.subtitle')}</p>
    </section>

    <section class="about-section">
      <div class="about-grid">
        <div class="about-intro">
          <h2>{t(locale, 'about.philosophyTitle')}</h2>
          <p>{t(locale, 'about.philosophyP1')}</p>
          <p>{t(locale, 'about.philosophyP2')}</p>
        </div>
        <div class="about-values">
          <div class="value-card">
            <div class="value-icon">✦</div>
            <h3>{t(locale, 'about.valueSafety')}</h3>
            <p>{t(locale, 'about.valueSafetyDesc')}</p>
          </div>
          <div class="value-card">
            <div class="value-icon">✦</div>
            <h3>{t(locale, 'about.valueCustom')}</h3>
            <p>{t(locale, 'about.valueCustomDesc')}</p>
          </div>
          <div class="value-card">
            <div class="value-icon">✦</div>
            <h3>{t(locale, 'about.valueNatural')}</h3>
            <p>{t(locale, 'about.valueNaturalDesc')}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="about-section about-section-alt">
      <h2>{t(locale, 'about.doctorsTitle')}</h2>
      <div class="doctor-grid">
        <div class="doctor-card">
          <div class="doctor-avatar" aria-hidden="true">👨‍⚕️</div>
          <h3 class="doctor-name">{CLINIC_INFO.director}</h3>
          <p class="doctor-spec">{t(locale, 'about.doctorSpec')}</p>
          <p class="doctor-bio">{t(locale, 'about.doctorBio')}</p>
        </div>
      </div>
    </section>

    <section class="about-section" id="location">
      <h2>{t(locale, 'about.locationTitle')}</h2>
      <div class="location-info">
        <div class="location-detail">
          <div class="location-item">
            <strong>{t(locale, 'about.locationAddress')}</strong>
            <span>
              {CLINIC_INFO.address}
              <br/>
              <small>{locale === 'en' ? '(Mapo-gu, Seoul · 2–3 min walk from Hongdae Station Exit 8/9)' : CLINIC_INFO.addressDetail}</small>
            </span>
          </div>
          <div class="location-item">
            <strong>{t(locale, 'about.locationPhone')}</strong>
            <span><a href={`tel:${CLINIC_INFO.phone}`}>{CLINIC_INFO.phone}</a></span>
          </div>
          <div class="location-item">
            <strong>{t(locale, 'about.locationHours')}</strong>
            <div>
              {locale === 'en' ? (
                <>
                  <p>Mon · Tue · Wed · Fri: 10:30 – 19:30</p>
                  <p>Thu (Evening hours): 13:00 – 21:00</p>
                  <p>Sat: 10:00 – 16:00</p>
                  <p>Sun · Holidays: Closed</p>
                </>
              ) : (
                CLINIC_INFO.hours.map(h => (
                  <p>{h.days}: {h.time}</p>
                ))
              )}
            </div>
          </div>
        </div>
        <div class="location-map">
          <NaverMapCta variant="card" />
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .about-wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 0 3rem;
  }

  .about-hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  .about-hero-badge {
    display: inline-block;
    margin-bottom: 1rem;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    background: rgba(201, 169, 110, 0.15);
    border: 1px solid rgba(201, 169, 110, 0.3);
    color: var(--accent-dark);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .about-hero-title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text);
    margin: 0 0 0.75rem;
  }

  .about-hero-subtitle {
    font-size: 1.1rem;
    color: var(--t2);
    margin: 0;
  }

  .about-section {
    padding: 3rem 0;
    border-top: 1px solid var(--rule);
  }

  .about-section h2 {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
    margin: 0 0 1.5rem;
    letter-spacing: -0.02em;
  }

  .about-section-alt {
    background: var(--bg2);
    border-radius: 20px;
    margin-inline: calc(-1 * var(--page-inline));
    padding-inline: var(--page-inline);
    box-sizing: border-box;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .about-intro p {
    color: var(--t2);
    line-height: 1.8;
    margin: 0 0 1rem;
  }

  .about-values {
    display: grid;
    gap: 1rem;
  }

  .value-card {
    padding: 1.25rem;
    border: 1px solid var(--rule);
    border-radius: 16px;
    background: var(--surface);
  }

  .value-icon {
    color: var(--accent);
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .value-card h3 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .value-card p {
    margin: 0;
    font-size: 0.88rem;
    color: var(--t2);
    line-height: 1.6;
  }

  .doctor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .doctor-card {
    padding: 2rem 1.5rem;
    border: 1px solid var(--color-gold);
    border-radius: 20px;
    background: linear-gradient(135deg, var(--surface), var(--color-gold-light));
    text-align: center;
  }

  .doctor-avatar {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .doctor-name {
    margin: 0 0 0.35rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text);
  }

  .doctor-spec {
    margin: 0 0 0.75rem;
    font-size: 0.82rem;
    color: var(--accent-dark);
    font-weight: 600;
  }

  .doctor-bio {
    margin: 0;
    font-size: 0.88rem;
    color: var(--t2);
    line-height: 1.7;
  }

  .location-info {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .location-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0.5rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .location-item strong {
    color: var(--text);
    font-size: 0.88rem;
  }

  .location-item span,
  .location-item p {
    color: var(--t2);
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .about-grid,
    .location-info {
      grid-template-columns: 1fr;
    }
  }
</style>
