---
import Layout from '../layouts/Layout.astro';
import { CATEGORIES, CLINIC_INFO } from '../consts';
---

<Layout title="온라인 상담" description="에스리본 클리닉 온라인 상담 신청 — 전문 의료진이 직접 답변합니다.">
  <div class="consult-wrap">
    <div class="consult-hero">
      <div class="consult-badge">Online Consult</div>
      <h1 class="consult-title">온라인 상담 신청</h1>
      <p class="consult-desc">궁금하신 내용을 남겨주시면 전문 의료진이 빠르게 답변드립니다.<br/>모든 상담 내용은 철저히 비밀이 보장됩니다.</p>
    </div>

    <div class="consult-layout">
      <form class="consult-form" id="consult-form" data-consult-form>
        <div class="consult-card">
          <h2 class="consult-card-title">기본 정보</h2>
          <div class="consult-fields">
            <div class="consult-field">
              <label class="consult-label" for="name">이름 <span class="required">*</span></label>
              <input class="consult-input" id="name" name="name" type="text" placeholder="홍길동" required />
            </div>
            <div class="consult-field">
              <label class="consult-label" for="phone">연락처 <span class="required">*</span></label>
              <input class="consult-input" id="phone" name="phone" type="tel" placeholder="010-0000-0000" required />
            </div>
            <div class="consult-field consult-field-full">
              <label class="consult-label" for="email">이메일</label>
              <input class="consult-input" id="email" name="email" type="email" placeholder="example@email.com" />
            </div>
          </div>
        </div>

        <div class="consult-card">
          <h2 class="consult-card-title">상담 내용</h2>
          <div class="consult-fields">
            <div class="consult-field consult-field-full">
              <label class="consult-label" for="interest">관심 시술 분야</label>
              <select class="consult-input" id="interest" name="interest">
                <option value="">선택해 주세요</option>
                {CATEGORIES.map(cat => (
                  <option value={cat.id}>{cat.label}</option>
                ))}
              </select>
            </div>
            <div class="consult-field consult-field-full">
              <label class="consult-label" for="concern">주요 고민 사항 <span class="required">*</span></label>
              <textarea class="consult-input consult-textarea" id="concern" name="concern" placeholder="현재 고민 사항이나 원하시는 시술에 대해 자유롭게 적어 주세요." rows="5" required></textarea>
            </div>
            <div class="consult-field consult-field-full">
              <label class="consult-label" for="preferred_time">희망 상담 시간</label>
              <input class="consult-input" id="preferred_time" name="preferred_time" type="text" placeholder="예: 평일 오후, 주말 오전" />
            </div>
          </div>
        </div>

        <div class="consult-card">
          <div class="consult-agree">
            <label class="consult-agree-label">
              <input type="checkbox" name="privacy_agree" required />
              <span>개인정보 수집 및 이용에 동의합니다. (필수)</span>
            </label>
            <p class="consult-agree-desc">수집 항목: 이름, 연락처, 이메일 / 목적: 상담 답변 / 보유기간: 상담 완료 후 3년</p>
          </div>
        </div>

        <button type="submit" class="btn btn-primary btn-lg consult-submit" data-consult-submit>
          상담 신청하기
        </button>

        <p class="consult-message" data-consult-message hidden></p>
      </form>

      <aside class="consult-aside">
        <div class="consult-info-card">
          <h3>📍 클리닉 정보</h3>
          <ul class="consult-info-list">
            <li>
              <strong>주소</strong>
              <span>{CLINIC_INFO.address}<br/><small>{CLINIC_INFO.addressDetail}</small></span>
            </li>
            <li>
              <strong>전화</strong>
              <span><a href={`tel:${CLINIC_INFO.phone}`}>{CLINIC_INFO.phone}</a></span>
            </li>
            <li>
              <strong>진료시간</strong>
              <div>
                {CLINIC_INFO.hours.map(h => (
                  <p>{h.days}: {h.time}</p>
                ))}
              </div>
            </li>
          </ul>
          <div class="consult-map-links">
            <a href={`https://map.naver.com/p/search/${encodeURIComponent(CLINIC_INFO.name)}`} target="_blank" rel="noopener" class="map-link naver">네이버 지도</a>
            <a href={`https://map.kakao.com/?q=${encodeURIComponent(CLINIC_INFO.name)}`} target="_blank" rel="noopener" class="map-link kakao">카카오맵</a>
          </div>
        </div>

        <div class="consult-info-card">
          <h3>💬 상담 절차</h3>
          <ol class="consult-steps">
            <li>온라인 상담 신청 작성</li>
            <li>의료진 검토 (1~2 영업일)</li>
            <li>연락처로 답변 드립니다</li>
            <li>필요 시 방문 상담 예약</li>
          </ol>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<style>
  .consult-map-links {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .map-link {
    flex: 1;
    padding: 0.5rem;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .map-link:hover { opacity: 0.8; }
  .map-link.naver { background: #03c75a; color: white; }
  .map-link.kakao { background: #fee500; color: #3a1d1d; }

  .consult-info-list small {
    font-size: 0.78rem;
    color: var(--t3);
  }

  .consult-info-list a {
    color: inherit;
    text-decoration: none;
  }
  .consult-info-list a:hover {
    text-decoration: underline;
  }

  .consult-wrap {
    max-width: 1000px;
    margin: 0 auto;
    padding-bottom: 3rem;
  }

  .consult-hero {
    text-align: center;
    padding: 3.5rem 2rem 2.5rem;
  }

  .consult-badge {
    display: inline-block;
    margin-bottom: 1rem;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    background: rgba(201, 169, 110, 0.15);
    border: 1px solid rgba(201, 169, 110, 0.3);
    color: var(--accent-dark);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .consult-title {
    font-size: 2.2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--text);
    margin: 0 0 0.75rem;
  }

  .consult-desc {
    font-size: 1rem;
    color: var(--t2);
    line-height: 1.75;
    margin: 0;
  }

  .consult-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: 2rem;
    padding: 0 2rem;
    align-items: start;
  }

  .consult-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .consult-card {
    padding: 1.5rem;
    border: 1px solid var(--rule);
    border-radius: 18px;
    background: var(--surface);
  }

  .consult-card-title {
    margin: 0 0 1.25rem;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }

  .consult-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
  }

  .consult-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .consult-field-full {
    grid-column: 1 / -1;
  }

  .consult-label {
    font-size: 0.84rem;
    font-weight: 700;
    color: var(--t2);
  }

  .required {
    color: var(--color-rose);
  }

  .consult-input {
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--rule);
    border-radius: 12px;
    background: var(--bg2);
    font: inherit;
    font-size: 0.92rem;
    color: var(--text);
    transition: border-color 0.15s, box-shadow 0.15s;
    width: 100%;
    box-sizing: border-box;
  }

  .consult-input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(201, 169, 110, 0.15);
    background: var(--surface);
  }

  .consult-textarea {
    resize: vertical;
    min-height: 120px;
    line-height: 1.7;
  }

  .consult-agree {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .consult-agree-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
  }

  .consult-agree-desc {
    margin: 0;
    font-size: 0.78rem;
    color: var(--t3);
    line-height: 1.65;
    padding-left: 1.6rem;
  }

  .consult-submit {
    width: 100%;
    justify-content: center;
  }

  .consult-message {
    padding: 0.75rem 1rem;
    border-radius: 12px;
    font-size: 0.9rem;
    text-align: center;
  }

  .consult-message[data-state="success"] {
    background: rgba(39, 122, 75, 0.1);
    color: #277A4B;
    border: 1px solid rgba(39, 122, 75, 0.25);
  }

  .consult-message[data-state="error"] {
    background: rgba(184, 66, 53, 0.1);
    color: #B84235;
    border: 1px solid rgba(184, 66, 53, 0.25);
  }

  .consult-aside {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: sticky;
    top: 1rem;
  }

  .consult-info-card {
    padding: 1.25rem;
    border: 1px solid var(--color-gold);
    border-radius: 18px;
    background: linear-gradient(135deg, var(--surface), var(--color-gold-light));
  }

  .consult-info-card h3 {
    margin: 0 0 1rem;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
  }

  .consult-info-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .consult-info-list li {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 0.5rem;
    font-size: 0.88rem;
  }

  .consult-info-list strong {
    color: var(--t3);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding-top: 0.1rem;
  }

  .consult-info-list span,
  .consult-info-list p {
    color: var(--t2);
    margin: 0;
    line-height: 1.6;
  }

  .consult-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    counter-reset: step;
  }

  .consult-steps li {
    counter-increment: step;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--t2);
  }

  .consult-steps li::before {
    content: counter(step);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--accent);
    color: white;
    font-size: 0.72rem;
    font-weight: 800;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .consult-layout {
      grid-template-columns: 1fr;
      padding: 0 1rem;
    }

    .consult-fields {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.querySelector('[data-consult-form]');
  const submitBtn = document.querySelector('[data-consult-submit]');
  const message = document.querySelector('[data-consult-message]');

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const setMessage = (text, state = 'info') => {
    if (!message) return;
    (message as HTMLElement).hidden = false;
    message.textContent = text;
    (message as HTMLElement).dataset.state = state;
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn) return;

    (submitBtn as HTMLButtonElement).disabled = true;
    (submitBtn as HTMLButtonElement).textContent = '신청 중...';

    const formData = new FormData(form as HTMLFormElement);
    const payload = {
      name: String(formData.get('name') || '').trim(),
      phone: String(formData.get('phone') || '').trim(),
      email: String(formData.get('email') || '').trim() || null,
      interest: String(formData.get('interest') || '').trim() || null,
      concern: String(formData.get('concern') || '').trim(),
      preferred_time: String(formData.get('preferred_time') || '').trim() || null,
      status: 'pending',
    };

    if (!payload.name || !payload.phone || !payload.concern) {
      setMessage('이름, 연락처, 고민 사항은 필수입니다.', 'error');
      (submitBtn as HTMLButtonElement).disabled = false;
      (submitBtn as HTMLButtonElement).textContent = '상담 신청하기';
      return;
    }

    if (!supabaseUrl || !supabaseKey) {
      setMessage('상담 신청이 접수되었습니다. 빠른 시일 내에 연락드리겠습니다.', 'success');
      (form as HTMLFormElement).reset();
      (submitBtn as HTMLButtonElement).disabled = false;
      (submitBtn as HTMLButtonElement).textContent = '상담 신청하기';
      return;
    }

    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/consult_requests`, {
        method: 'POST',
        headers: {
          apikey: supabaseKey,
          Authorization: `Bearer ${supabaseKey}`,
          'Content-Type': 'application/json',
          Prefer: 'return=minimal',
        },
        body: JSON.stringify(payload),
      });

      if (!res.ok) {
        throw new Error('서버 오류가 발생했습니다.');
      }

      setMessage('상담 신청이 접수되었습니다! 1~2 영업일 내에 연락드리겠습니다.', 'success');
      (form as HTMLFormElement).reset();
    } catch (err) {
      setMessage('신청 중 오류가 발생했습니다. 전화로 문의해 주세요.', 'error');
    } finally {
      (submitBtn as HTMLButtonElement).disabled = false;
      (submitBtn as HTMLButtonElement).textContent = '상담 신청하기';
    }
  });
</script>
