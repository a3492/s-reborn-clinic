<script>
  import { createClient } from '@supabase/supabase-js';
  import { fetchViewCountsMap, formatViewCount } from '../../lib/blog-post-views';

  const url = import.meta.env.PUBLIC_SUPABASE_URL;
  const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  function applyRandomFeaturedFromPool() {
    const jsonEl = document.getElementById('featured-random-pool');
    const root = document.querySelector('[data-featured-card]');
    if (!jsonEl || !root) return;
    let pool;
    try {
      pool = JSON.parse(jsonEl.textContent || '[]');
    } catch {
      return;
    }
    if (!Array.isArray(pool) || pool.length < 1) return;
    const pick = pool[Math.floor(Math.random() * pool.length)];
    root.setAttribute('href', pick.href);
    root.dataset.homeSlug = pick.id;

    const titleEl = root.querySelector('[data-featured-title]');
    const descEl = root.querySelector('[data-featured-desc]');
    const catEl = root.querySelector('[data-featured-cat]');
    const thumbWrap = root.querySelector('[data-featured-thumb]');

    if (titleEl) titleEl.textContent = pick.title;
    if (descEl) descEl.textContent = pick.description;

    if (catEl) {
      if (pick.categoryLabel) {
        catEl.textContent = pick.categoryLabel;
        catEl.hidden = false;
      } else {
        catEl.textContent = '';
        catEl.hidden = true;
      }
    }

    if (thumbWrap) {
      if (pick.thumbnail) {
        thumbWrap.textContent = '';
        const img = document.createElement('img');
        img.src = pick.thumbnail;
        img.alt = pick.title;
        img.width = 960;
        img.height = 540;
        img.loading = 'eager';
        img.decoding = 'async';
        img.setAttribute('fetchpriority', 'high');
        thumbWrap.appendChild(img);
        thumbWrap.style.display = '';
      } else {
        thumbWrap.textContent = '';
        thumbWrap.style.display = 'none';
      }
    }

    document.querySelectorAll('.post-grid [data-home-slug]').forEach((node) => {
      if (node instanceof HTMLElement && node.dataset.homeSlug === pick.id) {
        node.closest('.post-card')?.remove();
      }
    });
  }

  async function fillHomeViewBadges() {
    if (!url || !key) return;
    const roots = document.querySelectorAll('[data-home-slug]');
    const slugs = [...roots]
      .map((el) => (el instanceof HTMLElement ? el.dataset.homeSlug?.trim() : ''))
      .filter(Boolean);
    if (!slugs.length) return;
    const supabase = createClient(url, key);
    const map = await fetchViewCountsMap(supabase, slugs);
    const isEn = document.documentElement.lang === 'en';
    document.querySelectorAll('[data-home-view-badge]').forEach((badge) => {
      const root = badge.closest('[data-home-slug]');
      const slug = root instanceof HTMLElement ? root.dataset.homeSlug?.trim() ?? '' : '';
      if (!slug) return;
      const n = map.get(slug) ?? 0;
      badge.textContent = isEn ? `${formatViewCount(n)} views` : `조회 ${formatViewCount(n)}`;
    });
  }

  function shuffleLatestGrid() {
    const grid = document.querySelector('[data-latest-grid]');
    if (!grid) return;
    const cards = [...grid.querySelectorAll('[data-latest-card]')];
    if (cards.length <= 6) return;
    // Fisher-Yates shuffle — re-append in random order
    for (let i = cards.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [cards[i], cards[j]] = [cards[j], cards[i]];
    }
    cards.forEach((card, idx) => {
      grid.appendChild(card);
      (card as HTMLElement).style.display = idx < 6 ? '' : 'none';
    });
  }

  applyRandomFeaturedFromPool();
  shuffleLatestGrid();
  fillHomeViewBadges();
</script>

<script define:vars={{ categoryLabels }}>
  import { createClient } from '@supabase/supabase-js';
  import { postHrefFromDbSlug } from '../../lib/academy';
  import { fetchTrendingPosts, type TrendingPostRow } from '../../lib/trending-posts';

  const url = import.meta.env.PUBLIC_SUPABASE_URL;
  const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const rowEl = document.getElementById('home-trending-row');
  const statusEl = document.querySelector('[data-home-trending-status]');

  function escapeHtml(s: string) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function gaugePercent(rank: number, total: number) {
    if (total <= 0) return 0;
    return Math.max(10, Math.round(((total - rank + 1) / total) * 100));
  }

  async function loadHomeTrending() {
    if (!rowEl) return;
    const isEn = document.documentElement.lang === 'en';
    if (!url || !key) {
      if (statusEl) statusEl.textContent = '';
      rowEl.innerHTML = '';
      return;
    }
    if (statusEl) statusEl.textContent = isEn ? 'Loading…' : '불러오는 중…';
    const supabase = createClient(url, key);
    const rows = await fetchTrendingPosts(supabase, 7, 3);
    if (statusEl) statusEl.textContent = '';
    if (!rows.length) {
      rowEl.innerHTML = `<p class="trending-home-empty">${isEn ? 'No trending posts this week.' : '이번 주 순위에 올라온 글이 없습니다.'}</p>`;
      return;
    }
    const n = rows.length;
    rowEl.innerHTML = (rows as TrendingPostRow[])
      .map((row, i) => {
        const rank = i + 1;
        const rankLabel = isEn ? `#${rank}` : `${rank}위`;
        const href = postHrefFromDbSlug(row.slug);
        const cat = row.category || '';
        const catLabel = (categoryLabels as Record<string, string>)[cat] || cat || '';
        const thumb = row.thumbnail_url?.trim();
        const pct = gaugePercent(rank, n);
        const thumbBlock = thumb
          ? `<div class="post-card-thumb"><img src="${escapeHtml(thumb)}" alt="" loading="lazy" /></div>`
          : '';
        return `<a href="${escapeHtml(href)}" class="post-card trending-home-card">
  <span class="trending-home-rank" aria-label="${rankLabel}">${rankLabel}</span>
  ${thumbBlock}
  <div class="post-card-body">
    <div class="post-card-meta">
      ${catLabel ? `<span class="post-card-cat">${escapeHtml(catLabel)}</span>` : '<span class="post-card-cat" hidden></span>'}
    </div>
    <h3 class="post-card-title">${escapeHtml(row.title || '')}</h3>
    <p class="post-card-desc">${escapeHtml(row.description || '')}</p>
    <div class="trending-home-gauge" aria-hidden="true"><div class="trending-home-gauge-fill" style="width:${pct}%"></div></div>
  </div>
</a>`;
      })
      .join('');
  }

  void loadHomeTrending();
</script>
