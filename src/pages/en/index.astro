---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, CLINIC_INFO } from '../../consts';
import { PROCEDURE_PILLAR_SUMMARIES } from '../../data/procedure-catalog';
import { ACADEMY_PUBLIC_PATH, isAcademyBlogPost, postPermalink } from '../../lib/academy';
import { getPublicSiteSettings } from '../../lib/site-settings';
import { getVisibleFaqItems } from '../../lib/faq-items';
import ContentImage from '../../components/ContentImage.astro';
import { t, type Locale } from '../../i18n';

const locale: Locale = Astro.currentLocale === 'en' ? 'en' : 'ko';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const clinicPosts = allPosts.filter((p) => !isAcademyBlogPost(p));
const publicSettings = await getPublicSiteSettings();
const featuredSlugConfigured = publicSettings.featuredSlug?.trim() || '';

const adminFeaturedMatch =
  featuredSlugConfigured.length > 0
    ? clinicPosts.find((p) => p.id === featuredSlugConfigured)
    : undefined;
/** 관리자 설정으로 글이 지정된 경우에만 고정 (slug 오타 등으로 못 찾으면 자동 랜덤 허용) */
const isFeaturedLocked = Boolean(adminFeaturedMatch);

let featuredPost = adminFeaturedMatch ?? (clinicPosts.length > 0 ? clinicPosts[0] : null);

const FEATURED_RANDOM_POOL_MAX = 30;
const featuredRandomPool = clinicPosts.slice(0, FEATURED_RANDOM_POOL_MAX).map((p) => ({
  id: p.id,
  title: p.data.title_en ?? p.data.title,
  description: p.data.description_en ?? p.data.description,
  thumbnail: p.data.thumbnail?.trim() || '',
  categoryLabel:
    p.data.category != null
      ? CATEGORIES.find((c) => c.id === p.data.category)?.labelEn ?? p.data.category
      : '',
  href: postPermalink(p),
}));
const featuredRandomPoolJson =
  featuredRandomPool.length > 1
    ? JSON.stringify(featuredRandomPool).replace(/</g, '\\u003c')
    : '';

// 관리자 미지정 시 빌드 타임에도 랜덤 픽 (매 배포마다 다른 글)
if (!isFeaturedLocked && featuredRandomPool.length > 1) {
  const buildTimeIdx = Math.floor(Math.random() * featuredRandomPool.length);
  featuredPost = clinicPosts.find((p) => p.id === featuredRandomPool[buildTimeIdx].id) ?? featuredPost;
}

const latestPosts = clinicPosts
  .filter((p) => !featuredPost || p.id !== featuredPost.id)
  .slice(0, 20);
const academyPreview = allPosts.filter(isAcademyBlogPost).slice(0, 3);
const doctorColumn = allPosts.filter(p => p.data.category === 'doctor-column').slice(0, 3);
const faqPosts = allPosts.filter(p => p.data.category === 'faq').slice(0, 4);
const homeFaqItems = await getVisibleFaqItems();
const mythPosts = allPosts.filter(p => p.data.category === 'myth').slice(0, 4);
const categoryLabels = Object.fromEntries(CATEGORIES.map((c) => [c.id, c.label]));
---

<Layout>
  <!-- 히어로 섹션 -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-badge">{t(locale, 'home.heroBadge')}</div>
      <h1 class="hero-title">{t(locale, 'home.heroTitle')}</h1>
      <p class="hero-desc">{t(locale, 'home.heroDesc')}</p>
      <div class="hero-actions">
        <a href={locale === 'en' ? '/en/procedures/' : '/procedures/'} class="btn btn-primary btn-lg">{t(locale, 'home.heroCta')}</a>
        <a href={locale === 'en' ? '/en/consult/' : '/consult/'} class="hero-consult-link">{t(locale, 'home.heroConsult')}</a>
      </div>
    </div>
  </section>

  <!-- 피처드 글 (site_settings.homepage.featured_slug, 없으면 클리닉 최신 1편을 초기값으로 두고 풀에서 랜덤 교체) -->
  {featuredPost && (
    <section class="section featured-section">
      <div class="section-header">
        <h2 class="section-title">{t(locale, 'home.featuredTitle')}</h2>
        <a href={locale === 'en' ? '/en/blog/' : '/blog/'} class="section-more">{t(locale, 'home.featuredMore')}</a>
      </div>
      {featuredRandomPoolJson && (
        <script type="application/json" id="featured-random-pool" set:html={featuredRandomPoolJson} />
      )}
      <a
        href={postPermalink(featuredPost)}
        class="featured-hero-card"
        data-featured-card
        data-home-slug={featuredPost.id}
      >
        <div
          class="featured-hero-thumb"
          data-featured-thumb
          style={featuredPost.data.thumbnail ? undefined : 'display: none'}
        >
          {featuredPost.data.thumbnail && (
            <ContentImage
              src={featuredPost.data.thumbnail}
              alt={featuredPost.data.title}
              width={960}
              height={540}
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          )}
        </div>
        <div class="featured-hero-body">
          <div class="featured-hero-meta-row">
            <span
              class="featured-hero-cat"
              data-featured-cat
              hidden={!featuredPost.data.category}
            >
              {featuredPost.data.category
                ? CATEGORIES.find((c) => c.id === featuredPost.data.category)?.labelEn ?? featuredPost.data.category
                : ''}
            </span>
            <span class="featured-hero-views" data-home-view-badge aria-label={locale === 'en' ? 'Views' : '조회수'}>{locale === 'en' ? 'Views —' : '조회 —'}</span>
          </div>
          <h3 class="featured-hero-title" data-featured-title>{featuredPost.data.title_en ?? featuredPost.data.title}</h3>
          <p class="featured-hero-desc" data-featured-desc>{featuredPost.data.description_en ?? featuredPost.data.description}</p>
          <span class="featured-hero-cta">{locale === 'en' ? 'Read more →' : '자세히 읽기 →'}</span>
        </div>
      </a>
    </section>
  )}

  <!-- 이번 주 인기글 (Supabase RPC, 클라이언트 실시간) -->
  <section class="section trending-home-section" aria-labelledby="home-trending-title">
    <div class="section-header">
      <h2 class="section-title" id="home-trending-title">{locale === 'en' ? 'Trending This Week' : '이번 주 인기글'}</h2>
      <a href={locale === 'en' ? '/en/trending/' : '/trending/'} class="section-more">{locale === 'en' ? 'See more →' : '더 보기 →'}</a>
    </div>
    <div class="trending-home-row" id="home-trending-row" data-home-trending-row></div>
    <p class="trending-home-status" data-home-trending-status aria-live="polite"></p>
  </section>

  <!-- 신뢰 지표 바 -->
  <section class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item">
        <span class="trust-icon">🏥</span>
        <span class="trust-label">{locale === 'en' ? 'Board-Certified Physician' : '가정의학과 전문의'}</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <span class="trust-icon">✦</span>
        <span class="trust-label">{locale === 'en' ? 'Verified Products Only' : '검증된 제품 사용'}</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <span class="trust-icon">💬</span>
        <span class="trust-label">{locale === 'en' ? 'Friendly Guidance' : '친절한 안내'}</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <span class="trust-icon">📍</span>
        <span class="trust-label">{locale === 'en' ? '2–3 min from Hongdae Station' : '홍대입구역 도보 2~3분'}</span>
      </div>
    </div>
  </section>

  <!-- 시술 카드 섹션 -->
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">{t(locale, 'home.proceduresTitle')}</h2>
      <p class="section-desc">{locale === 'en' ? 'Organized by treatment area on a dedicated page' : '블로그와 별도 페이지에서, 영역별로 정리해 두었습니다'}</p>
    </div>
    <div class="procedure-grid">
      {PROCEDURE_PILLAR_SUMMARIES.map((p) => (
        <a href={locale === 'en' ? `/en/procedures/#${p.id}` : `/procedures/#${p.id}`} class="procedure-card">
          <div class="procedure-card-icon" aria-hidden="true">✦</div>
          <h3 class="procedure-card-title">{locale === 'en' ? (p.labelEn ?? p.label) : p.label}</h3>
          <p class="procedure-card-desc">{locale === 'en' ? (p.descriptionEn ?? p.description) : p.description}</p>
          <span class="procedure-card-link">{p.short} · {locale === 'en' ? 'Details →' : '자세히 →'}</span>
        </a>
      ))}
      <a href={locale === 'en' ? '/en/procedures/' : '/procedures/'} class="procedure-card procedure-card-all">
        <div class="procedure-card-icon" aria-hidden="true">⊞</div>
        <h3 class="procedure-card-title">{locale === 'en' ? 'All Procedures' : '전체 시술 안내'}</h3>
        <p class="procedure-card-desc">{locale === 'en' ? 'Browse all EBD, injections, oral, and topical treatments' : 'EBD·주사·경구·외용제 목록을 한 페이지에서 보기'}</p>
        <span class="procedure-card-link">{locale === 'en' ? 'View all →' : '바로가기 →'}</span>
      </a>
    </div>
  </section>

  <!-- 최신 글 섹션 -->
  {latestPosts.length > 0 && (
    <section class="section">
      <div class="section-header">
        <h2 class="section-title">{t(locale, 'home.latestTitle')}</h2>
        <a href={locale === 'en' ? '/en/blog/' : '/blog/'} class="section-more">{t(locale, 'home.latestMore')}</a>
      </div>
      <div class="post-grid" data-latest-grid>
        {latestPosts.map(post => (
          <a href={postPermalink(post)} class="post-card" data-home-slug={post.id} data-latest-card>
            {post.data.thumbnail && (
              <div class="post-card-thumb">
                <img src={post.data.thumbnail} alt={post.data.title} loading="lazy" />
              </div>
            )}
            <div class="post-card-body">
              <div class="post-card-meta">
                {post.data.category && (
                  <span class="post-card-cat">
                    {CATEGORIES.find(c => c.id === post.data.category)?.labelEn ?? post.data.category}
                  </span>
                )}
                <span class="post-card-views" data-home-view-badge aria-label="Views">Views —</span>
              </div>
              <h3 class="post-card-title">{post.data.title_en ?? post.data.title}</h3>
              <p class="post-card-desc">{post.data.description_en ?? post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- 원장 칼럼 -->
  {doctorColumn.length > 0 && (
    <section class="section section-alt">
      <div class="section-header">
        <h2 class="section-title">{t(locale, 'home.columnTitle')}</h2>
        <a href={locale === 'en' ? '/en/blog/?category=doctor-column' : '/blog/?category=doctor-column'} class="section-more">{t(locale, 'home.columnMore')}</a>
      </div>
      <div class="column-list">
        {doctorColumn.map(post => (
          <a href={postPermalink(post)} class="column-card">
            <div class="column-card-kicker">Doctor's Column</div>
            <h3 class="column-card-title">{post.data.title_en ?? post.data.title}</h3>
            <p class="column-card-desc">{post.data.description_en ?? post.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- FAQ (Supabase faq_items, 없으면 블로그 FAQ 글 fallback) -->
  {(homeFaqItems.length > 0 || faqPosts.length > 0) && (
    <section class="section">
      <div class="section-header">
        <h2 class="section-title">{t(locale, 'home.faqTitle')}</h2>
        <a href={locale === 'en' ? '/en/blog/?category=faq' : '/blog/?category=faq'} class="section-more">{t(locale, 'home.faqMore')}</a>
      </div>
      <div class="faq-list">
        {homeFaqItems.length > 0 ? (
          homeFaqItems.map((item) => (
            <article class="faq-item faq-item-static">
              <span class="faq-q" aria-hidden="true">Q</span>
              <div>
                <p class="faq-title">{item.question}</p>
                <p class="faq-desc faq-desc-answer">{item.answer}</p>
              </div>
            </article>
          ))
        ) : (
          faqPosts.map((post) => (
            <a href={postPermalink(post)} class="faq-item">
              <span class="faq-q">Q</span>
              <div>
                <p class="faq-title">{post.data.title_en ?? post.data.title}</p>
                <p class="faq-desc">{post.data.description_en ?? post.data.description}</p>
              </div>
            </a>
          ))
        )}
      </div>
    </section>
  )}

  <!-- MYTH · 자주하는 오해 -->
  {mythPosts.length > 0 && (
    <section class="section section-alt">
      <div class="section-header">
        <h2 class="section-title">{t(locale, 'home.mythTitle')}</h2>
        <a href={locale === 'en' ? '/en/blog/?category=myth' : '/blog/?category=myth'} class="section-more">{t(locale, 'home.mythMore')}</a>
      </div>
      <div class="myth-list">
        {mythPosts.map(post => (
          <a href={postPermalink(post)} class="myth-item">
            <span class="myth-mark" aria-hidden="true">M</span>
            <div>
              <p class="myth-title">{post.data.title_en ?? post.data.title}</p>
              <p class="myth-desc">{post.data.description_en ?? post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Doctor AI Academy -->
  {academyPreview.length > 0 && (
    <section class="section">
      <div class="section-header">
        <h2 class="section-title">{t(locale, 'home.academyTitle')}</h2>
        <a href={`${ACADEMY_PUBLIC_PATH}/`} class="section-more">{t(locale, 'home.academyMore')}</a>
      </div>
      <div class="post-grid">
        {academyPreview.map((post) => (
          <a href={postPermalink(post)} class="post-card">
            {post.data.thumbnail && (
              <div class="post-card-thumb">
                <img src={post.data.thumbnail} alt={post.data.title} loading="lazy" />
              </div>
            )}
            <div class="post-card-body">
              <span class="post-card-cat">Doctor AI Academy</span>
              <h3 class="post-card-title">{post.data.title}</h3>
              <p class="post-card-desc">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- 플로팅 연락 버튼 -->
  <div class="floating-contact">
    <a href={`tel:${CLINIC_INFO.phone}`} class="floating-btn phone" aria-label={locale === 'en' ? 'Call us' : '전화 연결'}>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
    </a>
    <a href={CLINIC_INFO.kakaoChannel} target="_blank" rel="noopener" class="floating-btn kakao" aria-label={locale === 'en' ? 'Kakao Channel' : '카카오 채널'}>
      <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3C6.477 3 2 6.477 2 10.5c0 2.52 1.57 4.74 3.95 6.07-.16.58-.52 1.97-.6 2.27-.1.36.13.36.28.26.11-.07 1.83-1.22 2.57-1.72.57.08 1.16.12 1.8.12 5.523 0 10-3.477 10-7.5S17.523 3 12 3z"/></svg>
    </a>
  </div>
</Layout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-soft-white) 0%, var(--color-cream) 40%, var(--color-gold-light) 100%);
    padding: clamp(3.25rem, 8vw, 5rem) var(--page-inline) clamp(2.75rem, 6vw, 4rem);
    text-align: center;
    margin-inline: calc(-1 * var(--page-inline));
    box-sizing: border-box;
  }

  /* design.css .hero-inner 의 2열 grid 를 반드시 덮어씀 */
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: min(700px, 100%);
    margin: 0 auto;
    padding-inline: 0;
    box-sizing: border-box;
    gap: 0;
    grid-template-columns: none;
  }

  .hero-badge {
    display: inline-block;
    align-self: center;
    margin-bottom: 1.25rem;
    padding: 0.35rem 1rem;
    border-radius: 999px;
    background: rgba(201, 169, 110, 0.15);
    border: 1px solid rgba(201, 169, 110, 0.35);
    color: var(--accent-dark);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
  }

  .hero-title {
    font-size: clamp(1.15rem, 2.2vw + 0.85rem, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.045em;
    color: var(--text);
    line-height: 1.25;
    margin: 0 0 1.25rem;
    max-width: 100%;
    width: 100%;
    word-break: keep-all;
    overflow-wrap: break-word;
    text-wrap: balance;
  }

  .hero-desc {
    font-size: 1.1rem;
    color: var(--t2);
    line-height: 1.75;
    margin: 0 0 2rem;
    max-width: 560px;
    width: 100%;
    text-align: center;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    width: 100%;
  }

  .hero-consult-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0.5rem 0.75rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--t2);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    box-sizing: border-box;
  }

  .hero-consult-link:hover {
    color: var(--accent-dark);
  }

  .hero-consult-link:focus-visible {
    outline: 2px solid var(--accent, #b8956a);
    outline-offset: 2px;
    border-radius: 6px;
  }

  .section {
    padding: 4rem 0;
  }

  .section-alt {
    background: var(--bg2);
    margin-inline: calc(-1 * var(--page-inline));
    padding-inline: var(--page-inline);
    box-sizing: border-box;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-title {
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 0;
  }

  .section-desc {
    color: var(--t2);
    margin: 0.35rem 0 0;
    font-size: 0.92rem;
  }

  .featured-section {
    padding-bottom: 0;
  }

  .featured-hero-card {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1.2fr);
    gap: 0;
    border: 1px solid var(--rule);
    border-radius: 22px;
    overflow: hidden;
    text-decoration: none;
    background: var(--surface);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s;
    box-shadow: 0 4px 20px rgba(28, 24, 20, 0.06);
  }

  .featured-hero-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(201, 169, 110, 0.18);
    border-color: var(--color-gold);
  }

  .featured-hero-thumb {
    min-height: 200px;
    max-height: 320px;
    overflow: hidden;
    background: var(--bg2);
  }

  .featured-hero-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .featured-hero-body {
    padding: clamp(1.25rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    justify-content: center;
  }

  .featured-hero-meta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem 0.75rem;
  }

  .featured-hero-views {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--t2);
    font-variant-numeric: tabular-nums;
  }

  .featured-hero-cat {
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--accent-dark);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .featured-hero-title {
    margin: 0;
    font-size: clamp(1.15rem, 2vw + 0.6rem, 1.55rem);
    font-weight: 800;
    color: var(--text);
    line-height: 1.35;
    letter-spacing: -0.02em;
  }

  .featured-hero-desc {
    margin: 0;
    font-size: 0.95rem;
    color: var(--t2);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .featured-hero-cta {
    margin-top: 0.35rem;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--accent-dark);
  }

  @media (max-width: 720px) {
    .featured-hero-card {
      grid-template-columns: 1fr;
    }

    .featured-hero-thumb {
      max-height: 220px;
      min-height: 180px;
    }
  }

  .section-more {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.35rem 0.15rem;
    color: var(--accent-dark);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    box-sizing: border-box;
  }

  .section-more:focus-visible {
    outline: 2px solid var(--accent, #b8956a);
