---
import Layout from '../layouts/Layout.astro';
---

<Layout title="로그인" description="에스리본 클리닉 — 소셜 계정으로 로그인합니다.">
  <div class="reader-login-page">
    <section class="reader-login-card" aria-labelledby="reader-login-title">
      <h1 id="reader-login-title" class="reader-login-title">로그인</h1>
      <p class="reader-login-lead">
        블로그 반응 등 일부 기능을 계정과 연결하려면 소셜 로그인을 이용하세요. 관리자 로그인은
        <a href="/admin/login/">/admin/login</a>에서 진행합니다.
      </p>
      <div class="reader-login-actions">
        <button type="button" class="reader-oauth-btn reader-oauth-google" data-oauth="google">
          <span class="reader-oauth-icon" aria-hidden="true">G</span>
          구글로 계속하기
        </button>
        <button type="button" class="reader-oauth-btn reader-oauth-kakao" data-oauth="kakao">
          <span class="reader-oauth-icon" aria-hidden="true">K</span>
          카카오로 계속하기
        </button>
      </div>
      <p class="reader-login-msg" data-login-msg role="status" aria-live="polite"></p>
    </section>
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { READER_RETURN_STORAGE_KEY, safeInternalPath } from '../lib/reader-auth';

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const msg = document.querySelector('[data-login-msg]');

  const setMsg = (t: string) => {
    if (msg) msg.textContent = t;
  };

  if (!supabaseUrl || !supabaseKey) {
    setMsg('Supabase 환경 변수가 설정되지 않았습니다.');
  } else {
    const params = new URLSearchParams(window.location.search);
    const fromQuery = params.get('return');
    if (fromQuery) {
      sessionStorage.setItem(READER_RETURN_STORAGE_KEY, safeInternalPath(fromQuery));
    } else {
      sessionStorage.setItem(READER_RETURN_STORAGE_KEY, '/');
    }

    const redirectTo = `${window.location.origin}/login/`;
    const supabase = createClient(supabaseUrl, supabaseKey, {
      auth: {
        persistSession: true,
        autoRefreshToken: true,
        detectSessionInUrl: true,
      },
    });

    const goAfterLogin = () => {
      const dest = safeInternalPath(sessionStorage.getItem(READER_RETURN_STORAGE_KEY) || '/');
      sessionStorage.removeItem(READER_RETURN_STORAGE_KEY);
      window.location.replace(dest);
    };

    supabase.auth.onAuthStateChange((event, session) => {
      if (event === 'SIGNED_IN' && session) goAfterLogin();
    });

    const { data: existing } = await supabase.auth.getSession();
    if (existing.session) goAfterLogin();

    document.querySelectorAll('[data-oauth]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const provider = btn.getAttribute('data-oauth') as 'google' | 'kakao' | null;
        if (!provider) return;
        setMsg('이동 중…');
        const { error } = await supabase.auth.signInWithOAuth({
          provider,
          options: { redirectTo },
        });
        if (error) setMsg(error.message);
      });
    });
  }
</script>

<style>
  .reader-login-page {
    max-width: 420px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 4rem;
  }

  .reader-login-card {
    padding: 1.75rem 1.5rem;
    border: 1px solid var(--rule);
    border-radius: 16px;
    background: var(--surface);
    box-shadow: 0 8px 28px rgba(28, 24, 20, 0.06);
  }

  .reader-login-title {
    margin: 0 0 0.75rem;
    font-size: 1.45rem;
    font-weight: 800;
  }

  .reader-login-lead {
    margin: 0 0 1.5rem;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--t2);
  }

  .reader-login-lead a {
    font-weight: 700;
  }

  .reader-login-actions {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .reader-oauth-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 48px;
    padding: 0.55rem 1rem;
    border-radius: 12px;
    border: 1px solid var(--rule);
    font: inherit;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition:
      border-color 0.15s ease,
      background 0.15s ease;
  }

  .reader-oauth-google {
    background: #fff;
    color: #1c1814;
  }

  .reader-oauth-google:hover {
    border-color: #4285f4;
  }

  .reader-oauth-kakao {
    background: #fee500;
    color: #191600;
    border-color: #e6cf00;
  }

  .reader-oauth-kakao:hover {
    filter: brightness(1.03);
  }

  .reader-oauth-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 900;
  }

  .reader-oauth-google .reader-oauth-icon {
    background: linear-gradient(135deg, #4285f4, #34a853);
    color: #fff;
  }

  .reader-oauth-kakao .reader-oauth-icon {
    background: #191600;
    color: #fee500;
  }

  .reader-login-msg {
    margin: 1rem 0 0;
    min-height: 1.25em;
    font-size: 0.86rem;
    color: var(--t2);
  }
</style>
