---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../consts';
import { blogPillarLabel } from '../../data/blog-nav';
import { isAcademyBlogPost, postPermalink } from '../../lib/academy';
import { blogTagPageHref } from '../../lib/blog-tag-url';
import { sortSeriesPosts } from '../../lib/blog-series';
import ContentImage from '../../components/ContentImage.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('blog', ({ data }) => !data.draft)).filter((p) => !isAcademyBlogPost(p));
	const seen = new Set<string>();
	for (const p of posts) {
		const s = String(p.data.series ?? '').trim();
		if (s) seen.add(s);
	}
	return [...seen].map((series) => ({
		params: { series },
	}));
}

const param = Astro.params.series ?? '';
let decodedSeries = '';
try {
	decodedSeries = decodeURIComponent(param);
} catch {
	decodedSeries = param;
}

const allClinic = (await getCollection('blog', ({ data }) => !data.draft))
	.filter((p) => !isAcademyBlogPost(p))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const matched = allClinic
	.filter((p) => String(p.data.series ?? '').trim() === decodedSeries)
	.sort(sortSeriesPosts);

const seriesPostIds = matched.map((p) => p.id);
const postIdsJson = JSON.stringify(seriesPostIds);
const pageTitle = decodedSeries ? `${decodedSeries} 시리즈` : '시리즈';
const seriesShareOrigin = Astro.site?.origin ?? Astro.url.origin;
const seriesShareUrl = `${seriesShareOrigin}/series/${encodeURIComponent(decodedSeries)}/`;
---

<Layout title={pageTitle} description={`에스리본 클리닉 — ${decodedSeries} 시리즈 글 모음`}>
	<div class="blog-layout">
		<Sidebar tagCloudPosts={allClinic} />

		<div class="blog-main">
			<div class="blog-header">
				<h1 class="blog-header-title">{decodedSeries || '시리즈'}</h1>
				{
					matched.length > 0 && (
						<div class="blog-series-complete-banner" data-series-complete hidden>
							<p class="blog-series-complete-msg">
								🎉 「{decodedSeries}」 시리즈를 완독했습니다!
							</p>
							<button type="button" class="btn btn-primary blog-series-share-btn" data-share-complete>
								완독 공유하기
							</button>
						</div>
					)
				}
				<p class="blog-series-meta">
					<a href="/blog/" class="blog-series-back">← 블로그 전체</a>
				</p>
				{
					matched.length > 0 && (
						<div class="blog-series-read-panel" data-series-read-panel>
							<div
								class="blog-series-progress-track"
								role="progressbar"
								aria-valuemin="0"
								aria-valuemax="100"
								aria-valuenow="0"
								data-series-progress-track
							>
								<div class="blog-series-progress-fill" data-series-progress-fill style="width: 0%"></div>
							</div>
							<p class="blog-series-read-panel-text">
								<strong data-series-hub-progress-detail>—</strong>
								<span class="blog-series-progress-hint">(이 브라우저에만 저장)</span>
							</p>
						</div>
					)
				}
			</div>

			{
				matched.length === 0 ? (
					<div class="blog-empty">
						<p>이 시리즈에 해당하는 글이 없습니다.</p>
						<a href="/blog/" class="btn btn-outline btn-sm">
							블로그로 돌아가기
						</a>
					</div>
				) : (
					<div class="blog-grid">
						{matched.map((post, index) => (
							<article class="blog-post-card blog-series-card" data-series-card-id={post.id}>
								<span class="blog-series-card-read-check" data-series-card-check hidden aria-hidden="true">
									✓
								</span>
								<a href={postPermalink(post)} class="blog-post-card-main">
									{post.data.thumbnail && (
										<div class="blog-post-card-thumb">
											<ContentImage
												src={post.data.thumbnail}
												alt={post.data.title}
												width={640}
												height={360}
												loading="lazy"
												decoding="async"
											/>
										</div>
									)}
									<div class="blog-post-card-body">
										<div class="blog-post-card-badges">
											<span class="blog-post-card-series-pill">{index + 1}편</span>
											{post.data.pillar && (
												<span class="blog-post-card-pillar">{blogPillarLabel(post.data.pillar)}</span>
											)}
											{post.data.category && (
												<span class="blog-post-card-cat">
													{CATEGORIES.find((c) => c.id === post.data.category)?.label ?? post.data.category}
												</span>
											)}
										</div>
										<h2 class="blog-post-card-title">{post.data.title}</h2>
										<p class="blog-post-card-desc">{post.data.description}</p>
									</div>
								</a>
								<div class="blog-post-card-footer">
									<time class="blog-post-card-date" datetime={post.data.date.toISOString()}>
										{
											new Intl.DateTimeFormat('ko-KR', {
												year: 'numeric',
												month: 'short',
												day: 'numeric',
											}).format(post.data.date)
										}
									</time>
									{post.data.tags &&
										post.data.tags.slice(0, 4).map((tag) => (
											<a href={blogTagPageHref(tag)} class="blog-post-card-tag">
												#{tag}
											</a>
										))}
								</div>
							</article>
						))}
					</div>
				)
			}
		</div>
	</div>

	<script
		is:inline
		define:vars={{
			seriesLabel: decodedSeries,
			postIdsJson,
			seriesShareUrl,
			seriesTotalPosts: matched.length,
		}}
	>
		(function () {
			var detailEl = document.querySelector('[data-series-hub-progress-detail]');
			var fillEl = document.querySelector('[data-series-progress-fill]');
			var trackEl = document.querySelector('[data-series-progress-track]');
			var bannerEl = document.querySelector('[data-series-complete]');
			var shareBtn = document.querySelector('[data-share-complete]');
			if (!seriesLabel || !detailEl) return;

			var SESSION_KEY = 'series_complete_seen_v1:' + encodeURIComponent(seriesLabel);

			function readKey(id) {
				return 'read:' + id;
			}

			function refreshSeriesHub() {
				var ids = [];
				try {
					ids = JSON.parse(postIdsJson || '[]');
				} catch (e) {
					ids = [];
				}
				var total = ids.length;
				var n = 0;
				for (var i = 0; i < total; i++) {
					if (localStorage.getItem(readKey(ids[i])) === 'true') n++;
				}
				var pct = total ? Math.round((n / total) * 100) : 0;

				detailEl.textContent = n + ' / ' + total + '편 완료 (' + pct + '%)';

				if (fillEl) fillEl.style.width = pct + '%';
				if (trackEl) {
					trackEl.setAttribute('aria-valuenow', String(pct));
					trackEl.setAttribute('aria-label', '시리즈 완독 진도 ' + pct + '%');
				}

				document.querySelectorAll('[data-series-card-id]').forEach(function (card) {
					var id = card.getAttribute('data-series-card-id');
					var check = card.querySelector('[data-series-card-check]');
					if (!id || !check) return;
					var done = localStorage.getItem(readKey(id)) === 'true';
					check.hidden = !done;
				});

				if (bannerEl) {
					if (total > 0 && n === total) {
						if (!sessionStorage.getItem(SESSION_KEY)) {
							bannerEl.hidden = false;
							sessionStorage.setItem(SESSION_KEY, '1');
						} else {
							bannerEl.hidden = true;
						}
					} else {
						bannerEl.hidden = true;
					}
				}
			}

			refreshSeriesHub();
			window.addEventListener('storage', function (e) {
				if (e.key && e.key.indexOf('read:') === 0) refreshSeriesHub();
			});

			if (shareBtn) {
				shareBtn.addEventListener('click', function () {
					var body =
						"S-Reborn AI Blog의 '" +
						seriesLabel +
						"' 시리즈를 완독했습니다.\n의료 AI 핵심 개념 " +
						seriesTotalPosts +
						'편 → ' +
						seriesShareUrl;
					if (navigator.share) {
						navigator.share({ text: body, url: seriesShareUrl }).catch(function () {});
					} else if (navigator.clipboard && navigator.clipboard.writeText) {
						navigator.clipboard.writeText(body).then(function () {
							var t = shareBtn.textContent;
							shareBtn.textContent = '복사했습니다';
							setTimeout(function () {
								shareBtn.textContent = t;
							}, 2000);
						});
					}
				});
			}
		})();
	</script>
</Layout>

<style>
	.blog-series-meta {
		margin: 0.35rem 0 0;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1rem;
		font-size: 0.88rem;
		color: var(--t2);
	}

	.blog-series-complete-banner {
		margin: 0.75rem 0 1rem;
		padding: 1rem 1.15rem;
		border-radius: 14px;
		border: 1px solid var(--rule);
		background: linear-gradient(135deg, rgba(184, 149, 106, 0.18), rgba(184, 149, 106, 0.06));
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem 1rem;
	}

	.blog-series-complete-msg {
		margin: 0;
		flex: 1;
		min-width: 12rem;
		font-size: 0.95rem;
		font-weight: 800;
		color: var(--text);
	}

	.blog-series-read-panel {
		margin: 0.5rem 0 1.25rem;
		max-width: 36rem;
	}

	.blog-series-progress-track {
		height: 0.45rem;
		border-radius: 999px;
		background: var(--bg2, rgba(0, 0, 0, 0.06));
		overflow: hidden;
		border: 1px solid var(--rule);
	}

	.blog-series-progress-fill {
		height: 100%;
		border-radius: inherit;
		background: linear-gradient(90deg, var(--accent-dark, #8c6d45), var(--accent, #b8956a));
		transition: width 0.35s ease;
	}

	.blog-series-read-panel-text {
		margin: 0.45rem 0 0;
		font-size: 0.88rem;
		color: var(--t2);
	}

	.blog-series-read-panel-text strong {
		color: var(--text);
		font-weight: 800;
	}

	.blog-series-back {
		color: var(--accent-dark);
		font-weight: 700;
		text-decoration: none;
	}

	.blog-series-back:hover {
		text-decoration: underline;
	}

	.blog-series-progress-hint {
		margin-left: 0.35rem;
		font-size: 0.78rem;
		color: var(--t3);
	}

	.blog-series-card {
		position: relative;
	}

	.blog-series-card-read-check {
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		z-index: 2;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 1.65rem;
		height: 1.65rem;
		border-radius: 999px;
		font-size: 0.95rem;
		font-weight: 800;
		color: #fff;
		background: var(--accent-dark, #8c6d45);
		box-shadow: 0 2px 8px rgba(28, 25, 23, 0.12);
	}

	.blog-post-card-series-pill {
		font-size: 0.68rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--accent-dark);
		background: rgba(184, 149, 106, 0.16);
		padding: 0.2rem 0.5rem;
		border-radius: 8px;
		border: 1px solid var(--rule);
	}
</style>
