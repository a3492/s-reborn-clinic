---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';

const { id } = Astro.params;
---

<AdminLayout
  title="상담 상세"
  pageTitle="상담 신청 상세"
  pageDescription="상담 신청 내용 확인 및 상태 관리"
  status="Consultations"
>
  <div id="detail-loading" class="admin-card pad-lg" style="text-align:center;color:var(--admin-t2,#6b7280);padding:3rem;">
    불러오는 중...
  </div>

  <div id="detail-wrap" hidden>
    <!-- 상단 헤더 -->
    <div class="detail-header admin-card pad-lg">
      <div class="detail-header-left">
        <a href="/admin/consultations" class="admin-back-link">← 목록으로</a>
        <h2 class="detail-name" id="d-name">—</h2>
        <p class="detail-sub" id="d-sub">—</p>
      </div>
      <div class="detail-header-right">
        <span class="status-badge" id="d-status-badge">—</span>
      </div>
    </div>

    <div class="detail-grid">
      <!-- 좌측: 기본정보 + 고민 + AI 분석 -->
      <div class="detail-col-main">

        <!-- 기본 정보 -->
        <div class="admin-card pad-lg">
          <h3 class="admin-section-title">기본 정보</h3>
          <dl class="info-grid">
            <dt>이름</dt><dd id="d-name2">—</dd>
            <dt>연락처</dt><dd id="d-phone">—</dd>
            <dt>연령대</dt><dd id="d-age">—</dd>
            <dt>성별</dt><dd id="d-gender">—</dd>
            <dt>언어</dt><dd id="d-lang">—</dd>
            <dt>선호 상담</dt><dd id="d-contact">—</dd>
            <dt>접수일시</dt><dd id="d-date">—</dd>
          </dl>
          <div class="detail-actions" style="margin-top:1rem;display:flex;gap:0.75rem;">
            <a id="d-kakao-btn" href="#" class="admin-btn admin-btn-primary" target="_blank" rel="noopener">
              카카오 채널 열기
            </a>
            <a id="d-tel-btn" href="#" class="admin-btn">
              전화 연결
            </a>
          </div>
        </div>

        <!-- 선택 고민 -->
        <div class="admin-card pad-lg">
          <h3 class="admin-section-title">선택한 고민</h3>
          <ul class="concern-list" id="d-concerns">
            <li>—</li>
          </ul>
        </div>

        <!-- 상세 답변 -->
        <div class="admin-card pad-lg" id="d-answers-card">
          <h3 class="admin-section-title">상세 답변</h3>
          <dl class="answers-grid" id="d-answers">
            <dt>—</dt><dd>—</dd>
          </dl>
        </div>

        <!-- AI 분석 -->
        <div class="admin-card pad-lg" id="d-ai-card">
          <h3 class="admin-section-title">AI 분석 결과</h3>
          <div class="ai-summary" id="d-ai-summary"></div>
          <div class="ai-recs" id="d-ai-recs"></div>
        </div>
      </div>

      <!-- 우측: 상태 관리 -->
      <div class="detail-col-side">
        <div class="admin-card pad-lg sticky-panel">
          <h3 class="admin-section-title">상태 관리</h3>

          <label class="admin-field-label" for="status-select">진행 상태</label>
          <select id="status-select" class="admin-select">
            <option value="new">새 상담</option>
            <option value="reviewing">검토중</option>
            <option value="contacted">연락완료</option>
            <option value="completed">완료</option>
          </select>

          <label class="admin-field-label" for="assigned-to" style="margin-top:1rem;">담당자</label>
          <input id="assigned-to" type="text" class="admin-input" placeholder="담당자 이름" />

          <label class="admin-field-label" for="admin-note" style="margin-top:1rem;">관리자 메모</label>
          <textarea id="admin-note" class="admin-textarea" rows="5" placeholder="내부 메모를 입력하세요..."></textarea>

          <button id="save-btn" class="admin-btn admin-btn-primary" style="width:100%;margin-top:1rem;">
            저장
          </button>
          <p id="save-msg" class="save-msg" hidden></p>
        </div>
      </div>
    </div>
  </div>

  <div id="detail-error" hidden class="admin-card pad-lg" style="text-align:center;color:#dc2626;padding:3rem;">
    상담 신청을 찾을 수 없습니다. <a href="/admin/consultations" class="admin-link">목록으로 돌아가기</a>
  </div>

  <script define:vars={{ consultationId: id }}>
    const STATUS_LABEL = {
      new: '새 상담',
      reviewing: '검토중',
      contacted: '연락완료',
      completed: '완료',
    };

    const STATUS_CLASS = {
      new: 'badge-new',
      reviewing: 'badge-reviewing',
      contacted: 'badge-contacted',
      completed: 'badge-completed',
    };

    const LANG_LABEL = { ko: '한국어', zh: '中文', ja: '日本語', en: 'English' };

    function fmt(iso) {
      return new Intl.DateTimeFormat('ko-KR', {
        year: 'numeric', month: 'long', day: 'numeric',
        hour: '2-digit', minute: '2-digit',
        timeZone: 'Asia/Seoul',
      }).format(new Date(iso));
    }

    function setEl(id, value) {
      const el = document.getElementById(id);
      if (el) el.textContent = value || '—';
    }

    async function loadDetail() {
      const loadingEl = document.getElementById('detail-loading');
      const wrapEl = document.getElementById('detail-wrap');
      const errorEl = document.getElementById('detail-error');

      try {
        const res = await fetch(`/api/admin/consultations/${consultationId}`);
        const json = await res.json();

        if (!json.ok || !json.data) {
          loadingEl.hidden = true;
          errorEl.hidden = false;
          return;
        }

        const d = json.data;

        // 기본 정보
        setEl('d-name', d.name);
        setEl('d-name2', d.name);
        setEl('d-sub', `${d.age_range || '—'} / ${d.gender || '—'} · ${LANG_LABEL[d.language] || d.language || '한국어'}`);
        setEl('d-phone', d.phone);
        setEl('d-age', d.age_range);
        setEl('d-gender', d.gender);
        setEl('d-lang', LANG_LABEL[d.language] || d.language || '한국어');
        setEl('d-contact', d.preferred_contact);
        setEl('d-date', fmt(d.created_at));

        // 액션 버튼
        const kakaoBtn = document.getElementById('d-kakao-btn');
        const telBtn = document.getElementById('d-tel-btn');
        if (kakaoBtn) kakaoBtn.href = 'https://pf.kakao.com/_placeholder'; // 실제 카카오채널 URL로 교체
        if (telBtn) telBtn.href = `tel:${d.phone}`;

        // 상태 뱃지
        const badge = document.getElementById('d-status-badge');
        if (badge) {
          badge.textContent = STATUS_LABEL[d.status] || d.status;
          badge.className = `status-badge ${STATUS_CLASS[d.status] || ''}`;
        }

        // 고민 목록
        const concernsEl = document.getElementById('d-concerns');
        if (concernsEl && d.concerns?.length) {
          concernsEl.innerHTML = d.concerns.map(c =>
            `<li><span class="concern-label">${c.label}</span></li>`
          ).join('');
        }

        // 상세 답변
        const answersEl = document.getElementById('d-answers');
        if (answersEl && d.answers && Object.keys(d.answers).length) {
          answersEl.innerHTML = Object.entries(d.answers).map(([q, a]) =>
            `<dt>${q}</dt><dd>${Array.isArray(a) ? a.join(', ') : a}</dd>`
          ).join('');
        } else {
          document.getElementById('d-answers-card').hidden = true;
        }

        // AI 분석
        const summaryEl = document.getElementById('d-ai-summary');
        const recsEl = document.getElementById('d-ai-recs');
        if (d.ai_summary && summaryEl) {
          summaryEl.innerHTML = `<p class="ai-summary-text">${d.ai_summary}</p>`;
        }
        if (d.ai_recommendations?.length && recsEl) {
          recsEl.innerHTML = `
            <h4 class="ai-recs-title">추천 방향</h4>
            <ol class="ai-recs-list">
              ${d.ai_recommendations.map(r =>
                `<li>
                  <strong>${r.title || ''}</strong>
                  <p>${r.description || ''}</p>
                  ${r.reasoning ? `<p class="ai-reasoning">${r.reasoning}</p>` : ''}
                </li>`
              ).join('')}
            </ol>
          `;
        }
        if (!d.ai_summary && !d.ai_recommendations?.length) {
          document.getElementById('d-ai-card').hidden = true;
        }

        // 사이드 패널 초기값
        const statusSelect = document.getElementById('status-select');
        const assignedTo = document.getElementById('assigned-to');
        const adminNote = document.getElementById('admin-note');
        if (statusSelect) statusSelect.value = d.status || 'new';
        if (assignedTo) assignedTo.value = d.assigned_to || '';
        if (adminNote) adminNote.value = d.admin_note || '';

        loadingEl.hidden = true;
        wrapEl.hidden = false;
      } catch (e) {
        loadingEl.hidden = true;
        errorEl.hidden = false;
      }
    }

    // 저장
    document.getElementById('save-btn')?.addEventListener('click', async () => {
      const saveBtn = document.getElementById('save-btn');
      const saveMsg = document.getElementById('save-msg');
      const statusSelect = document.getElementById('status-select');
      const assignedTo = document.getElementById('assigned-to');
      const adminNote = document.getElementById('admin-note');

      saveBtn.disabled = true;
      saveBtn.textContent = '저장 중...';
      saveMsg.hidden = true;

      try {
        const res = await fetch(`/api/admin/consultations/${consultationId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            status: statusSelect.value,
            assigned_to: assignedTo.value,
            admin_note: adminNote.value,
          }),
        });
        const json = await res.json();

        if (json.ok) {
          saveMsg.textContent = '저장되었습니다.';
          saveMsg.className = 'save-msg save-ok';
          // 뱃지 업데이트
          const badge = document.getElementById('d-status-badge');
          if (badge) {
            badge.textContent = STATUS_LABEL[statusSelect.value] || statusSelect.value;
            badge.className = `status-badge ${STATUS_CLASS[statusSelect.value] || ''}`;
          }
        } else {
          saveMsg.textContent = `오류: ${json.error || '저장 실패'}`;
          saveMsg.className = 'save-msg save-err';
        }
      } catch {
        saveMsg.textContent = '네트워크 오류. 다시 시도해 주세요.';
        saveMsg.className = 'save-msg save-err';
      } finally {
        saveMsg.hidden = false;
        saveBtn.disabled = false;
        saveBtn.textContent = '저장';
      }
    });

    loadDetail();
  </script>
</AdminLayout>

<style>
  .detail-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .admin-back-link {
    display: inline-block;
    font-size: 0.84rem;
    color: var(--admin-accent, #b8895e);
    text-decoration: none;
    margin-bottom: 0.5rem;
    font-weight: 600;
  }

  .admin-back-link:hover { text-decoration: underline; }

  .detail-name {
    margin: 0 0 0.2rem;
    font-size: 1.4rem;
    font-weight: 800;
  }

  .detail-sub {
    margin: 0;
    font-size: 0.88rem;
    color: var(--admin-t2, #6b7280);
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 1rem;
    align-items: flex-start;
  }

  .detail-col-main {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .detail-col-side {
    position: sticky;
    top: 1rem;
  }

  .sticky-panel { display: flex; flex-direction: column; }

  .info-grid {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0.5rem 1rem;
    margin: 0;
  }

  .info-grid dt {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--admin-t2, #6b7280);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding-top: 0.1rem;
  }

  .info-grid dd {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 500;
  }

  .concern-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .concern-label {
    display: inline-block;
    padding: 0.3rem 0.7rem;
    background: rgba(184,138,94,0.1);
    border: 1px solid rgba(184,138,94,0.25);
    border-radius: 999px;
    font-size: 0.84rem;
    font-weight: 600;
    color: #7c5c32;
  }

  .answers-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem 1.5rem;
    margin: 0;
  }

  .answers-grid dt {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--admin-t2, #6b7280);
    grid-column: 1;
  }

  .answers-grid dd {
    margin: 0;
    font-size: 0.88rem;
    grid-column: 2;
  }

  .ai-summary-text {
    margin: 0 0 1rem;
    padding: 0.75rem 1rem;
    background: rgba(184,138,94,0.07);
    border-left: 3px solid #c9a96e;
    border-radius: 0 8px 8px 0;
    line-height: 1.6;
    font-size: 0.92rem;
  }

  .ai-recs-title {
    font-size: 0.9rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--admin-t2, #6b7280);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .ai-recs-list {
    margin: 0;
    padding-left: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ai-recs-list li strong {
    font-size: 0.94rem;
  }

  .ai-recs-list li p {
    margin: 0.2rem 0 0;
    font-size: 0.86rem;
    color: var(--admin-t2, #6b7280);
    line-height: 1.5;
  }

  .ai-reasoning {
    font-size: 0.78rem !important;
    font-style: italic;
    color: #9ca3af !important;
  }

  .admin-field-label {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--admin-t2, #6b7280);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.35rem;
  }

  .admin-input, .admin-select, .admin-textarea {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--admin-rule, #e5e7eb);
    border-radius: 8px;
    font-size: 0.88rem;
    background: var(--admin-bg, #fff);
    color: var(--admin-text, #1f2937);
    box-sizing: border-box;
  }

  .admin-textarea { resize: vertical; font-family: inherit; }

  .status-badge {
    display: inline-block;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
    border: 1px solid transparent;
  }

  .badge-new { background:#fef3c7; color:#92400e; border-color:#fde68a; }
  .badge-reviewing { background:#dbeafe; color:#1e40af; border-color:#bfdbfe; }
  .badge-contacted { background:#d1fae5; color:#065f46; border-color:#a7f3d0; }
  .badge-completed { background:#f3f4f6; color:#374151; border-color:#e5e7eb; }

  .save-msg {
    margin: 0.5rem 0 0;
    font-size: 0.82rem;
    text-align: center;
    padding: 0.4rem;
    border-radius: 6px;
  }

  .save-ok { background: #d1fae5; color: #065f46; }
  .save-err { background: #fee2e2; color: #991b1b; }

  .admin-link {
    color: var(--admin-accent, #b8895e);
    font-weight: 700;
    text-decoration: none;
  }

  .admin-btn-primary {
    background: var(--admin-accent, #b8895e);
    color: #fff;
    border: none;
  }

  .admin-btn-primary:hover { opacity: 0.9; }

  @media (max-width: 900px) {
    .detail-grid { grid-template-columns: 1fr; }
    .detail-col-side { position: static; }
  }
</style>
