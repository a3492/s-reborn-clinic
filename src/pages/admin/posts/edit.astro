---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { CATEGORIES } from '../../../consts';

const slug = Astro.url.searchParams.get('slug') ?? '';
---

<AdminLayout
  title="Edit Post"
  pageTitle="Edit Post"
  pageDescription="기존 draft를 수정하고 revision을 추가합니다."
  status="Draft Edit"
>
  <div class="admin-split">
    <section class="admin-card pad-lg">
      <div class="admin-actions-row">
        <div>
          <h2 class="admin-section-title">Editor</h2>
          <p class="admin-section-desc">선택한 글을 불러와 수정하고, preview 또는 publish 요청을 실행합니다.</p>
        </div>
        <div class="admin-actions-cluster">
          <a href="/admin/posts/preview" class="admin-btn" data-admin-edit-preview-link>저장본 미리보기</a>
          <button type="button" class="admin-btn" data-admin-publish-dryrun>Publish Dry Run</button>
          <button type="button" class="admin-btn" data-admin-publish-live>Publish 요청</button>
          <button type="button" class="admin-btn" data-admin-save-as-template>템플릿으로 저장</button>
          <button type="submit" form="admin-edit-post-form" class="admin-btn primary" data-admin-save-button>변경 저장</button>
        </div>
      </div>

      <form id="admin-edit-post-form" class="admin-form-grid" data-admin-edit-post-form>
        <div class="admin-field full">
          <label class="admin-label" for="title">제목</label>
          <input id="title" name="title" class="admin-input" type="text" required />
        </div>

        <div class="admin-field full admin-ab-test-wrap" data-admin-ab-root>
          <p class="admin-label" style="margin-bottom: 0.35rem">제목 A/B 테스트</p>
          <p class="admin-help" style="margin-top: 0">
            목록 카드에만 B안 제목이 노출됩니다. 승자 확정 전까지 <code>posts.title</code>(본문·발행용)은 바꾸지 않습니다.
          </p>
          <label class="admin-label" for="title_ab_b">제목 B (A/B 테스트용)</label>
          <input
            id="title_ab_b"
            name="title_ab_b"
            class="admin-input"
            type="text"
            data-ab-title-b
            placeholder="A안은 위「제목」필드와 동일하게 취급됩니다"
          />
          <div class="admin-actions-cluster" style="margin-top: 0.65rem">
            <button type="button" class="admin-btn" data-ab-start>테스트 시작</button>
          </div>
          <div class="admin-ab-stats" data-ab-stats hidden>
            <p class="admin-item-title" style="margin: 0.75rem 0 0.35rem">진행 중 통계</p>
            <ul class="admin-list" style="margin-bottom: 0.75rem">
              <li class="admin-list-row" data-ab-row-a>
                <div>
                  <p class="admin-item-title">A안</p>
                  <p class="admin-item-meta" data-ab-line-a>노출 0회 · 클릭 0회 · CTR 0%</p>
                </div>
              </li>
              <li class="admin-list-row" data-ab-row-b>
                <div>
                  <p class="admin-item-title">B안</p>
                  <p class="admin-item-meta" data-ab-line-b>노출 0회 · 클릭 0회 · CTR 0%</p>
                </div>
              </li>
            </ul>
            <div class="admin-actions-cluster">
              <button type="button" class="admin-btn primary" data-ab-winner="a">승자: A안 → 제목 반영</button>
              <button type="button" class="admin-btn primary" data-ab-winner="b">승자: B안 → 제목 반영</button>
            </div>
          </div>
          <p class="admin-inline-note" data-ab-msg hidden></p>
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="description">설명</label>
          <textarea id="description" name="description" class="admin-textarea" style="min-height: 100px;" required></textarea>
        </div>

        <div class="admin-field">
          <label class="admin-label" for="slug">Slug</label>
          <input id="slug" name="slug" class="admin-input" type="text" required />
        </div>

        <div class="admin-field">
          <label class="admin-label" for="category">글 유형</label>
          <select id="category" name="category" class="admin-select">
            {CATEGORIES.map((c) => (
              <option value={c.id}>{c.label}</option>
            ))}
          </select>
        </div>

        <div class="admin-field">
          <label class="admin-label" for="date">발행일</label>
          <input id="date" name="date" class="admin-input" type="datetime-local" />
        </div>

        <div class="admin-field">
          <label class="admin-label" for="scheduled_at_date">예약 발행일</label>
          <input id="scheduled_at_date" name="scheduled_at_date" class="admin-input" type="date" />
          <span class="admin-help">캘린더에 표시할 예정일입니다. 비우면 일정에서 제외됩니다.</span>
        </div>

        <div class="admin-field">
          <label class="admin-label" for="status">상태</label>
          <select id="status" name="status" class="admin-select">
            <option value="draft">draft</option>
            <option value="review">review</option>
            <option value="scheduled">scheduled</option>
            <option value="published">published</option>
            <option value="archived">archived</option>
          </select>
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="thumbnail_url">Thumbnail URL</label>
          <input id="thumbnail_url" name="thumbnail_url" class="admin-input" type="url" />
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="tags">태그</label>
          <input id="tags" name="tags" class="admin-input" type="text" />
        </div>

        <div class="admin-field">
          <label class="admin-label" for="seo_title">SEO Title</label>
          <input id="seo_title" name="seo_title" class="admin-input" type="text" />
        </div>

        <div class="admin-field">
          <label class="admin-label" for="canonical_url">Canonical URL</label>
          <input id="canonical_url" name="canonical_url" class="admin-input" type="url" />
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="seo_description">SEO Description</label>
          <textarea id="seo_description" name="seo_description" class="admin-textarea" style="min-height: 110px;"></textarea>
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="body">본문 Markdown</label>
          <textarea id="body" name="body" class="admin-textarea"></textarea>
        </div>
      </form>

      <p class="admin-inline-note" data-admin-edit-post-message hidden></p>
    </section>

    <div class="admin-panel-stack">
      <section class="admin-card pad-md admin-quality-card" data-admin-quality-panel>
        <h2 class="admin-section-title">품질 점수</h2>
        <p class="admin-section-desc">「변경 저장」에 성공한 뒤에만 점수·체크리스트가 갱신됩니다.</p>
        <p class="admin-quality-score-line" data-admin-quality-score>점수: —</p>
        <ul class="admin-list admin-quality-checklist" data-admin-quality-checklist>
          <li class="admin-list-row"><p class="admin-help">폼을 불러오는 중…</p></li>
        </ul>
      </section>

      <section class="admin-card pad-md" data-admin-social-preview-card>
        <div class="admin-actions-row">
          <div>
            <h2 class="admin-section-title">소셜 미리보기</h2>
            <p class="admin-section-desc">트위터·카카오·슬랙에서 링크를 공유할 때 보이는 카드를 시뮬레이션합니다. (외부 API·iframe 없음)</p>
          </div>
        </div>

        <div class="admin-social-tabs" role="tablist" aria-label="소셜 플랫폼">
          <button type="button" class="admin-btn admin-btn-sm admin-social-tab" role="tab" data-social-tab="twitter" aria-selected="true">Twitter / X</button>
          <button type="button" class="admin-btn admin-btn-sm admin-social-tab" role="tab" data-social-tab="kakao" aria-selected="false">카카오톡</button>
          <button type="button" class="admin-btn admin-btn-sm admin-social-tab" role="tab" data-social-tab="slack" aria-selected="false">슬랙</button>
        </div>

        <div class="admin-social-panel-stack">
          <div class="admin-social-panel" role="tabpanel" data-social-panel="twitter">
            <div class="og-preview og-preview--twitter">
              <div class="og-preview__image" data-social-og-img-wrap>
                <img data-social-og-img src="" alt="" loading="lazy" hidden />
                <div class="og-preview__placeholder" data-social-img-placeholder>이미지 없음</div>
              </div>
              <div class="og-preview__body">
                <p class="og-preview__domain" data-social-domain>s-reborn-blog.pages.dev</p>
                <p class="og-preview__title" data-social-title>(제목)</p>
                <p class="og-preview__desc" data-social-desc></p>
              </div>
            </div>
          </div>

          <div class="admin-social-panel" role="tabpanel" data-social-panel="kakao" hidden>
            <div class="og-preview og-preview--kakao">
              <div class="og-preview__image og-preview__image--sm" data-social-kakao-img-wrap>
                <img data-social-kakao-img src="" alt="" loading="lazy" hidden />
                <div class="og-preview__placeholder og-preview__placeholder--sm" data-social-kakao-placeholder>이미지 없음</div>
              </div>
              <div class="og-preview__body">
                <p class="og-preview__title" data-social-kakao-title>(제목)</p>
                <p class="og-preview__domain" data-social-kakao-domain>s-reborn-blog.pages.dev</p>
              </div>
            </div>
          </div>

          <div class="admin-social-panel" role="tabpanel" data-social-panel="slack" hidden>
            <div class="og-preview og-preview--slack">
              <div class="og-preview__slack-thumb" data-social-slack-img-wrap>
                <img data-social-slack-img src="" alt="" loading="lazy" hidden />
                <div class="og-preview__placeholder og-preview__placeholder--slack" data-social-slack-placeholder>—</div>
              </div>
              <div class="og-preview__slack-main">
                <p class="og-preview__slack-title" data-social-slack-title>(제목)</p>
                <p class="og-preview__slack-domain" data-social-slack-domain>s-reborn-blog.pages.dev</p>
                <p class="og-preview__slack-desc" data-social-slack-desc></p>
              </div>
            </div>
          </div>
        </div>

        <div class="admin-social-share-actions">
          <span class="admin-help" style="margin: 0 0.35rem 0 0">공유 URL 복사</span>
          <button type="button" class="admin-btn admin-btn-sm" data-copy-share="twitter">Twitter</button>
          <button type="button" class="admin-btn admin-btn-sm" data-copy-share="kakao">카카오 스토리</button>
          <button type="button" class="admin-btn admin-btn-sm" data-copy-share="link">글 링크</button>
        </div>

        <h3 class="admin-section-title" style="font-size: 0.95rem; margin-top: 1rem">메타 점검</h3>
        <p class="admin-help">항목을 클릭하면 해당 입력란으로 포커스가 이동합니다.</p>
        <ul class="admin-list admin-social-meta-check" data-admin-social-checklist></ul>

        <div class="admin-social-fetch-block" data-admin-social-fetch-wrap hidden>
          <button type="button" class="admin-btn admin-btn-sm" data-admin-social-fetch>실제 확인 (발행 페이지 HTML)</button>
          <p class="admin-help" data-admin-social-fetch-hint hidden style="margin-top: 0.35rem"></p>
          <pre class="admin-social-fetch-result" data-admin-social-fetch-result hidden></pre>
        </div>
      </section>

      <section class="admin-card pad-md">
        <h2 class="admin-section-title">Entry State</h2>
        <ul class="admin-list" data-admin-edit-meta>
          <li class="admin-list-row"><div><p class="admin-item-title">불러오는 중...</p></div></li>
        </ul>
        <ul class="admin-list" style="margin-top:0.5rem;" data-admin-release-state>
          <li class="admin-list-row"><div><p class="admin-item-title">불러오는 중...</p></div></li>
        </ul>
      </section>

      <section class="admin-card pad-md" data-admin-content-review-card>
        <h2 class="admin-section-title">의료 정보 검토</h2>
        <p class="admin-item-meta" data-admin-review-line>최종 검토: —</p>
        <p class="admin-inline-note" data-admin-review-flag hidden style="margin: 0.35rem 0;">🔄 목록에 검토 필요로 표시됨</p>
        <div class="admin-field" style="margin-top: 0.65rem;">
          <label class="admin-label" for="review_interval_days">재검토 주기(일)</label>
          <input
            form="admin-edit-post-form"
            id="review_interval_days"
            name="review_interval_days"
            class="admin-input"
            type="number"
            min="30"
            max="365"
            step="1"
            value="180"
          />
          <span class="admin-help">30~365일.「변경 저장」 시 이 글에만 적용됩니다.</span>
        </div>
        <div class="admin-actions-cluster" style="margin-top: 0.65rem;">
          <button type="button" class="admin-btn primary" data-admin-review-complete>검토 완료</button>
        </div>
        <p class="admin-help" style="margin-top: 0.5rem;">
          검토 완료 시 오늘을 기준으로 기록되며 검토 필요 표시만 해제됩니다. 발행일은 바뀌지 않습니다.
        </p>
      </section>

      <section class="admin-card pad-md">
        <div class="admin-actions-row">
          <h2 class="admin-section-title">Publish History</h2>
          <a href="/admin/jobs" class="admin-btn admin-btn-sm">Jobs</a>
        </div>
        <div data-admin-publish-history-summary>
          <p class="admin-help">불러오는 중...</p>
        </div>
      </section>

      <section class="admin-card pad-md">
        <div class="admin-actions-row">
          <div>
            <h2 class="admin-section-title">Publish Pipeline</h2>
            <p class="admin-section-desc">요청 직후 current job 상태를 이 패널에서 추적합니다.</p>
          </div>
          <a href="/admin/jobs" class="admin-btn">Jobs 보기</a>
        </div>
        <ul class="admin-list">
          <li class="admin-list-row"><div><p class="admin-item-title">Dry Run</p><p class="admin-item-meta">Markdown preview와 target path만 확인</p></div></li>
          <li class="admin-list-row"><div><p class="admin-item-title">Live Publish</p><p class="admin-item-meta">publish_jobs 생성 후 GitHub Contents API 호출</p></div></li>
        </ul>
        <div class="admin-job-card" data-admin-current-job hidden>
          <div class="admin-job-card-head">
            <strong data-admin-current-job-title>현재 publish job</strong>
            <span class="admin-status pending" data-admin-current-job-status>pending</span>
          </div>
          <p class="admin-job-card-path" data-admin-current-job-path>-</p>
          <p class="admin-job-card-meta" data-admin-current-job-meta>job 상태를 기다리는 중입니다.</p>
        </div>
      </section>

      <section class="admin-card pad-md" data-admin-publish-warnings-section hidden>
        <h2 class="admin-section-title">발행 품질 경고 (Dry Run)</h2>
        <p class="admin-help">아래는 발행을 막지 않는 권고입니다. 확인 후에만 &ldquo;그래도 발행&rdquo;을 사용할 수 있습니다.</p>
        <div class="admin-dryrun-warnings">
          <ul class="admin-dryrun-warnings-list" data-admin-dryrun-warnings-list></ul>
          <label class="admin-dryrun-warnings-ack">
            <input type="checkbox" data-admin-warnings-ack />
            위 경고를 확인했습니다.
          </label>
        </div>
        <div class="admin-warnings-anyway-footer">
          <button type="button" class="admin-btn primary" data-admin-publish-anyway hidden disabled>
            그래도 발행
          </button>
        </div>
      </section>

      <section class="admin-card pad-md">
        <details class="admin-details-block" data-admin-version-history-details>
          <summary class="admin-section-title" style="cursor: pointer; list-style: none">버전 히스토리</summary>
          <p class="admin-help" style="margin-top: 0.5rem">
            저장·발행 시점의 제목·본문 스냅샷입니다. 복원은 편집창만 채우며, 저장은 직접 진행합니다.
          </p>
          <ul class="admin-list" style="margin-top: 0.5rem" data-admin-version-list>
            <li class="admin-list-row"><p class="admin-help">불러오는 중…</p></li>
          </ul>
        </details>
      </section>

      <section class="admin-card pad-md" data-admin-poll-section>
        <h2 class="admin-section-title">투표 설정</h2>
        <p class="admin-section-desc">글당 1개만 등록할 수 있습니다. 현재 저장된 slug와 동일한 키로 블로그에 노출됩니다.</p>
        <div data-admin-poll-current>
          <p class="admin-help">불러오는 중…</p>
        </div>
        <div data-admin-poll-form-wrap hidden>
          <label class="admin-label" for="admin-poll-question">질문</label>
          <input
            id="admin-poll-question"
            class="admin-input"
            type="text"
            maxlength="500"
            data-admin-poll-question
            placeholder="예: AI를 진료에 활용하고 계신가요?"
          />
          <p class="admin-help" style="margin-top: 0.75rem">선택지 (2~4개, id는 영문·숫자 권장)</p>
          <ul class="admin-list" style="margin-top: 0.35rem" data-admin-poll-options></ul>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.5rem">
            <button type="button" class="admin-btn admin-btn-sm" data-admin-poll-add-option>항목 추가</button>
          </div>
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem">
            <button type="button" class="admin-btn primary" data-admin-poll-create>투표 생성</button>
          </div>
        </div>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 0.75rem">
          <button type="button" class="admin-btn" data-admin-poll-delete hidden>투표 삭제</button>
        </div>
        <div style="margin-top: 1rem" data-admin-poll-preview-wrap>
          <h3 class="admin-section-title" style="font-size: 0.95rem">결과 미리보기</h3>
          <ul class="admin-list" style="margin-top: 0.35rem" data-admin-poll-preview-list>
            <li class="admin-list-row"><p class="admin-help">—</p></li>
          </ul>
        </div>
        <p class="admin-help admin-help-error" data-admin-poll-msg hidden style="margin-top: 0.75rem"></p>
      </section>
    </div>
  </div>

  <div
    id="post-save-summary-modal"
    class="post-version-modal-root"
    data-post-save-summary-modal
    hidden
    role="dialog"
    aria-modal="true"
    aria-labelledby="post-save-summary-title"
  >
    <div class="post-version-modal-backdrop" data-post-save-summary-close tabindex="-1" aria-hidden="true"></div>
    <div class="post-version-modal-box">
      <h2 id="post-save-summary-title" class="post-version-modal-title">변경 저장</h2>
      <p class="admin-help">변경 요약은 선택입니다.</p>
      <label class="admin-label" for="post-save-summary-input">변경 요약</label>
      <textarea
        id="post-save-summary-input"
        class="admin-textarea"
        maxlength="500"
        rows="3"
        placeholder="예: 시술 문구 수정, 금기 추가"
      ></textarea>
      <div class="post-version-modal-actions">
        <button type="button" class="admin-btn" data-post-save-summary-cancel>취소</button>
        <button type="button" class="admin-btn primary" data-post-save-summary-confirm>저장 진행</button>
      </div>
    </div>
  </div>

  <div
    id="post-template-save-modal"
    class="post-version-modal-root"
    data-admin-template-save-modal
    hidden
    role="dialog"
    aria-modal="true"
    aria-labelledby="post-template-save-title"
  >
    <div class="post-version-modal-backdrop" data-admin-template-save-close tabindex="-1" aria-hidden="true"></div>
    <div class="post-version-modal-box">
      <h2 id="post-template-save-title" class="post-version-modal-title">템플릿으로 저장</h2>
      <p class="admin-help">현재 폼의 카테고리·태그·본문 Markdown으로 새 템플릿을 만듭니다.</p>
      <label class="admin-label" for="post-template-save-name">템플릿 이름</label>
      <input
        id="post-template-save-name"
        class="admin-input"
        type="text"
        maxlength="200"
        data-admin-template-save-name
        placeholder="예: 5분 AI 팁 시리즈"
      />
      <label class="admin-label" for="post-template-save-desc" style="margin-top: 0.65rem">설명 (선택)</label>
      <textarea
        id="post-template-save-desc"
        class="admin-textarea"
        rows="2"
        maxlength="500"
        data-admin-template-save-desc
        placeholder="템플릿 용도 메모"
      ></textarea>
      <div class="post-version-modal-actions">
        <button type="button" class="admin-btn" data-admin-template-save-cancel>취소</button>
        <button type="button" class="admin-btn primary" data-admin-template-save-confirm>저장</button>
      </div>
    </div>
  </div>

  <div
