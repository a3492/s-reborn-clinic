  <script>
    import { createClient } from '@supabase/supabase-js';
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    const slug = new URLSearchParams(window.location.search).get('slug') ?? '';

    const form = document.querySelector('[data-admin-edit-post-form]');
    const message = document.querySelector('[data-admin-edit-post-message]');
    const metaList = document.querySelector('[data-admin-edit-meta]');
    const releaseState = document.querySelector('[data-admin-release-state]');
    const reviewLineEl = document.querySelector('[data-admin-review-line]');
    const reviewFlagEl = document.querySelector('[data-admin-review-flag]');
    const reviewCompleteBtn = document.querySelector('[data-admin-review-complete]');
    const publishHistorySummary = document.querySelector('[data-admin-publish-history-summary]');
    const previewLink = document.querySelector('[data-admin-edit-preview-link]');
    const dryRunButton = document.querySelector('[data-admin-publish-dryrun]');
    const livePublishButton = document.querySelector('[data-admin-publish-live]');
    const publishAnywayButton = document.querySelector('[data-admin-publish-anyway]');
    const saveButton = document.querySelector('[data-admin-save-button]');
    const publishWarningsSection = document.querySelector('[data-admin-publish-warnings-section]');
    const dryRunWarningsList = document.querySelector('[data-admin-dryrun-warnings-list]');
    const warningsAckCheckbox = document.querySelector('[data-admin-warnings-ack]');
    const qualityScoreEl = document.querySelector('[data-admin-quality-score]');
    const qualityChecklistEl = document.querySelector('[data-admin-quality-checklist]');
    const jobCard = document.querySelector('[data-admin-current-job]');
    const jobTitle = document.querySelector('[data-admin-current-job-title]');
    const jobStatus = document.querySelector('[data-admin-current-job-status]');
    const jobPath = document.querySelector('[data-admin-current-job-path]');
    const jobMeta = document.querySelector('[data-admin-current-job-meta]');
    const reportsSection = document.querySelector('[data-admin-post-reports]');
    const reportsList = document.querySelector('[data-admin-post-reports-list]');
    const reportsEmpty = document.querySelector('[data-admin-post-reports-empty]');
    const reportsError = document.querySelector('[data-admin-post-reports-error]');
    const commentsSection = document.querySelector('[data-admin-post-comments]');
    const commentsList = document.querySelector('[data-admin-post-comments-list]');
    const commentsEmpty = document.querySelector('[data-admin-post-comments-empty]');
    const commentsError = document.querySelector('[data-admin-post-comments-error]');
    const versionListEl = document.querySelector('[data-admin-version-list]');
    const saveSummaryModal = document.querySelector('[data-post-save-summary-modal]');
    const templateSaveModal = document.querySelector('[data-admin-template-save-modal]');
    const templateSaveName = document.querySelector('[data-admin-template-save-name]');
    const templateSaveDesc = document.querySelector('[data-admin-template-save-desc]');
    const versionPreviewModal = document.querySelector('[data-post-version-preview-modal]');
    const versionPreviewMeta = document.querySelector('[data-post-version-preview-meta]');
    const versionPreviewTitleText = document.querySelector('[data-post-version-preview-title-text]');
    const versionPreviewBody = document.querySelector('[data-post-version-preview-body]');
    const abTitleBInput = document.querySelector('[data-ab-title-b]');
    const abStartBtn = document.querySelector('[data-ab-start]');
    const abStats = document.querySelector('[data-ab-stats]');
    const abLineA = document.querySelector('[data-ab-line-a]');
    const abLineB = document.querySelector('[data-ab-line-b]');
    const abMsg = document.querySelector('[data-ab-msg]');
    const abWinnerBtns = document.querySelectorAll('[data-ab-winner]');
    let activeAbTest = null;
    let currentPostId = null;
    let currentSlug = slug;
    let currentUserId = null;
    let publishPollTimer = null;
    let hasUnsavedChanges = false;
    let formSnapshot = '';
    /** Dry Run 성공 직후 폼 스냅샷 — 편집 시 경고 게이트 무효화 */
    let dryRunFormSnapshot = '';
    let cachedPostVersions = [];
    let versionPreviewCurrent = null;
    /** URL·OG API용 — 폼에 없는 서브폴더 */
    let loadedPostSubcategory = '';
    const getCurrentRole = () => document.body.dataset.adminRole || '';

    const escapeHtml = (value) => String(value ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    const setMessage = (text, state = 'info') => {
      if (!message) return;
      message.hidden = false;
      message.textContent = text;
      message.dataset.state = state;
    };

    const setActionBusy = (type, busy) => {
      if (type === 'save' && saveButton) {
        saveButton.disabled = busy;
        saveButton.textContent = busy ? '저장 중...' : '변경 저장';
      }
      if (type === 'publish') {
        if (livePublishButton) livePublishButton.disabled = busy;
        if (dryRunButton) dryRunButton.disabled = busy;
        if (publishAnywayButton instanceof HTMLButtonElement) {
          if (busy) publishAnywayButton.disabled = true;
          else syncPublishWarningButtons();
        }
      }
    };

    const syncPublishWarningButtons = () => {
      if (!(publishAnywayButton instanceof HTMLButtonElement)) return;
      const panelOpen = publishWarningsSection instanceof HTMLElement && !publishWarningsSection.hidden;
      if (!panelOpen) {
        publishAnywayButton.hidden = true;
        publishAnywayButton.disabled = true;
        if (livePublishButton instanceof HTMLButtonElement) {
          livePublishButton.disabled = false;
        }
        return;
      }
      publishAnywayButton.hidden = false;
      publishAnywayButton.disabled = !(warningsAckCheckbox instanceof HTMLInputElement && warningsAckCheckbox.checked);
      if (livePublishButton instanceof HTMLButtonElement) {
        livePublishButton.disabled = true;
      }
    };

    const slugify = (value) =>
      value
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');

    const formatDateInput = (value) => {
      if (!value) return '';
      const date = new Date(value);
      const pad = (n) => String(n).padStart(2, '0');
      return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
    };

    const formatDateOnlyInput = (value) => {
      if (!value) return '';
      const date = new Date(value);
      const pad = (n) => String(n).padStart(2, '0');
      return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}`;
    };

    const formatDate = (value) => {
      if (!value) return '-';
      return new Intl.DateTimeFormat('ko-KR', {
        year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit'
      }).format(new Date(value));
    };

    const reportTypeLabel = (t) =>
      ({ typo: '오탈자', factual_error: '사실 오류', outdated: '오래된 정보', other: '기타' })[t] || t;

    const abCtrLine = (views, clicks) => {
      const v = Number(views) || 0;
      const c = Number(clicks) || 0;
      const pct = v > 0 ? ((100 * c) / v).toFixed(2) : '0.00';
      return `노출 ${v}회 · 클릭 ${c}회 · CTR ${pct}%`;
    };

    const setAbMsg = (text, state = '') => {
      if (!abMsg) return;
      if (!text) {
        abMsg.hidden = true;
        abMsg.textContent = '';
        delete abMsg.dataset.state;
        return;
      }
      abMsg.hidden = false;
      abMsg.textContent = text;
      if (state) abMsg.dataset.state = state;
    };

    const syncAbUi = () => {
      if (!(abTitleBInput instanceof HTMLInputElement) || !(abStartBtn instanceof HTMLButtonElement) || !abStats) return;
      if (activeAbTest) {
        abTitleBInput.value = activeAbTest.title_b || '';
        abTitleBInput.disabled = true;
        abStartBtn.disabled = true;
        abStats.hidden = false;
        if (abLineA) abLineA.textContent = abCtrLine(activeAbTest.views_a, activeAbTest.clicks_a);
        if (abLineB) abLineB.textContent = abCtrLine(activeAbTest.views_b, activeAbTest.clicks_b);
      } else {
        abTitleBInput.disabled = false;
        abStartBtn.disabled = false;
        abStats.hidden = true;
      }
    };

    const loadAbTest = async (postSlug) => {
      activeAbTest = null;
      if (!supabase || !postSlug) {
        syncAbUi();
        return;
      }
      const { data, error } = await supabase
        .from('ab_tests')
        .select('id, slug, title_a, title_b, views_a, views_b, clicks_a, clicks_b')
        .eq('slug', postSlug)
        .is('ended_at', null)
        .maybeSingle();
      if (error) {
        setAbMsg(`A/B 테스트 조회 실패: ${error.message}`, 'error');
      } else {
        activeAbTest = data || null;
        setAbMsg('', '');
      }
      syncAbUi();
    };

    const updatePreviewHref = (value) => {
      currentSlug = value || currentSlug;
      if (previewLink) {
        previewLink.href = `/admin/posts/preview?slug=${encodeURIComponent(currentSlug)}`;
      }
    };

    const serializeForm = () => {
      if (!form) return '';
      return JSON.stringify(Object.fromEntries(new FormData(form).entries()));
    };

    const applyDryRunWarnings = (warnings) => {
      const list = Array.isArray(warnings) ? warnings : [];
      if (!(publishWarningsSection instanceof HTMLElement) || !dryRunWarningsList) return;

      if (list.length === 0) {
        publishWarningsSection.hidden = true;
        dryRunWarningsList.innerHTML = '';
        dryRunFormSnapshot = '';
        if (warningsAckCheckbox instanceof HTMLInputElement) warningsAckCheckbox.checked = false;
        syncPublishWarningButtons();
        return;
      }

      dryRunFormSnapshot = serializeForm();
      publishWarningsSection.hidden = false;
      dryRunWarningsList.innerHTML = list.map((w) => `<li>${escapeHtml(String(w))}</li>`).join('');
      if (warningsAckCheckbox instanceof HTMLInputElement) warningsAckCheckbox.checked = false;
      syncPublishWarningButtons();
    };

    const invalidateDryRunWarningGateIfStale = () => {
      if (dryRunFormSnapshot && serializeForm() !== dryRunFormSnapshot) {
        applyDryRunWarnings([]);
      }
    };

    const computeQualityItems = () => {
      if (!form) return [];
      const fd = new FormData(form);
      const title = String(fd.get('title') || '').trim();
      const body = String(fd.get('body') || '').trim();
      const thumb = String(fd.get('thumbnail_url') || '').trim();
      const tagsRaw = String(fd.get('tags') || '');
      const tags = tagsRaw.split(',').map((t) => t.trim()).filter(Boolean);
      const seoDesc = String(fd.get('seo_description') || '').trim();
      const len = body.length;
      return [
        {
          label: '본문 글자수',
          detail: `${len}자 (권장 500자 이상)`,
          ok: len >= 500,
          severe: len === 0,
        },
        {
          label: '썸네일',
          detail: thumb ? 'URL 입력됨' : '없음',
          ok: Boolean(thumb),
          severe: false,
        },
        {
          label: '태그',
          detail: tags.length ? `${tags.length}개` : '없음',
          ok: tags.length > 0,
          severe: false,
        },
        {
          label: 'SEO 설명',
          detail: seoDesc ? `${seoDesc.length}자` : '없음',
          ok: Boolean(seoDesc),
          severe: false,
        },
        {
          label: '제목 길이',
          detail: `${title.length}자 (권장 약 10~120자)`,
          ok: title.length >= 10 && title.length <= 120,
          severe: title.length === 0,
        },
      ];
    };

    const showQualityPending = () => {
      if (!qualityChecklistEl || !qualityScoreEl) return;
      qualityScoreEl.textContent = '점수: —';
      qualityChecklistEl.innerHTML =
        '<li class="admin-list-row"><p class="admin-help">저장하면 품질 점수가 갱신됩니다.</p></li>';
    };

    const calculateQualityScore = () => {
      if (!qualityChecklistEl || !qualityScoreEl) return;
      const items = computeQualityItems();
      if (items.length === 0) return;
      const passed = items.filter((i) => i.ok).length;
      const total = items.length;
      qualityScoreEl.textContent = `점수: ${passed} / ${total}`;
      qualityChecklistEl.innerHTML = items
        .map((i) => {
          let icon = '⚠️';
          if (i.ok) icon = '✅';
          else if (i.severe) icon = '❌';
          return `<li class="admin-list-row"><div class="admin-quality-row"><span class="admin-quality-icon" aria-hidden="true">${icon}</span><div><p class="admin-item-title">${escapeHtml(i.label)}</p><p class="admin-item-meta">${escapeHtml(i.detail)}</p></div></div></li>`;
        })
        .join('');
    };

    const updateDirtyState = () => {
      hasUnsavedChanges = serializeForm() !== formSnapshot;
      if (saveButton) {
        saveButton.dataset.dirty = hasUnsavedChanges ? 'true' : 'false';
      }
      invalidateDryRunWarningGateIfStale();
      refreshSocialPreview();
    };

    const publicR2MediaBase = (import.meta.env.PUBLIC_R2_MEDIA_URL || '').trim().replace(/\/$/, '');

    const encodePathSegments = (pathStr) =>
      String(pathStr || '')
        .split('/')
        .filter(Boolean)
        .map((seg) => encodeURIComponent(seg))
        .join('/');

    const resolveContentSlugPath = () => {
      if (!form) return '';
      const slugVal = String(form.elements.slug?.value || '').trim();
      const category = String(form.elements.category?.value || '').trim() || 'uncategorized';
      if (!slugVal) return '';
      if (slugVal.includes('/')) return slugVal;
      return [category, loadedPostSubcategory, slugVal].filter(Boolean).join('/');
    };

    const buildLivePostUrl = () => {
      const siteBase = (import.meta.env.PUBLIC_SITE_URL || window.location.origin).replace(/\/$/, '');
      const rel = resolveContentSlugPath();
      if (!rel) return `${siteBase}/blog/`;
      if (rel.startsWith('doctor-ai-academy/')) {
        return `${siteBase}/doctor-ai-academy/${encodePathSegments(rel.slice('doctor-ai-academy/'.length))}/`;
      }
      if (rel.startsWith('doctor-ai/')) {
        return `${siteBase}/doctor-ai-academy/${encodePathSegments(rel.slice('doctor-ai/'.length))}/`;
      }
      return `${siteBase}/blog/${encodePathSegments(rel)}/`;
    };

    const resolveOgPreviewImageUrl = (thumbRaw) => {
      const siteBase = (import.meta.env.PUBLIC_SITE_URL || window.location.origin).replace(/\/$/, '');
      const t = String(thumbRaw || '').trim();
      if (t) {
        try {
          return t.startsWith('http') ? t : new URL(t, window.location.origin).href;
        } catch {
          return t;
        }
      }
      const path = resolveContentSlugPath();
      if (!path) return '';
      return `${siteBase}/api/og/${encodeURIComponent(path)}/`;
    };

    const focusField = (name) => {
      const el = document.querySelector(`[name="${name}"]`);
      if (el instanceof HTMLElement) {
        el.focus();
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    };

    const refreshSocialPreview = () => {
      const card = document.querySelector('[data-admin-social-preview-card]');
      if (!card || !form) return;

      const siteBase = (import.meta.env.PUBLIC_SITE_URL || window.location.origin).replace(/\/$/, '');
      let host = 's-reborn-blog.pages.dev';
      try {
        host = new URL(siteBase).hostname || host;
      } catch {
        /* keep default */
      }

      const title = String(form.elements.title?.value || '').trim();
      const seoTitle = String(form.elements.seo_title?.value || '').trim();
      const description = String(form.elements.description?.value || '').trim();
      const seoDescription = String(form.elements.seo_description?.value || '').trim();
      const thumbRaw = String(form.elements.thumbnail_url?.value || '').trim();
      const canonicalForm = String(form.elements.canonical_url?.value || '').trim();
      const status = String(form.elements.status?.value || '').trim();

      const ogTitleStr = seoTitle || title || '(제목 없음)';
      const ogDescStr = seoDescription || description || '';
      const postUrl = canonicalForm || buildLivePostUrl();
      let ogImageUrl = resolveOgPreviewImageUrl(thumbRaw);

      const setImg = (img, ph, url) => {
        if (!(img instanceof HTMLImageElement) || !ph) return;
        if (url) {
          img.removeAttribute('hidden');
          ph.setAttribute('hidden', '');
          img.src = url;
          img.onerror = () => {
            img.setAttribute('hidden', '');
            ph.removeAttribute('hidden');
          };
        } else {
          img.src = '';
          img.setAttribute('hidden', '');
          ph.removeAttribute('hidden');
        }
      };

      const img = card.querySelector('[data-social-og-img]');
      const ph = card.querySelector('[data-social-img-placeholder]');
      setImg(img, ph, ogImageUrl);

      const kImg = card.querySelector('[data-social-kakao-img]');
      const kPh = card.querySelector('[data-social-kakao-placeholder]');
      setImg(kImg, kPh, ogImageUrl);

      const sImg = card.querySelector('[data-social-slack-img]');
      const sPh = card.querySelector('[data-social-slack-placeholder]');
      setImg(sImg, sPh, ogImageUrl);

      card.querySelectorAll('[data-social-domain]').forEach((el) => {
        el.textContent = host;
      });
      card.querySelectorAll('[data-social-title]').forEach((el) => {
        el.textContent = ogTitleStr;
      });
      card.querySelectorAll('[data-social-desc]').forEach((el) => {
        el.textContent = ogDescStr;
      });
      const kTitle = card.querySelector('[data-social-kakao-title]');
      if (kTitle) kTitle.textContent = ogTitleStr;
      const kDom = card.querySelector('[data-social-kakao-domain]');
      if (kDom) kDom.textContent = host;
      const slT = card.querySelector('[data-social-slack-title]');
      if (slT) slT.textContent = ogTitleStr;
      const slD = card.querySelector('[data-social-slack-domain]');
      if (slD) slD.textContent = host;
      const slDe = card.querySelector('[data-social-slack-desc]');
      if (slDe) slDe.textContent = ogDescStr;

      const ogTitleLen = ogTitleStr.length;
      const ogDescLen = ogDescStr.length;
      const hasOgImage = Boolean(ogImageUrl);

      let imageSizeOk = true;
      let imageSizeDetail = '동적 OG 또는 외부 이미지';
      if (!hasOgImage) {
        imageSizeOk = false;
        imageSizeDetail = '이미지 URL 없음';
      } else if (ogImageUrl.includes('/api/og/')) {
        imageSizeOk = true;
        imageSizeDetail = '동적 OG(1200×630)';
      } else if (publicR2MediaBase && ogImageUrl.startsWith(publicR2MediaBase)) {
        try {
          const u = new URL(ogImageUrl);
          const w = parseInt(u.searchParams.get('width') || '0', 10);
          const h = parseInt(u.searchParams.get('height') || '0', 10);
          if (w >= 1150 && h >= 600) {
            imageSizeOk = true;
            imageSizeDetail = `R2 쿼리 ${w}×${h}`;
          } else {
            imageSizeOk = false;
            imageSizeDetail = 'R2 URL — 권장: width≈1200·height≈630 쿼리';
          }
        } catch {
          imageSizeOk = false;
          imageSizeDetail = 'R2 URL 파싱 실패';
        }
      } else {
        imageSizeDetail = '고정 이미지 — 크기는 배포 페이지에서 확인';
      }

      const canonicalOk = Boolean(canonicalForm) || Boolean(resolveContentSlugPath());
      const twitterCardOk = true;

      const rows = [
        {
          icon: ogTitleLen <= 60 ? '✅' : '⚠️',
          label: `og:title (${ogTitleLen}자)`,
          detail: ogTitleLen <= 60 ? '60자 이하' : '60자 초과 — 잘릴 수 있음',
          focus: seoTitle ? 'seo_title' : 'title',
        },
        {
          icon: ogDescLen <= 160 ? '✅' : '⚠️',
          label: `og:description (${ogDescLen}자)`,
          detail: ogDescLen <= 160 ? '160자 이하' : '160자 초과 — 미리보기에서 잘릴 수 있음',
          focus: seoDescription ? 'seo_description' : 'description',
        },
        {
          icon: hasOgImage ? '✅' : '❌',
          label: 'og:image',
          detail: hasOgImage ? ogImageUrl.split('?')[0] : '썸네일 없음·동적 OG도 불가(슬러그 필요)',
          focus: 'thumbnail_url',
        },
        {
          icon: imageSizeOk ? '✅' : '⚠️',
          label: 'og:image 권장 1200×630',
          detail: imageSizeDetail,
          focus: 'thumbnail_url',
        },
        {
          icon: twitterCardOk ? '✅' : '❌',
          label: 'twitter:card',
          detail: 'summary_large_image (블로그 기본)',
          focus: 'title',
        },
        {
          icon: canonicalOk ? '✅' : '❌',
          label: 'canonical URL',
          detail: canonicalForm.trim() || postUrl,
          focus: 'canonical_url',
        },
      ];

      const list = card.querySelector('[data-admin-social-checklist]');
      if (list) {
        list.innerHTML = rows
          .map(
            (r) => `
          <li class="admin-list-row admin-social-check-row" tabindex="0" data-check-focus="${escapeHtml(r.focus)}">
            <div class="admin-quality-row">
              <span class="admin-quality-icon" aria-hidden="true">${r.icon}</span>
              <div>
                <p class="admin-item-title">${escapeHtml(r.label)}</p>
                <p class="admin-item-meta">${escapeHtml(r.detail)}</p>
              </div>
            </div>
          </li>`,
          )
          .join('');
      }

      const fetchWrap = card.querySelector('[data-admin-social-fetch-wrap]');
      const fetchHint = card.querySelector('[data-admin-social-fetch-hint]');
      const fetchResult = card.querySelector('[data-admin-social-fetch-result]');
      if (fetchWrap instanceof HTMLElement) {
        if (status === 'published') {
          fetchWrap.hidden = false;
          if (fetchHint instanceof HTMLElement) {
            fetchHint.hidden = false;
            fetchHint.textContent =
              '발행된 공개 URL만 서버에서 가져옵니다. 미저장 변경은 반영되지 않을 수 있습니다.';
          }
        } else {
          fetchWrap.hidden = true;
          if (fetchResult instanceof HTMLElement) {
            fetchResult.hidden = true;
            fetchResult.textContent = '';
          }
        }
      }

      const encPost = encodeURIComponent(postUrl);
      card.dataset.shareTwitter = `https://twitter.com/intent/tweet?url=${encPost}&text=${encodeURIComponent(ogTitleStr)}`;
      card.dataset.shareKakao = `https://story.kakao.com/share?url=${encPost}`;
      card.dataset.shareLink = postUrl;
    };

    const fillMeta = (post) => {
      if (!metaList) return;
      metaList.innerHTML = `
        <li class="admin-list-row"><div><p class="admin-item-title">${post.title}</p><p class="admin-item-meta">slug: ${post.slug}</p></div><div><span class="admin-status ${post.status}">${post.status}</span></div></li>
        <li class="admin-list-row"><div><p class="admin-item-title">글 유형</p><p class="admin-item-meta">${post.category ?? '-'}</p></div></li>
        <li class="admin-list-row"><div><p class="admin-item-title">최근 수정</p><p class="admin-item-meta">${post.updated_at ?? '-'}</p></div></li>
      `;
      updatePreviewHref(post.slug);
    };

    const updateReviewUi = (post) => {
      if (reviewLineEl) {
        const last = post?.last_reviewed_at;
        if (!last) {
          reviewLineEl.textContent = '최종 검토: 기록 없음';
        } else {
          const days = Math.floor((Date.now() - new Date(last).getTime()) / (24 * 60 * 60 * 1000));
          reviewLineEl.textContent = `최종 검토: ${days}일 전`;
        }
      }
      if (reviewFlagEl instanceof HTMLElement) {
        reviewFlagEl.hidden = !post?.needs_review;
      }
    };

    const fillReleaseState = (post, publishMeta = {}) => {
      if (!releaseState) return;
      const canonical = post.canonical_url || '-';
      const publishStatusClass = post.status === 'published' ? 'ready' : post.status;
      const lastPublish = publishMeta.completedAt || post.published_at || null;
      const commit = publishMeta.commitSha || '-';
      const targetPath = publishMeta.targetPath || `src/content/blog/${post.category ?? 'uncategorized'}/${post.slug}.md`;

      releaseState.innerHTML = `
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">현재 상태</p>
            <p class="admin-item-meta">마지막 발행 ${lastPublish ? formatDate(lastPublish) : '없음'}</p>
          </div>
          <div><span class="admin-status ${publishStatusClass}">${post.status || 'draft'}</span></div>
        </li>
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">Canonical URL</p>
            <p class="admin-item-meta">${canonical}</p>
          </div>
        </li>
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">Target Path</p>
            <p class="admin-item-meta admin-cell-mono">${targetPath}</p>
          </div>
        </li>
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">Latest Commit</p>
            <p class="admin-item-meta admin-cell-mono">${commit}</p>
          </div>
        </li>
      `;
    };

    const fillPublishHistorySummary = (summary) => {
      if (!publishHistorySummary) return;

      if (!summary) {
        publishHistorySummary.innerHTML = '<p class="admin-help">이력 없음</p>';
        return;
      }

      const sha8 = summary.successCommit ? summary.successCommit.slice(0, 8) : null;
      const failMsg = summary.failureMessage ? summary.failureMessage.split('\n')[0].slice(0, 60) : null;
      const latestStatus = summary.latestStatus ?? 'draft';

      publishHistorySummary.innerHTML = `
        <div class="admin-change-row">
          <span class="admin-cell-subtle">최근 job</span>
          <span class="admin-cell-date admin-cell-subtle">${summary.latestAt ? formatDate(summary.latestAt) : '-'}</span>
          <span class="admin-status ${latestStatus}">${latestStatus}</span>
        </div>
        <div class="admin-change-row">
          <span class="admin-cell-subtle">Success${sha8 ? ` · <code>${sha8}</code>` : ': 없음'}</span>
          <span></span>
          ${summary.successCommit ? '<span class="admin-status success">ok</span>' : '<span class="admin-status draft">-</span>'}
        </div>
        <div class="admin-change-row">
          <span class="admin-cell-subtle" title="${escapeHtml(summary.failureMessage ?? '')}">${failMsg ? escapeHtml(failMsg) : '실패 없음'}</span>
          <span></span>
          ${summary.failureMessage ? '<span class="admin-status failed">!</span><button type="button" class="admin-btn admin-btn-sm" data-admin-history-retry>Retry</button>' : '<span class="admin-status success">✓</span><span></span>'}
        </div>
      `;
    };

    const loadPublishHistorySummary = async () => {
      if (!currentPostId) {
        fillPublishHistorySummary(null);
        return;
      }

      const { data, error } = await supabase
        .from('publish_jobs')
        .select('status, commit_sha, error_message, created_at, completed_at, target_path')
        .eq('post_id', currentPostId)
        .order('created_at', { ascending: false })
        .limit(10);

      if (error) {
        fillPublishHistorySummary({
          successCommit: null,
          successAt: null,
          failureMessage: `publish 이력 조회 실패: ${error.message}`,
          failureAt: null,
          latestStatus: 'failed',
          latestAt: null,
          latestTargetPath: null,
        });
        return;
      }

      const rows = data ?? [];
      const latest = rows[0] ?? null;
      const latestSuccess = rows.find((row) => row.status === 'success') ?? null;
      const latestFailure = rows.find((row) => row.status === 'failed') ?? null;

      fillPublishHistorySummary({
        successCommit: latestSuccess?.commit_sha ?? null,
        successAt: latestSuccess?.completed_at ?? latestSuccess?.created_at ?? null,
        failureMessage: latestFailure?.error_message ?? null,
        failureAt: latestFailure?.completed_at ?? latestFailure?.created_at ?? null,
        latestStatus: latest?.status ?? null,
        latestAt: latest?.created_at ?? null,
        latestTargetPath: latest?.target_path ?? null,
      });
    };

    const renderCurrentJob = (job, extraText) => {
      if (!jobCard) return;
      jobCard.hidden = false;
      if (jobTitle) jobTitle.textContent = `Publish job ${job.id?.slice(0, 8) || ''}`.trim();
      if (jobStatus) {
        jobStatus.className = `admin-status ${job.status || 'pending'}`;
        jobStatus.textContent = job.status || 'pending';
      }
      if (jobPath) jobPath.textContent = job.target_path || '-';
      if (jobMeta) {
        const parts = [
          extraText || null,
          job.commit_sha ? `commit ${job.commit_sha}` : null,
          job.error_message || null,
          job.completed_at ? formatDate(job.completed_at) : null,
        ].filter(Boolean);
        jobMeta.textContent = parts.join(' · ') || 'job 상태를 기다리는 중입니다.';
      }
    };

    if (!supabaseUrl || !supabaseKey) {
      setMessage('Supabase 환경 변수가 없어 편집 기능을 초기화할 수 없습니다.', 'error');
    } else {
      let supabase = null;

      const loadPostReports = async (postSlug) => {
        if (!(reportsSection instanceof HTMLElement) || !reportsList || !reportsEmpty) return;
        if (!supabase || !postSlug) {
          reportsSection.hidden = true;
          return;
        }
        reportsSection.hidden = false;
        if (reportsError instanceof HTMLElement) {
          reportsError.hidden = true;
          reportsError.textContent = '';
        }
        const { data, error } = await supabase
          .from('post_reports')
          .select('id, report_type, description, reporter_email, status, created_at')
          .eq('slug', postSlug)
          .order('created_at', { ascending: false });

        if (error) {
          if (reportsError instanceof HTMLElement) {
            reportsError.hidden = false;
            reportsError.textContent = `신고 목록을 불러오지 못했습니다: ${error.message}`;
            reportsError.dataset.state = 'error';
          }
          reportsList.innerHTML = '';
          reportsEmpty.hidden = true;
          return;
        }

        const rows = data ?? [];
        reportsEmpty.hidden = rows.length > 0;

        if (!rows.length) {
          reportsList.innerHTML = '';
          return;
        }

        reportsList.innerHTML = rows
          .map((r) => {
            const desc = r.description ? escapeHtml(r.description) : '—';
            const email = r.reporter_email ? escapeHtml(r.reporter_email) : '이메일 없음';
            const actions =
              r.status === 'open'
                ? `<div class="admin-post-report-actions">
            <button type="button" class="admin-btn admin-btn-sm primary" data-admin-report-action="resolved" data-report-id="${escapeHtml(r.id)}">해결</button>
            <button type="button" class="admin-btn admin-btn-sm" data-admin-report-action="dismissed" data-report-id="${escapeHtml(r.id)}">기각</button>
          </div>`
                : `<div class="admin-post-report-actions"><span class="admin-status ${escapeHtml(r.status)}">${escapeHtml(r.status)}</span></div>`;
            return `<li class="admin-list-row">
          <div>
            <p class="admin-item-title">${escapeHtml(reportTypeLabel(r.report_type))}</p>
            <p class="admin-item-meta">접수 ${formatDate(r.created_at)} · <span class="admin-status ${escapeHtml(r.status)}">${escapeHtml(r.status)}</span></p>
            <p class="admin-item-meta">${desc}</p>
            <p class="admin-item-meta">${email}</p>
          </div>
          ${actions}
        </li>`;
          })
          .join('');
      };

      const loadPostComments = async (postSlug) => {
        if (!(commentsSection instanceof HTMLElement) || !commentsList || !commentsEmpty) return;
        if (!supabase || !postSlug) {
          commentsSection.hidden = true;
          return;
        }
        commentsSection.hidden = false;
        if (commentsError instanceof HTMLElement) {
          commentsError.hidden = true;
          commentsError.textContent = '';
        }
        const { data, error } = await supabase
          .from('comments')
          .select('id, parent_id, author_name, body, created_at, is_approved')
          .eq('slug', postSlug)
          .eq('is_approved', false)
          .order('created_at', { ascending: false });

        if (error) {
          if (commentsError instanceof HTMLElement) {
            commentsError.hidden = false;
            commentsError.textContent = `댓글 목록을 불러오지 못했습니다: ${error.message}`;
            commentsError.dataset.state = 'error';
          }
          commentsList.innerHTML = '';
          commentsEmpty.hidden = true;
          return;
        }

        const rows = data ?? [];
        commentsEmpty.hidden = rows.length > 0;
        if (!rows.length) {
          commentsList.innerHTML = '';
          return;
        }

        commentsList.innerHTML = rows
          .map((c) => {
            const parentNote = c.parent_id
              ? `<p class="admin-item-meta">답글 (parent: <code>${escapeHtml(c.parent_id.slice(0, 8))}…</code>)</p>`
              : '';
            const bodyText = escapeHtml(c.body).replace(/\n/g, '<br />');
            return `<li class="admin-list-row">
          <div>
            <p class="admin-item-title">${escapeHtml(c.author_name)}</p>
            <p class="admin-item-meta">${formatDate(c.created_at)}</p>
            ${parentNote}
            <p class="admin-item-meta">${bodyText}</p>
          </div>
          <div class="admin-post-comment-actions">
            <button type="button" class="admin-btn admin-btn-sm primary" data-admin-comment-approve data-comment-id="${escapeHtml(c.id)}">승인</button>
            <button type="button" class="admin-btn admin-btn-sm" data-admin-comment-delete data-comment-id="${escapeHtml(c.id)}">삭제</button>
          </div>
        </li>`;
          })
          .join('');
      };

      const renderVersionList = () => {
        if (!versionListEl) return;
        if (!cachedPostVersions.length) {
          versionListEl.innerHTML =
            '<li class="admin-list-row"><p class="admin-help">저장된 버전이 없습니다.</p></li>';
          return;
        }
        versionListEl.innerHTML = cachedPostVersions
          .map((v, i) => {
            const when = formatDate(v.created_at);
            const who = v.changed_by ? `${String(v.changed_by).slice(0, 8)}…` : '—';
            const sum = v.change_summary ? escapeHtml(v.change_summary) : '—';
            return `<li class="admin-list-row" style="flex-wrap:wrap;gap:0.5rem;">
            <div style="flex:1;min-width:0;">
              <p class="admin-item-title">${when}</p>
              <p class="admin-item-meta">변경자 ${escapeHtml(who)} · ${sum}</p>
            </div>
            <button type="button" class="admin-btn admin-btn-sm" data-version-open="${i}">이 버전 보기</button>
          </li>`;
          })
          .join('');
      };

      const loadPostVersions = async (postSlug) => {
        if (!versionListEl || !supabase || !postSlug) return;
        versionListEl.innerHTML = '<li class="admin-list-row"><p class="admin-help">불러오는 중…</p></li>';
        const { data, error } = await supabase
          .from('post_versions')
          .select('id, slug, title, body_markdown, changed_by, change_summary, created_at')
          .eq('slug', postSlug)
          .order('created_at', { ascending: false })
          .limit(10);
        if (error) {
          cachedPostVersions = [];
          versionListEl.innerHTML = `<li class="admin-list-row"><p class="admin-help admin-help-error">${escapeHtml(error.message)}</p></li>`;
          return;
        }
        cachedPostVersions = data || [];
        renderVersionList();
      };

      const closeVersionPreview = () => {
        if (versionPreviewModal instanceof HTMLElement) versionPreviewModal.hidden = true;
        versionPreviewCurrent = null;
      };

      const openVersionPreview = (v) => {
        versionPreviewCurrent = v;
        if (!(versionPreviewModal instanceof HTMLElement)) return;
        if (versionPreviewMeta) {
          versionPreviewMeta.textContent = `${formatDate(v.created_at)} · ${v.change_summary || '요약 없음'}`;
        }
        if (versionPreviewTitleText) versionPreviewTitleText.textContent = v.title || '(제목 없음)';
        if (versionPreviewBody) versionPreviewBody.textContent = v.body_markdown || '';
        versionPreviewModal.hidden = false;
      };

      const openSaveSummaryModal = () =>
        new Promise((resolve) => {
          const saveSummaryInput = document.getElementById('post-save-summary-input');
          if (!saveSummaryModal || !(saveSummaryInput instanceof HTMLTextAreaElement)) {
            resolve({ ok: true, summary: '' });
            return;
          }
          let settled = false;
          const finish = (payload) => {
            if (settled) return;
            settled = true;
            saveSummaryModal.hidden = true;
            document.removeEventListener('keydown', onKey);
            resolve(payload);
          };
          const onKey = (ev) => {
            if (ev.key === 'Escape') {
              ev.preventDefault();
              finish({ ok: false, summary: '' });
            }
          };
          document.addEventListener('keydown', onKey);
          saveSummaryInput.value = '';
          saveSummaryModal.hidden = false;
          saveSummaryInput.focus();
          const onConfirm = () => finish({ ok: true, summary: saveSummaryInput.value.trim() });
          const onCancel = () => finish({ ok: false, summary: '' });
          saveSummaryModal.querySelector('[data-post-save-summary-confirm]')?.addEventListener('click', onConfirm, {
            once: true,
          });
          saveSummaryModal.querySelector('[data-post-save-summary-cancel]')?.addEventListener('click', onCancel, {
            once: true,
          });
          saveSummaryModal.querySelectorAll('[data-post-save-summary-close]').forEach((el) => {
            el.addEventListener('click', onCancel, { once: true });
          });
        });

      let adminPollCached = null;

      const parseAdminPollOptions = (raw) => {
        if (!Array.isArray(raw)) return [];
        const out = [];
        for (const x of raw) {
          if (!x || typeof x !== 'object') continue;
          const id = typeof x.id === 'string' ? x.id.trim() : '';
          const label = typeof x.label === 'string' ? x.label.trim() : '';
          if (id && label) out.push({ id, label });
        }
        return out;
      };

      const getAdminPollEls = () => ({
        currentEl: document.querySelector('[data-admin-poll-current]'),
        formWrap: document.querySelector('[data-admin-poll-form-wrap]'),
        questionInput: document.querySelector('[data-admin-poll-question]'),
        optionsList: document.querySelector('[data-admin-poll-options]'),
        previewList: document.querySelector('[data-admin-poll-preview-list]'),
        createBtn: document.querySelector('[data-admin-poll-create]'),
        deleteBtn: document.querySelector('[data-admin-poll-delete]'),
        addOptBtn: document.querySelector('[data-admin-poll-add-option]'),
        msgEl: document.querySelector('[data-admin-poll-msg]'),
      });

      const showAdminPollMsg = (text, isErr) => {
        const { msgEl } = getAdminPollEls();
        if (!(msgEl instanceof HTMLElement)) return;
        if (!text) {
          msgEl.hidden = true;
          msgEl.textContent = '';
          return;
        }
        msgEl.hidden = false;
        msgEl.textContent = text;
        msgEl.classList.toggle('admin-help-error', !!isErr);
      };

      const addPollOptionRow = (id = '', label = '') => {
        const { optionsList } = getAdminPollEls();
        if (!optionsList) return;
        const rows = optionsList.querySelectorAll('[data-admin-poll-opt-row]');
        if (rows.length >= 4) return;
        const li = document.createElement('li');
        li.className = 'admin-list-row';
        li.setAttribute('data-admin-poll-opt-row', '');
        li.style.cssText = 'flex-wrap:wrap;gap:0.5rem;align-items:flex-end;';
        li.innerHTML = `<div style="flex:1;min-width:100px;">
            <span class="admin-label">옵션 id</span>
            <input class="admin-input" type="text" data-admin-poll-opt-id maxlength="40" placeholder="a" value="${escapeHtml(id)}"/>
          </div>
          <div style="flex:2;min-width:140px;">
            <span class="admin-label">표시</span>
            <input class="admin-input" type="text" data-admin-poll-opt-label maxlength="200" value="${escapeHtml(label)}"/>
          </div>
          <button type="button" class="admin-btn admin-btn-sm" data-admin-poll-opt-remove>삭제</button>`;
        optionsList.appendChild(li);
      };

      const resetAdminPollForm = () => {
        const { questionInput, optionsList } = getAdminPollEls();
        if (questionInput instanceof HTMLInputElement) questionInput.value = '';
        if (optionsList) {
          optionsList.innerHTML = '';
          addPollOptionRow('a', '예');
          addPollOptionRow('b', '아니오');
        }
      };

      const collectAdminPollOptions = () => {
        const { optionsList } = getAdminPollEls();
        if (!optionsList) return [];
        const out = [];
        optionsList.querySelectorAll('[data-admin-poll-opt-row]').forEach((row) => {
          const idInp = row.querySelector('[data-admin-poll-opt-id]');
          const labInp = row.querySelector('[data-admin-poll-opt-label]');
          const oid = idInp instanceof HTMLInputElement ? idInp.value.trim() : '';
          const label = labInp instanceof HTMLInputElement ? labInp.value.trim() : '';
          if (oid && label) out.push({ id: oid, label });
        });
        return out;
      };

      const refreshAdminPollPreview = async (pollId) => {
        const { previewList } = getAdminPollEls();
        if (!previewList || !supabase) return;
        if (!pollId) {
          previewList.innerHTML =
            '<li class="admin-list-row"><p class="admin-help">투표가 없습니다.</p></li>';
          return;
        }
        const { data: poll, error: pErr } = await supabase
          .from('polls')
          .select('options')
          .eq('id', pollId)
          .maybeSingle();
        if (pErr || !poll) {
          previewList.innerHTML = `<li class="admin-list-row"><p class="admin-help admin-help-error">${escapeHtml(pErr?.message || '조회 실패')}</p></li>`;
          return;
        }
        const opts = parseAdminPollOptions(poll.options);
        const { data: votes } = await supabase
          .from('poll_votes')
          .select('option_id')
          .eq('poll_id', pollId);
        const counts = new Map();
        opts.forEach((o) => counts.set(o.id, 0));
        (votes || []).forEach((v) => {
          counts.set(v.option_id, (counts.get(v.option_id) ?? 0) + 1);
        });
        const total = votes?.length ?? 0;
        if (!opts.length) {
          previewList.innerHTML = '<li class="admin-list-row"><p class="admin-help">선택지 없음</p></li>';
          return;
        }
        previewList.innerHTML = opts
          .map((o) => {
            const c = counts.get(o.id) ?? 0;
            const pct = total > 0 ? Math.round((100 * c) / total) : 0;
            return `<li class="admin-list-row"><div>
              <p class="admin-item-title">${escapeHtml(o.label)}</p>
              <p class="admin-item-meta">${c}표 · ${pct}%</p>
            </div></li>`;
          })
          .join('');
      };

      const loadAdminPoll = async (postSlug) => {
        const els = getAdminPollEls();
        if (!els.currentEl || !els.formWrap || !els.optionsList) return;
        showAdminPollMsg('', false);
        if (!postSlug || !supabase) {
          els.currentEl.innerHTML = '<p class="admin-help">slug가 있어야 투표를 설정할 수 있습니다.</p>';
          els.formWrap.hidden = true;
          if (els.deleteBtn instanceof HTMLElement) els.deleteBtn.hidden = true;
          if (els.createBtn instanceof HTMLElement) els.createBtn.hidden = true;
          adminPollCached = null;
          await refreshAdminPollPreview(null);
          return;
        }

        els.currentEl.innerHTML = '<p class="admin-help">불러오는 중…</p>';
        const { data: poll, error } = await supabase
          .from('polls')
          .select('id, slug, question, options')
          .eq('slug', postSlug)
          .maybeSingle();

        if (error) {
          els.currentEl.innerHTML = `<p class="admin-help admin-help-error">${escapeHtml(error.message)}</p>`;
          return;
        }

        adminPollCached = poll;
        if (poll) {
          const opts = parseAdminPollOptions(poll.options);
          const optLines = opts.map((o) => `• ${escapeHtml(o.id)}: ${escapeHtml(o.label)}`).join('<br/>');
          els.currentEl.innerHTML = `<p class="admin-item-title">${escapeHtml(poll.question)}</p><p class="admin-item-meta">${optLines || '선택지 없음'}</p>`;
          els.formWrap.hidden = true;
          if (els.createBtn instanceof HTMLElement) els.createBtn.hidden = true;
          if (els.deleteBtn instanceof HTMLElement) els.deleteBtn.hidden = false;
        } else {
          els.currentEl.innerHTML = '<p class="admin-help">투표 없음</p>';
          els.formWrap.hidden = false;
          resetAdminPollForm();
          if (els.createBtn instanceof HTMLElement) els.createBtn.hidden = false;
          if (els.deleteBtn instanceof HTMLElement) els.deleteBtn.hidden = true;
        }
        await refreshAdminPollPreview(poll?.id ?? null);
      };

      const loadPost = async () => {
        const { data: post, error } = await supabase
          .from('posts')
          .select(
            'id, title, description, slug, category, subcategory, tags, body_markdown, status, published_at, scheduled_at, updated_at, thumbnail_url, seo_title, seo_description, canonical_url, last_reviewed_at, needs_review, review_interval_days',
          )
          .eq('slug', currentSlug)
          .single();

        if (error || !post) {
          setMessage(error?.message || '글을 찾을 수 없습니다.', 'error');
          loadedPostSubcategory = '';
          if (reportsSection instanceof HTMLElement) reportsSection.hidden = true;
          if (commentsSection instanceof HTMLElement) commentsSection.hidden = true;
          await loadAdminPoll('');
          refreshSocialPreview();
          return null;
        }

        currentPostId = post.id;
        loadedPostSubcategory = (post.subcategory || '').trim();
        form.elements.title.value = post.title || '';
        form.elements.description.value = post.description || '';
        form.elements.slug.value = post.slug || '';
        form.elements.category.value = post.category || 'ai';
        form.elements.tags.value = (post.tags || []).join(', ');
        form.elements.body.value = post.body_markdown || '';
        form.elements.status.value = post.status || 'draft';
        form.elements.date.value = formatDateInput(post.published_at);
        form.elements.scheduled_at_date.value = formatDateOnlyInput(post.scheduled_at);
        form.elements.thumbnail_url.value = post.thumbnail_url || '';
        form.elements.seo_title.value = post.seo_title || '';
        form.elements.seo_description.value = post.seo_description || '';
        form.elements.canonical_url.value = post.canonical_url || '';
        if (form.elements.title_ab_b) form.elements.title_ab_b.value = '';
        const riInput = document.getElementById('review_interval_days');
        if (riInput instanceof HTMLInputElement) {
          const rd = post.review_interval_days;
          const n = Number(rd);
          riInput.value = String(Number.isFinite(n) ? Math.min(365, Math.max(30, Math.floor(n))) : 180);
        }
        fillMeta(post);
        fillReleaseState(post);
        updateReviewUi(post);
        await loadPublishHistorySummary();
        await loadPostReports(post.slug);
        await loadPostComments(post.slug);
        await loadAbTest(post.slug);
        await loadPostVersions(post.slug);
        await loadAdminPoll(post.slug);
        formSnapshot = serializeForm();
        hasUnsavedChanges = false;
        if (saveButton) saveButton.dataset.dirty = 'false';
        applyDryRunWarnings([]);
        const justSaved = new URLSearchParams(window.location.search).get('updated') === '1';
        if (justSaved) {
          calculateQualityScore();
        } else {
          showQualityPending();
        }
        refreshSocialPreview();
        return post;
      };

      const stopPublishPolling = () => {
        if (publishPollTimer) {
          window.clearInterval(publishPollTimer);
          publishPollTimer = null;
        }
      };

      const pollPublishJob = async (jobId) => {
        const { data: job, error } = await supabase
          .from('publish_jobs')
          .select('id, status, target_path, commit_sha, error_message, completed_at')
          .eq('id', jobId)
          .single();

        if (error || !job) {
          setMessage(error?.message || 'publish job 상태를 읽을 수 없습니다.', 'error');
          stopPublishPolling();
          setActionBusy('publish', false);
          applyDryRunWarnings([]);
          return;
        }

        renderCurrentJob(job, '최신 상태 반영');

        if (job.status === 'success') {
          stopPublishPolling();
          setActionBusy('publish', false);
          applyDryRunWarnings([]);
          const post = await loadPost();
          if (post) {
            fillReleaseState(post, {
              completedAt: job.completed_at,
              commitSha: job.commit_sha,
              targetPath: job.target_path,
            });
            await loadPublishHistorySummary();
          }
          setMessage(`Publish 완료: ${job.target_path}. Jobs 화면에서도 이력이 보입니다.`, 'success');
        }

        if (job.status === 'failed') {
          stopPublishPolling();
          setActionBusy('publish', false);
          applyDryRunWarnings([]);
          await loadPublishHistorySummary();
          setMessage(job.error_message || 'publish job이 실패했습니다.', 'error');
        }
      };

      const startPublishPolling = (jobId) => {
        stopPublishPolling();
        pollPublishJob(jobId);
        publishPollTimer = window.setInterval(() => {
          if (document.hidden) return;
          pollPublishJob(jobId);
        }, 5000);
      };

      const publishRequestHeaders = async () => {
        const h = { 'Content-Type': 'application/json' };
        if (!supabase) return h;
        const {
          data: { session },
        } = await supabase.auth.getSession();
        if (session?.access_token) {
          h['Authorization'] = `Bearer ${session.access_token}`;
        }
        return h;
      };

      const requestPublish = async (requestedSlug, requestedBy, dryRun, opts = {}) => {
        const bypassWarningGate = Boolean(opts?.bypassWarningGate);
        if (!getCurrentRole()) {
          setMessage('admin_profiles 권한 확인이 끝나기 전에는 publish를 실행할 수 없습니다.', 'error');
          return;
        }
        if (
          !dryRun &&
          !bypassWarningGate &&
          publishWarningsSection instanceof HTMLElement &&
          !publishWarningsSection.hidden
        ) {
          setMessage('품질 경고가 있습니다. 내용을 확인한 뒤 체크하고「그래도 발행」을 눌러 주세요.', 'error');
          return;
        }
        setActionBusy('publish', true);
        setMessage(dryRun ? 'publish dry-run을 실행하는 중입니다...' : 'publish 요청을 실행하는 중입니다...', 'info');
        const response = await fetch('/api/admin/publish', {
          method: 'POST',
          headers: await publishRequestHeaders(),
          body: JSON.stringify({ slug: requestedSlug, requestedBy, dryRun }),
        });

        let payload = null;
        try {
          payload = await response.json();
        } catch {
          payload = null;
        }

        if (!response.ok) {
          setActionBusy('publish', false);
          applyDryRunWarnings([]);
          if (payload?.jobId) {
            renderCurrentJob({ id: payload.jobId, status: 'failed', target_path: payload.targetPath, error_message: payload.error }, 'publish 요청 실패');
          }
          const validationText = Array.isArray(payload?.validationIssues) && payload.validationIssues.length
            ? ` (${payload.validationIssues.join(', ')})`
            : '';
          setMessage((payload?.error || 'publish 요청에 실패했습니다. Pages Functions 환경을 확인하세요.') + validationText, 'error');
          return;
        }

        if (dryRun) {
          setActionBusy('publish', false);
          renderCurrentJob({ id: 'dry-run', status: 'success', target_path: payload.targetPath, commit_sha: null, completed_at: new Date().toISOString() }, `Dry run 완료 · status ${payload.postStatus || '-'}`);
          fillReleaseState({
            status: payload.postStatus || 'draft',
            published_at: null,
            canonical_url: form.elements.canonical_url?.value || null,
            category: form.elements.category?.value || null,
            slug: currentSlug,
          }, {
            completedAt: new Date().toISOString(),
            targetPath: payload.targetPath,
            commitSha: null,
          });
          const wrn = Array.isArray(payload.warnings) ? payload.warnings : [];
          applyDryRunWarnings(wrn);
          let msg = `Dry run 완료: ${payload.targetPath}`;
          if (wrn.length) {
            msg += ` · 품질 경고 ${wrn.length}건(노란 카드). 확인 후「그래도 발행」을 사용할 수 있습니다.`;
          }
          setMessage(msg, 'success');
          return;
        }

        applyDryRunWarnings([]);
        renderCurrentJob({ id: payload.jobId, status: 'processing', target_path: payload.targetPath }, 'publish job 생성됨');
        setMessage(`Publish 요청 완료: ${payload.targetPath}. job 상태를 추적합니다.`, 'info');
        if (payload.jobId) {
          startPublishPolling(payload.jobId);
        }
      };

      document.addEventListener('admin:session-ready', async ({ detail }) => {
        supabase = window.__adminSupabase;
        currentUserId = detail.userId;
        const params = new URLSearchParams(window.location.search);
        if (params.get('created') === '1') {
          setMessage('draft가 생성되었습니다. 이어서 메타를 다듬거나 바로 발행할 수 있습니다.', 'success');
        }
        if (params.get('updated') === '1') {
          if (params.get('version_log_failed') === '1') {
            setMessage(
              '변경 사항은 저장되었으나 버전 히스토리 기록에 실패했습니다. 권한·RLS를 확인해 주세요.',
              'warning',
            );
          } else {
            setMessage('변경 사항이 저장되었습니다. 이어서 preview 또는 publish를 진행할 수 있습니다.', 'success');
          }
        }

        await loadPost();

        reviewCompleteBtn?.addEventListener('click', async () => {
          if (!supabase || !currentPostId) return;
          if (!getCurrentRole()) {
            setMessage('admin_profiles 권한 확인이 끝나기 전에는 사용할 수 없습니다.', 'error');
            return;
          }
          setMessage('검토 완료 처리 중...', 'info');
          if (reviewCompleteBtn instanceof HTMLButtonElement) reviewCompleteBtn.disabled = true;
          const { error: revErr } = await supabase
            .from('posts')
            .update({ last_reviewed_at: new Date().toISOString(), needs_review: false })
            .eq('id', currentPostId);
          if (reviewCompleteBtn instanceof HTMLButtonElement) reviewCompleteBtn.disabled = false;
          if (revErr) {
            setMessage(revErr.message, 'error');
            return;
          }
          setMessage('검토 완료로 기록했습니다.', 'success');
          await loadPost();
        });

        warningsAckCheckbox?.addEventListener('change', () => {
          syncPublishWarningButtons();
        });
        publishAnywayButton?.addEventListener('click', () => {
          void requestPublish(currentSlug, currentUserId, false, { bypassWarningGate: true });
        });
        syncPublishWarningButtons();

        versionListEl?.addEventListener('click', (e) => {
          const btn = e.target.closest('[data-version-open]');
          if (!(btn instanceof HTMLButtonElement)) return;
          const idx = Number.parseInt(btn.getAttribute('data-version-open') || '', 10);
          const v = cachedPostVersions[idx];
          if (v) openVersionPreview(v);
        });

        versionPreviewModal?.addEventListener('click', (e) => {
          if (
            e.target.closest('[data-post-version-preview-close]') ||
            e.target.closest('[data-post-version-preview-close-btn]')
          ) {
            closeVersionPreview();
          }
        });

        document.querySelector('[data-post-version-restore]')?.addEventListener('click', () => {
          if (!versionPreviewCurrent || !form) return;
          if (
            !confirm(
              '이 버전 내용을 편집창에 불러옵니다. 아직 서버에 저장되지 않습니다. 계속할까요?',
            )
          ) {
            return;
          }
          form.elements.title.value = versionPreviewCurrent.title || '';
          form.elements.body.value = versionPreviewCurrent.body_markdown || '';
          closeVersionPreview();
          updateDirtyState();
          setMessage('편집창에 선택한 버전을 불러왔습니다. 확인 후 저장하세요.', 'info');
        });

        const closeTemplateSaveModal = () => {
          if (templateSaveModal instanceof HTMLElement) templateSaveModal.hidden = true;
          if (templateSaveName instanceof HTMLInputElement) templateSaveName.value = '';
          if (templateSaveDesc instanceof HTMLTextAreaElement) templateSaveDesc.value = '';
        };

        document.querySelector('[data-admin-save-as-template]')?.addEventListener('click', () => {
          if (!getCurrentRole()) {
            setMessage('admin_profiles 권한 확인이 끝나기 전에는 템플릿으로 저장할 수 없습니다.', 'error');
            return;
          }
          if (!(templateSaveModal instanceof HTMLElement)) return;
          if (templateSaveName instanceof HTMLInputElement) templateSaveName.value = '';
          if (templateSaveDesc instanceof HTMLTextAreaElement) templateSaveDesc.value = '';
          templateSaveModal.hidden = false;
          templateSaveName?.focus();
        });

        templateSaveModal?.addEventListener('click', (e) => {
          if (
            e.target.closest('[data-admin-template-save-close]') ||
            e.target.closest('[data-admin-template-save-cancel]')
          ) {
            closeTemplateSaveModal();
          }
        });

        document.querySelector('[data-admin-template-save-confirm]')?.addEventListener('click', async () => {
          if (!supabase || !form) return;
          if (!getCurrentRole()) {
            setMessage('admin_profiles 권한 확인이 끝나기 전에는 저장할 수 없습니다.', 'error');
            return;
          }
          const name = templateSaveName instanceof HTMLInputElement ? templateSaveName.value.trim() : '';
          const desc = templateSaveDesc instanceof HTMLTextAreaElement ? templateSaveDesc.value.trim() : '';
          const body = String(form.elements.body?.value ?? '').trim();
          const category = String(form.elements.category?.value ?? '').trim() || null;
          const tagsStr = String(form.elements.tags?.value ?? '');
          const tags = tagsStr
            .split(',')
            .map((t) => t.trim())
            .filter(Boolean);
          if (!name) {
            setMessage('템플릿 이름을 입력하세요.', 'error');
            return;
          }
          if (!body) {
            setMessage('본문이 비어 있으면 템플릿으로 저장할 수 없습니다.', 'error');
            return;
          }
          const { error: tErr } = await supabase.from('post_templates').insert({
            name,
            description: desc || null,
            category,
            body_markdown: body,
            default_tags: tags,
            created_by: currentUserId != null ? String(currentUserId) : null,
          });
          if (tErr) {
            setMessage(tErr.message, 'error');
            return;
          }
          closeTemplateSaveModal();
          setMessage('템플릿을 저장했습니다. 새 글 작성 화면에서 불러올 수 있습니다.', 'success');
        });

        document.addEventListener('keydown', (e) => {
          if (e.key !== 'Escape') return;
          if (templateSaveModal instanceof HTMLElement && !templateSaveModal.hidden) {
            closeTemplateSaveModal();
            return;
          }
          if (versionPreviewModal instanceof HTMLElement && !versionPreviewModal.hidden) {
            closeVersionPreview();
          }
        });

        document.querySelector('[data-admin-poll-options]')?.addEventListener('click', (e) => {
          const rm = e.target.closest('[data-admin-poll-opt-remove]');
          if (!rm) return;
          const row = rm.closest('[data-admin-poll-opt-row]');
          const list = document.querySelector('[data-admin-poll-options]');
          const n = list?.querySelectorAll('[data-admin-poll-opt-row]').length ?? 0;
          if (n <= 2) {
            setMessage('선택지는 최소 2개 필요합니다.', 'error');
            return;
          }
          row?.remove();
        });

        document.querySelector('[data-admin-poll-add-option]')?.addEventListener('click', () => {
          const list = document.querySelector('[data-admin-poll-options]');
          const n = list?.querySelectorAll('[data-admin-poll-opt-row]').length ?? 0;
          if (n >= 4) {
            setMessage('최대 4개까지 추가할 수 있습니다.', 'error');
            return;
          }
          const extraIds = ['c', 'd'];
          addPollOptionRow(extraIds[n - 2] || `opt${n + 1}`, '');
        });

        document.querySelector('[data-admin-poll-create]')?.addEventListener('click', async () => {
          if (!supabase || !form) return;
          if (!getCurrentRole()) {
            setMessage('admin_profiles 권한 확인이 끝나기 전에는 투표를 만들 수 없습니다.', 'error');
            return;
          }
          const slugNow = String(form.elements.slug?.value ?? '').trim() || currentSlug;
          if (!slugNow) {
            showAdminPollMsg('slug를 먼저 저장하거나 입력하세요.', true);
            return;
          }
          const { questionInput } = getAdminPollEls();
          const question =
            questionInput instanceof HTMLInputElement ? questionInput.value.trim() : '';
          const options = collectAdminPollOptions();
          if (!question) {
            showAdminPollMsg('질문을 입력하세요.', true);
            return;
          }
          if (options.length < 2 || options.length > 4) {
            showAdminPollMsg('선택지는 2~4개여야 합니다.', true);
            return;
          }
          const idSet = new Set(options.map((o) => o.id));
          if (idSet.size !== options.length) {
            showAdminPollMsg('옵션 id가 중복되었습니다.', true);
            return;
          }
          showAdminPollMsg('', false);
          const { error: insErr } = await supabase.from('polls').insert({
            slug: slugNow,
            question,
            options,
          });
          if (insErr) {
            if (insErr.code === '23505') {
              showAdminPollMsg('이 slug에 이미 투표가 있습니다. 삭제 후 다시 만들 수 있습니다.', true);
            } else {
              showAdminPollMsg(insErr.message, true);
            }
            return;
          }
          setMessage('투표가 생성되었습니다.', 'success');
          await loadAdminPoll(slugNow);
        });

        document.querySelector('[data-admin-poll-delete]')?.addEventListener('click', async () => {
          if (!supabase || !adminPollCached?.id) return;
          if (!getCurrentRole()) {
            setMessage('admin_profiles 권한 확인이 끝나기 전에는 삭제할 수 없습니다.', 'error');
            return;
          }
          if (!confirm('투표와 모든 투표 결과를 삭제합니다. 계속할까요?')) return;
          const slugNow = String(form?.elements?.slug?.value ?? '').trim() || currentSlug;
          const { error: delErr } = await supabase.from('polls').delete().eq('id', adminPollCached.id);
          if (delErr) {
            setMessage(`투표 삭제 실패: ${delErr.message}`, 'error');
            return;
          }
          adminPollCached = null;
          setMessage('투표가 삭제되었습니다.', 'success');
          await loadAdminPoll(slugNow || currentSlug);
        });

        abStartBtn?.addEventListener('click', async () => {
          if (!(abStartBtn instanceof HTMLButtonElement) || !supabase) return;
          if (!getCurrentRole()) {
            setMessage('admin_profiles 권한 확인이 끝나기 전에는 테스트를 시작할 수 없습니다.', 'error');
            return;
          }
          const slugNow = form?.elements?.slug?.value?.trim() || currentSlug;
          const titleA = form?.elements?.title?.value?.trim() || '';
          const titleB =
            abTitleBInput instanceof HTMLInputElement ? abTitleBInput.value.trim() : '';
          if (!slugNow) {
            setAbMsg('slug가 필요합니다.', 'error');
            return;
          }
          if (!titleA) {
            setAbMsg('제목(A안)을 먼저 입력하세요.', 'error');
            return;
          }
          if (!titleB) {
            setAbMsg('제목 B를 입력하세요.', 'error');
            return;
          }
          setAbMsg('', '');
          abStartBtn.disabled = true;
          const { error: insErr } = await supabase.from('ab_tests').insert({
            slug: slugNow,
            title_a: titleA,
            title_b: titleB,
          });
          abStartBtn.disabled = false;
          if (insErr) {
            setAbMsg(insErr.message.includes('duplicate') || insErr.code === '23505' ? '이 글에 이미 진행 중인 테스트가 있습니다.' : insErr.message, 'error');
            return;
          }
          setAbMsg('테스트가 시작되었습니다.', 'success');
          await loadAbTest(slugNow);
        });

        abWinnerBtns?.forEach((btn) => {
          btn.addEventListener('click', async () => {
            if (!(btn instanceof HTMLButtonElement) || !supabase || !activeAbTest) return;
            const w = btn.getAttribute('data-ab-winner');
            if (w !== 'a' && w !== 'b') return;
            if (!getCurrentRole()) {
              setMessage('admin_profiles 권한 확인이 끝나기 전에는 승자를 확정할 수 없습니다.', 'error');
              return;
            }
            if (!currentPostId) {
              setAbMsg('글 ID를 확인할 수 없습니다.', 'error');
              return;
            }
            const chosenTitle = w === 'a' ? activeAbTest.title_a : activeAbTest.title_b;
            abWinnerBtns.forEach((b) => {
              if (b instanceof HTMLButtonElement) b.disabled = true;
            });
            setAbMsg('승자 반영 중…', 'info');
            const endedAt = new Date().toISOString();
            const { error: abErr } = await supabase
              .from('ab_tests')
              .update({ winner: w, ended_at: endedAt })
              .eq('id', activeAbTest.id);
            if (abErr) {
              setAbMsg(`A/B 종료 저장 실패: ${abErr.message}`, 'error');
              abWinnerBtns.forEach((b) => {
                if (b instanceof HTMLButtonElement) b.disabled = false;
              });
              return;
            }
            const { error: postErr } = await supabase
              .from('posts')
              .update({ title: chosenTitle, updated_by: currentUserId })
              .eq('id', currentPostId);
            if (postErr) {
              setAbMsg(`글 제목 반영 실패: ${postErr.message}`, 'error');
              abWinnerBtns.forEach((b) => {
                if (b instanceof HTMLButtonElement) b.disabled = false;
              });
              return;
            }
            setAbMsg('승자 제목이 posts.title에 반영되었습니다. 필요 시 다시 발행하세요.', 'success');
            await loadPost();
            abWinnerBtns.forEach((b) => {
              if (b instanceof HTMLButtonElement) b.disabled = false;
            });
          });
        });

        reportsList?.addEventListener('click', async (e) => {
          const btn = e.target.closest('[data-admin-report-action]');
          if (!(btn instanceof HTMLButtonElement) || !supabase) return;
          const id = btn.dataset.reportId;
          const next = btn.getAttribute('data-admin-report-action');
          if (!id || (next !== 'resolved' && next !== 'dismissed')) return;
          if (!getCurrentRole()) {
            setMessage('admin_profiles 권한 확인이 끝나기 전에는 신고 상태를 바꿀 수 없습니다.', 'error');
            return;
          }
          btn.disabled = true;
          const { error: upErr } = await supabase.from('post_reports').update({ status: next }).eq('id', id);
          if (upErr) {
            setMessage(`신고 상태 변경 실패: ${upErr.message}`, 'error');
            btn.disabled = false;
            return;
          }
          const slugNow = form?.elements?.slug?.value?.trim() || currentSlug;
          await loadPostReports(slugNow);
        });

        commentsList?.addEventListener('click', async (e) => {
          const approveBtn = e.target.closest('[data-admin-comment-approve]');
          const deleteBtn = e.target.closest('[data-admin-comment-delete]');
          const btn = approveBtn || deleteBtn;
          if (!(btn instanceof HTMLButtonElement) || !supabase) return;
          const id = btn.getAttribute('data-comment-id');
          if (!id) return;
          if (!getCurrentRole()) {
            setMessage('admin_profiles 권한 확인이 끝나기 전에는 댓글을 처리할 수 없습니다.', 'error');
            return;
          }
          btn.disabled = true;
          const slugNow = form?.elements?.slug?.value?.trim() || currentSlug;
          if (approveBtn) {
            const { error: upErr } = await supabase.from('comments').update({ is_approved: true }).eq('id', id);
            if (upErr) {
              setMessage(`댓글 승인 실패: ${upErr.message}`, 'error');
              btn.disabled = false;
              return;
            }
          } else {
            const { error: delErr } = await supabase.from('comments').delete().eq('id', id);
            if (delErr) {
              setMessage(`댓글 삭제 실패: ${delErr.message}`, 'error');
              btn.disabled = false;
              return;
            }
          }
          await loadPostComments(slugNow);
        });

        form?.elements?.slug?.addEventListener('input', (event) => {
          updatePreviewHref(event.target.value.trim());
        });
        form?.addEventListener('input', updateDirtyState);
        form?.addEventListener('change', updateDirtyState);
        document.getElementById('review_interval_days')?.addEventListener('input', updateDirtyState);

        const socialRoot = document.querySelector('[data-admin-social-preview-card]');
        socialRoot?.addEventListener('click', async (e) => {
          const tab = e.target.closest('[data-social-tab]');
          if (tab instanceof HTMLButtonElement) {
            const name = tab.getAttribute('data-social-tab');
            if (!socialRoot || !name) return;
            socialRoot.querySelectorAll('[data-social-tab]').forEach((b) => {
              b.setAttribute('aria-selected', b === tab ? 'true' : 'false');
            });
            socialRoot.querySelectorAll('[data-social-panel]').forEach((p) => {
              p.hidden = p.getAttribute('data-social-panel') !== name;
            });
            return;
          }

          const checkRow = e.target.closest('[data-check-focus]');
          if (checkRow) {
            focusField(checkRow.getAttribute('data-check-focus') || '');
            return;
          }

          const copyBtn = e.target.closest('[data-copy-share]');
          if (copyBtn instanceof HTMLButtonElement) {
            const kind = copyBtn.getAttribute('data-copy-share');
            let v = '';
            if (kind === 'twitter') v = socialRoot?.dataset.shareTwitter || '';
            if (kind === 'kakao') v = socialRoot?.dataset.shareKakao || '';
            if (kind === 'link') v = socialRoot?.dataset.shareLink || '';
            if (!v) return;
            try {
              await navigator.clipboard.writeText(v);
              setMessage('클립보드에 복사했습니다.', 'success');
            } catch {
              setMessage('복사에 실패했습니다.', 'error');
            }
          }
        });

        socialRoot?.addEventListener('keydown', (e) => {
          if (e.key !== 'Enter') return;
          const row = e.target.closest('[data-check-focus]');
          if (row) focusField(row.getAttribute('data-check-focus') || '');
        });

        document.querySelector('[data-admin-social-fetch]')?.addEventListener('click', async () => {
          if (!form) return;
          const status = String(form.elements.status?.value || '');
          if (status !== 'published') {
            setMessage('발행된 글만 실제 확인할 수 있습니다.', 'warn');
            return;
          }
          const urlToFetch =
            String(form.elements.canonical_url?.value || '').trim() || buildLivePostUrl();
          if (!supabase) {
            setMessage('Supabase 클라이언트가 없습니다.', 'error');
            return;
          }
          const {
            data: { session },
          } = await supabase.auth.getSession();
          if (!session?.access_token) {
            setMessage('로그인 세션이 필요합니다.', 'error');
            return;
          }
          const resultEl = document.querySelector('[data-admin-social-fetch-result]');
          if (resultEl instanceof HTMLElement) {
            resultEl.hidden = false;
            resultEl.textContent = '불러오는 중…';
          }
          const res = await fetch('/api/admin/og-fetch', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Authorization: `Bearer ${session.access_token}`,
            },
            body: JSON.stringify({ url: urlToFetch }),
          });
          const json = await res.json().catch(() => ({}));
          if (resultEl instanceof HTMLElement) {
            resultEl.textContent = JSON.stringify(json, null, 2);
          }
          if (!res.ok) {
            setMessage(String(json.error || '실제 확인 실패'), 'error');
          } else {
            setMessage('서버가 공개 HTML을 가져와 메타를 추출했습니다. 아래 JSON과 폼을 비교하세요.', 'success');
          }
        });
        window.addEventListener('beforeunload', (event) => {
          if (!hasUnsavedChanges) return;
          event.preventDefault();
          event.returnValue = '';
        });

        dryRunButton?.addEventListener('click', async () => {
          if (!currentSlug) {
            setMessage('먼저 글을 저장해 slug를 확정하세요.', 'error');
            return;
          }
          if (hasUnsavedChanges) {
            setMessage('미저장 변경이 있습니다. 먼저 저장한 뒤 dry run을 실행하세요.', 'error');
            return;
          }
          await requestPublish(currentSlug, currentUserId, true);
        });

        livePublishButton?.addEventListener('click', async () => {
          if (!currentSlug) {
            setMessage('먼저 글을 저장해 slug를 확정하세요.', 'error');
            return;
          }
          if (hasUnsavedChanges) {
            setMessage('미저장 변경이 있습니다. 먼저 저장한 뒤 발행 요청을 실행하세요.', 'error');
            return;
          }
          await requestPublish(currentSlug, currentUserId, false);
        });

        publishHistorySummary?.addEventListener('click', async (event) => {
          const target = event.target.closest('[data-admin-history-retry]');
          if (!target) return;
          if (!currentSlug) {
            setMessage('현재 slug를 확인할 수 없습니다.', 'error');
            return;
          }
          if (hasUnsavedChanges) {
            setMessage('미저장 변경이 있습니다. 먼저 저장한 뒤 재발행을 실행하세요.', 'error');
            return;
          }
          await requestPublish(currentSlug, currentUserId, false);
        });

        form?.addEventListener('submit', async (event) => {
          event.preventDefault();
          if (!getCurrentRole()) {
            setMessage('admin_profiles 권한 확인이 끝나기 전에는 저장할 수 없습니다.', 'error');
            return;
          }
          if (!currentPostId) {
            setMessage('현재 글 ID를 확인할 수 없습니다.', 'error');
            return;
          }

          const formData = new FormData(form);
          const title = String(formData.get('title') || '').trim();
          const description = String(formData.get('description') || '').trim();
          const nextSlug = slugify(String(formData.get('slug') || '').trim() || title);
          const body = String(formData.get('body') || '').trim();
          const tags = String(formData.get('tags') || '').split(',').map((tag) => tag.trim()).filter(Boolean);
          const status = String(formData.get('status') || 'draft');
          const category = String(formData.get('category') || '') || null;
          const publishedAt = String(formData.get('date') || '') || null;
          const scheduledDateRaw = String(formData.get('scheduled_at_date') || '').trim();
          const scheduled_at = scheduledDateRaw
            ? new Date(`${scheduledDateRaw}T12:00:00`).toISOString()
            : null;
          const thumbnailUrl = String(formData.get('thumbnail_url') || '').trim() || null;
          const seoTitle = String(formData.get('seo_title') || '').trim() || null;
          const seoDescription = String(formData.get('seo_description') || '').trim() || null;
          const canonicalUrl = String(formData.get('canonical_url') || '').trim() || null;
          let reviewIntervalDays = parseInt(String(formData.get('review_interval_days') || '180'), 10);
          if (!Number.isFinite(reviewIntervalDays)) reviewIntervalDays = 180;
          reviewIntervalDays = Math.min(365, Math.max(30, Math.floor(reviewIntervalDays)));

          if (!title || !description || !body) {
            setMessage('제목, 설명, 본문은 필수입니다.', 'error');
            return;
          }

          if (!nextSlug) {
            setMessage('유효한 slug를 생성할 수 없습니다. 제목 또는 slug를 확인하세요.', 'error');
            return;
          }

          const { data: duplicatePost, error: duplicateError } = await supabase
            .from('posts')
            .select('id')
            .eq('slug', nextSlug)
            .neq('id', currentPostId)
            .maybeSingle();

          if (duplicateError) {
            setMessage(`기존 slug 확인에 실패했습니다: ${duplicateError.message}`, 'error');
            return;
          }

          if (duplicatePost) {
            setMessage(`이미 사용 중인 slug입니다: ${nextSlug}`, 'error');
            return;
          }

          const summaryResult = await openSaveSummaryModal();
          if (!summaryResult.ok) {
            setMessage('저장을 취소했습니다.', 'info');
            return;
          }
          const changeSummary = summaryResult.summary;

          setActionBusy('save', true);
          setMessage('변경 사항을 저장하는 중입니다...', 'info');

          const payload = {
            title,
            description,
            slug: nextSlug,
            body_markdown: body,
            tags,
            status,
            category,
            published_at: publishedAt,
            scheduled_at,
            thumbnail_url: thumbnailUrl,
            seo_title: seoTitle,
            seo_description: seoDescription,
            canonical_url: canonicalUrl,
            review_interval_days: reviewIntervalDays,
            updated_by: currentUserId,
          };

          const { error: updateError } = await supabase.from('posts').update(payload).eq('id', currentPostId);
          if (updateError) {
            setActionBusy('save', false);
            setMessage(updateError.message, 'error');
            return;
          }

          let versionLogFailed = false;
          const { error: versionError } = await supabase.from('post_versions').insert({
            post_id: currentPostId,
            slug: nextSlug,
            title,
            body_markdown: body,
            changed_by: currentUserId != null ? String(currentUserId) : null,
            change_summary: changeSummary || null,
          });
          if (versionError) {
            versionLogFailed = true;
            console.warn('post_versions insert failed:', versionError);
          }

          const { error: revisionError } = await supabase.from('post_revisions').insert({
            post_id: currentPostId,
            body_markdown: body,
            meta_snapshot: { title, description, slug: nextSlug, category, tags, status, thumbnail_url: thumbnailUrl, seo_title: seoTitle, seo_description: seoDescription, canonical_url: canonicalUrl, scheduled_at },
            created_by: currentUserId,
          });
          if (revisionError) {
            setActionBusy('save', false);
            const extra = versionLogFailed ? ' 버전 기록도 남지 않았을 수 있습니다.' : '';
            setMessage(`수정은 저장됐지만 revision 생성에 실패했습니다: ${revisionError.message}.${extra}`, 'error');
            return;
          }

          await supabase.from('audit_logs').insert({
            actor_id: currentUserId,
            action: 'post_updated',
            resource_type: 'post',
            resource_id: currentPostId,
            after_json: { title, slug: nextSlug, status },
          });

          setActionBusy('save', false);
          formSnapshot = serializeForm();
          hasUnsavedChanges = false;
          if (saveButton) saveButton.dataset.dirty = 'false';
          calculateQualityScore();
          const verQ = versionLogFailed ? '&version_log_failed=1' : '';
          if (nextSlug && nextSlug !== currentSlug) {
            window.location.replace(`/admin/posts/edit?slug=${encodeURIComponent(nextSlug)}&updated=1${verQ}`);
          } else {
            window.location.replace(
              '/admin/posts/edit?slug=' + encodeURIComponent(currentSlug) + '&updated=1' + verQ,
            );
          }
        });
      });
    }
  </script>
</AdminLayout>
