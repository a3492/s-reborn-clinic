---
import AdminLayout from '../../../layouts/AdminLayout.astro';

---

<AdminLayout
  title="Posts"
  pageTitle="Posts"
  pageDescription="글 목록, 최근 publish 상태, 수정 진입점을 함께 관리합니다."
  status="Draft List"
>
  <div class="admin-card pad-lg">
    <div class="admin-actions-row">
      <div>
        <h2 class="admin-section-title">Post List</h2>
        <p class="admin-section-desc">최신 글과 최근 publish 결과를 함께 확인합니다.</p>
      </div>
      <a href="/admin/posts/new" class="admin-btn primary">새 글 작성</a>
    </div>

    <p class="admin-inline-note" data-admin-posts-message hidden></p>

    <div class="admin-table-wrap">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Title</th>
          <th>Category</th>
          <th>Post Status</th>
          <th>Latest Publish</th>
          <th>Updated</th>
          <th>공개 관리</th>
        </tr>
      </thead>
      <tbody data-admin-posts-body>
        <tr>
          <td colspan="6">불러오는 중...</td>
        </tr>
      </tbody>
    </table>
    </div>
    <p class="admin-inline-note" data-admin-toggle-message hidden></p>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js';
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    const tbody = document.querySelector('[data-admin-posts-body]');
    const message = document.querySelector('[data-admin-posts-message]');

    const setMessage = (text, state = 'info') => {
      if (!message) return;
      message.hidden = false;
      message.textContent = text;
      message.dataset.state = state;
    };

    const formatDate = (value) => {
      if (!value) return '-';
      return new Intl.DateTimeFormat('ko-KR', {
        year: 'numeric', month: '2-digit', day: '2-digit',
        hour: '2-digit', minute: '2-digit'
      }).format(new Date(value));
    };

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const indexLatestJobs = (rows) => {
      const map = new Map();
      for (const row of rows ?? []) {
        if (!row.post_id || map.has(row.post_id)) continue;
        map.set(row.post_id, row);
      }
      return map;
    };

    const toggleMessage = document.querySelector('[data-admin-toggle-message]');

    const setToggleMessage = (text, state = 'info') => {
      if (!toggleMessage) return;
      toggleMessage.hidden = false;
      toggleMessage.textContent = text;
      toggleMessage.dataset.state = state;
      setTimeout(() => { toggleMessage.hidden = true; }, 5000);
    };

    const renderRows = (rows, latestJobs) => {
      if (!tbody) return;
      if (!rows.length) {
        tbody.innerHTML = '<tr><td colspan="6">아직 저장된 draft가 없습니다.</td></tr>';
        return;
      }

      tbody.innerHTML = rows.map((row) => {
        const latestJob = latestJobs.get(row.id);
        const latestPublish = latestJob
          ? `<div class="admin-status-stack"><span class="admin-status ${escapeHtml(latestJob.status)}">${escapeHtml(latestJob.status)}</span><span class="admin-cell-subtle">${formatDate(latestJob.created_at)}</span></div>`
          : '<span class="admin-cell-subtle">이력 없음</span>';
        const commitOrError = latestJob?.status === 'failed'
          ? `<span class="admin-cell-error">${escapeHtml(latestJob.error_message ?? 'unknown error')}</span>`
          : `<span class="admin-cell-mono">${escapeHtml(latestJob?.commit_sha ?? '-')}</span>`;

        const isPublished = row.status === 'published';
        const toggleLabel = isPublished ? '비공개 전환' : '공개 발행';
        const toggleClass = isPublished ? 'admin-btn admin-btn-sm danger' : 'admin-btn admin-btn-sm primary';

        return `
          <tr>
            <td>
              <a class="admin-table-link" href="/admin/posts/edit?slug=${encodeURIComponent(row.slug)}">${escapeHtml(row.title)}</a>
              <div class="admin-cell-subtle">${escapeHtml(row.slug)}</div>
            </td>
            <td>${escapeHtml(row.category ?? '-')}</td>
            <td><span class="admin-status ${escapeHtml(row.status)}">${escapeHtml(row.status)}</span></td>
            <td>
              ${latestPublish}
              <div class="admin-cell-subtle">${commitOrError}</div>
            </td>
            <td>${formatDate(row.updated_at)}</td>
            <td>
              <button
                class="${escapeHtml(toggleClass)}"
                data-toggle-slug="${escapeHtml(row.slug)}"
                data-toggle-status="${escapeHtml(row.status)}"
              >${escapeHtml(toggleLabel)}</button>
            </td>
          </tr>
        `;
      }).join('');
    };

    if (!supabaseUrl || !supabaseKey) {
      renderRows([], new Map());
      setMessage('Supabase 환경 변수가 없어 목록을 불러올 수 없습니다.', 'error');
    } else {
      let supabase = null;

      const params = new URLSearchParams(window.location.search);
      if (params.get('saved') === '1') {
        setMessage('draft가 저장되었습니다.', 'success');
      }
      if (params.get('updated') === '1') {
        setMessage('draft가 수정되었습니다.', 'success');
      }

      // 비공개/공개 토글
      document.addEventListener('click', async (e) => {
        const btn = e.target.closest('[data-toggle-slug]');
        if (!btn) return;

        const slug = btn.dataset.toggleSlug;
        const currentStatus = btn.dataset.toggleStatus;
        const newStatus = currentStatus === 'published' ? 'draft' : 'published';
        const label = newStatus === 'published' ? '공개' : '비공개';

        btn.disabled = true;
        btn.textContent = '처리 중...';

        // 1. Supabase status 업데이트
        const { error: updateError } = await supabase
          .from('posts')
          .update({ status: newStatus, updated_at: new Date().toISOString() })
          .eq('slug', slug);

        if (updateError) {
          setToggleMessage(`상태 변경 실패: ${updateError.message}`, 'error');
          btn.disabled = false;
          btn.textContent = currentStatus === 'published' ? '비공개 전환' : '공개 발행';
          return;
        }

        // 2. publish 파이프라인 실행 (markdown 파일 업데이트 + GitHub 커밋)
        const publishRes = await fetch('/api/admin/publish', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug }),
        });

        const publishResult = await publishRes.json().catch(() => ({}));

        if (!publishRes.ok) {
          setToggleMessage(`파일 업데이트 실패: ${publishResult.error ?? '알 수 없는 오류'}`, 'error');
          btn.disabled = false;
          btn.textContent = currentStatus === 'published' ? '비공개 전환' : '공개 발행';
          return;
        }

        setToggleMessage(`"${slug}" → ${label}로 전환됨. 배포 완료까지 1~2분 소요.`, 'success');
        // 목록 새로고침
        await loadPosts();
      });

      const loadPosts = async () => {
        const [postsResult, jobsResult] = await Promise.all([
          supabase
            .from('posts')
            .select('id, title, slug, category, status, updated_at')
            .order('updated_at', { ascending: false })
            .limit(20),
          supabase
            .from('publish_jobs')
            .select('post_id, status, commit_sha, error_message, created_at')
            .order('created_at', { ascending: false })
            .limit(60),
        ]);

        if (postsResult.error) {
          renderRows([], new Map());
          setMessage(postsResult.error.message, 'error');
        } else {
          renderRows(postsResult.data ?? [], indexLatestJobs(jobsResult.data ?? []));
          if (jobsResult.error) {
            setMessage(`글 목록은 불러왔지만 publish 이력은 읽지 못했습니다: ${jobsResult.error.message}`, 'error');
          }
        }
      };

      document.addEventListener('admin:session-ready', async () => {
        supabase = window.__adminSupabase;
        await loadPosts();
      });
    }
  </script>
</AdminLayout>