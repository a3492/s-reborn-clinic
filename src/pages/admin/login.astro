---
import '../../styles/admin.css';
import BaseHead from '../../components/BaseHead.astro';

---

<!doctype html>
<html lang="ko" class="admin-shell">
  <head>
    <BaseHead title="Admin Login | 에스리본 클리닉" description="에스리본 클리닉 관리자 로그인" applyVisitorTheme={false} />
  </head>
  <body class="admin-shell admin-login-body">
    <main class="admin-login-shell">
      <section class="admin-login-card">
        <span class="admin-brand-kicker">Admin Login</span>
        <h1 class="admin-login-title">에스리본 클리닉 운영 패널</h1>
        <p class="admin-login-desc">Supabase 계정으로 로그인한 뒤 관리자 페이지에 접근합니다.</p>

        <form class="admin-login-form" data-admin-login-form>
          <label class="admin-field">
            <span class="admin-label">이메일</span>
            <input class="admin-input" type="email" name="email" placeholder="you@example.com" required />
          </label>

          <label class="admin-field">
            <span class="admin-label">비밀번호</span>
            <input class="admin-input" type="password" name="password" placeholder="비밀번호" required />
          </label>

          <button type="submit" class="admin-btn primary admin-login-submit">로그인</button>
        </form>

        <div class="admin-login-magic-wrap">
          <button type="button" class="admin-btn admin-login-magic" data-admin-magic-link>매직 링크 보내기</button>
          <p class="admin-login-magic-desc">비밀번호 없이 로그인 — 이메일에 1회용 링크를 보내드립니다. 링크 클릭 시 자동 로그인됩니다.</p>
        </div>
        <p class="admin-login-message" data-admin-login-message hidden></p>
      </section>
    </main>

    <script>
      import { createClient } from '@supabase/supabase-js';
      const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
      const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

      const form = document.querySelector('[data-admin-login-form]');
      const magicLinkButton = document.querySelector('[data-admin-magic-link]');
      const message = document.querySelector('[data-admin-login-message]');
      const params = new URLSearchParams(window.location.search);
      const redirectTo = params.get('redirectTo') || '/admin';

      const setMessage = (text, type = 'info') => {
        if (!message) return;
        message.hidden = false;
        message.textContent = text;
        message.dataset.state = type;
      };

      if (!supabaseUrl || !supabaseKey) {
        setMessage('PUBLIC_SUPABASE_URL 또는 PUBLIC_SUPABASE_ANON_KEY가 없습니다.', 'error');
      } else {
        const supabase = createClient(supabaseUrl, supabaseKey, {
          auth: {
            persistSession: true,
            autoRefreshToken: true,
            detectSessionInUrl: true,
          },
        });

        // URL 해시의 access_token 처리 (매직 링크 클릭 후 리다이렉트된 경우)
        supabase.auth.onAuthStateChange((event, session) => {
          if ((event === 'SIGNED_IN' || event === 'TOKEN_REFRESHED') && session) {
            window.location.replace(redirectTo);
          }
        });

        const { data } = await supabase.auth.getSession();
        if (data.session) {
          window.location.replace(redirectTo);
        }

        form?.addEventListener('submit', async (event) => {
          event.preventDefault();
          const formData = new FormData(form);
          const email = String(formData.get('email') || '').trim();
          const password = String(formData.get('password') || '');

          if (!email || !password) {
            setMessage('이메일과 비밀번호를 모두 입력하세요.', 'error');
            return;
          }

          setMessage('로그인 중입니다...', 'info');
          const { error } = await supabase.auth.signInWithPassword({ email, password });
          if (error) {
            setMessage(error.message, 'error');
            return;
          }

          window.location.replace(redirectTo);
        });

        magicLinkButton?.addEventListener('click', async () => {
          const emailInput = form?.querySelector('input[name="email"]');
          const email = emailInput?.value?.trim();
          if (!email) {
            setMessage('매직 링크를 받으려면 이메일을 먼저 입력하세요.', 'error');
            return;
          }

          setMessage('매직 링크를 보내는 중입니다...', 'info');
          const { error } = await supabase.auth.signInWithOtp({
            email,
            options: {
              emailRedirectTo: window.location.href,  // 로그인 페이지로 되돌아와서 토큰 처리 후 admin 이동
            },
          });

          if (error) {
            setMessage(error.message, 'error');
            return;
          }

          setMessage('매직 링크를 보냈습니다. 메일함을 확인하세요.', 'success');
        });
      }
    </script>
  </body>
</html>
