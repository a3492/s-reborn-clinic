---
import { getCollection } from 'astro:content';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { isAcademyBlogPost } from '../../../lib/academy';

const recentClinicPostsForFeatured = (await getCollection('blog', ({ data }) => !data.draft))
  .filter((p) => !isAcademyBlogPost(p))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 20)
  .map((p) => ({ id: p.id, title: p.data.title }));

const featuredPickerJson = JSON.stringify(recentClinicPostsForFeatured).replace(/</g, '\\u003c');
---

<AdminLayout
  title="Settings"
  pageTitle="Settings"
  pageDescription="사이트 전역 설정과 소개/SEO 설정을 이 화면에서 저장합니다."
  status="Settings"
  requiredRole="owner"
>
  <div class="admin-split">
    <section class="admin-card pad-lg">
      <div class="admin-actions-row">
        <div>
          <h2 class="admin-section-title">Site Settings</h2>
          <p class="admin-section-desc">기본 메타, 소개 텍스트, featured slug를 저장합니다.</p>
        </div>
        <button type="submit" form="admin-settings-form" class="admin-btn primary">설정 저장</button>
      </div>

      <form id="admin-settings-form" class="admin-form-grid" data-admin-settings-form>
        <div class="admin-field full">
          <label class="admin-label" for="site-title">사이트 제목</label>
          <input id="site-title" name="site_title" class="admin-input" type="text" placeholder="S-Reborn World" />
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="site-description">기본 설명</label>
          <textarea id="site-description" name="site_description" class="admin-textarea" style="min-height: 110px;" placeholder="사이트 기본 메타 설명"></textarea>
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="featured-slug">홈 피처드 글 (클리닉 블로그)</label>
          <p class="admin-help" style="margin-bottom: 0.5rem;">
            저장된 slug: <strong data-admin-featured-slug-current>(불러오는 중)</strong>
            <span class="admin-cell-subtle"> · <code>site_settings.homepage.featured_slug</code></span>
          </p>
          <div class="admin-field-row" style="display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: flex-end; margin-bottom: 0.5rem;">
            <div class="admin-field" style="flex: 1; min-width: 220px; margin-bottom: 0;">
              <label class="admin-label" for="featured-slug-picker">최근 글에서 선택</label>
              <select id="featured-slug-picker" class="admin-select" data-featured-slug-picker>
                <option value="">— 선택 —</option>
              </select>
            </div>
          </div>
          <input
            id="featured-slug"
            name="featured_slug"
            class="admin-input"
            type="text"
            placeholder="doctor-column/welcome-skin-aging"
            autocomplete="off"
          />
          <span class="admin-help">블로그 글 id(경로)와 동일해야 합니다. 비우면 홈에서 클리닉 최신 글 1편이 피처드로 쓰입니다.</span>
        </div>

        <script type="application/json" id="admin-featured-post-picker-data" set:html={featuredPickerJson}></script>

        <div class="admin-field">
          <label class="admin-label" for="default-og-image">기본 OG 이미지</label>
          <input id="default-og-image" name="default_og_image" class="admin-input" type="text" placeholder="/blog-og-default.jpg" />
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="about-intro">About 소개문</label>
          <textarea id="about-intro" name="about_intro" class="admin-textarea" style="min-height: 180px;" placeholder="About 페이지 핵심 소개문"></textarea>
        </div>

        <div class="admin-field full">
          <label class="admin-label" for="social-links">소셜 링크(JSON)</label>
          <textarea id="social-links" name="social_links" class="admin-textarea" style="min-height: 160px;" placeholder='{"github":"https://...","linkedin":"https://..."}'></textarea>
          <span class="admin-help">유효한 JSON이어야 합니다.</span>
        </div>
      </form>

      <p class="admin-inline-note" data-admin-settings-message hidden></p>
    </section>

    <section class="admin-card pad-lg">
      <details class="admin-details-block">
        <summary class="admin-section-title" style="cursor:pointer;list-style:none;">Stored Keys <span class="admin-nav-badge">4</span></summary>
        <ul class="admin-list" style="margin-top:0.5rem;">
          <li class="admin-list-row"><div><p class="admin-item-title">`site_meta`</p><p class="admin-item-meta">title, description, default_og_image</p></div></li>
          <li class="admin-list-row"><div><p class="admin-item-title">`homepage`</p><p class="admin-item-meta">featured_slug</p></div></li>
          <li class="admin-list-row"><div><p class="admin-item-title">`about_page`</p><p class="admin-item-meta">about_intro</p></div></li>
          <li class="admin-list-row"><div><p class="admin-item-title">`social_links`</p><p class="admin-item-meta">JSON object</p></div></li>
        </ul>
      </details>

      <div class="admin-panel-stack" style="margin-top: 1rem;">
        <section class="admin-preview-card">
          <div class="admin-preview-kicker">Resolved Preview</div>
          <h3 class="admin-preview-title" data-settings-preview-title>S-Reborn World</h3>
          <p class="admin-preview-desc" data-settings-preview-description>사이트 기본 메타 설명</p>
          <div class="admin-preview-meta">
            <span data-settings-preview-featured>featured: 미설정</span>
            <span data-settings-preview-og>OG: 미설정</span>
          </div>
        </section>

        <section class="admin-card pad-md">
          <h3 class="admin-section-title">Social Preview</h3>
          <p class="admin-section-desc">푸터와 About에 노출될 링크 미리보기입니다.</p>
          <div class="admin-link-chips" data-settings-social-preview>
            <span class="admin-chip muted">등록된 소셜 링크가 없습니다.</span>
          </div>
        </section>

        <details class="admin-details-block">
          <summary class="admin-section-title" style="cursor:pointer;list-style:none;">Validation <span data-settings-validation-summary class="admin-cell-subtle"></span></summary>
          <ul class="admin-list" style="margin-top:0.5rem;" data-settings-validation>
            <li class="admin-list-row"><div><p class="admin-item-title">대기 중</p><p class="admin-item-meta">입력값을 읽는 중입니다.</p></div></li>
          </ul>
        </details>

        <section class="admin-card pad-md">
          <h3 class="admin-section-title">Recent Changes</h3>
          <div data-settings-history>
            <p class="admin-help">불러오는 중...</p>
          </div>
        </section>
      </div>
    </section>
  </div>

  <section class="admin-card pad-lg" style="margin-top: 1.25rem;" data-admin-disclaimers-root>
    <div class="admin-actions-row">
      <div>
        <h2 class="admin-section-title">면책 고지</h2>
        <p class="admin-section-desc">
          블로그 글에서 제목(h1) 바로 아래에 카테고리별 면책 문구가 자동 삽입됩니다. DB의 <code>disclaimers</code> 테이블을 사용하며, 비활성 항목은 공개 사이트에 노출되지 않습니다.
        </p>
      </div>
      <button type="button" class="admin-btn" data-admin-disclaimers-refresh>다시 불러오기</button>
    </div>
    <p class="admin-help" style="margin: 0.5rem 0 0.75rem;">
      편집·저장은 <strong>owner</strong>만 가능합니다. API는 서버에서 <code>SUPABASE_SERVICE_ROLE_KEY</code>로 PATCH 합니다.
    </p>
    <div data-admin-disclaimers-list>
      <p class="admin-help">세션 준비 후 목록을 불러옵니다.</p>
    </div>
    <p class="admin-inline-note" data-admin-disclaimers-message hidden></p>
  </section>

  <section class="admin-card pad-lg" style="margin-top: 1.25rem;">
    <div class="admin-actions-row">
      <div>
        <h2 class="admin-section-title">뉴스레터</h2>
        <p class="admin-section-desc">
          지난 7일간 발행된 글 중 조회수 상위 최대 5편을 묶어 Resend로 발송합니다. 구독자는 <code>lab_waitlist</code> 전체이며, 매주 월요일 09:00(KST)에 Edge Function이 자동 실행될 수 있습니다.
        </p>
      </div>
    </div>
    <ul class="admin-list" style="margin: 0.75rem 0 1rem;">
      <li class="admin-list-row">
        <div>
          <p class="admin-item-title">구독자 수</p>
          <p class="admin-item-meta">이메일 구독·대기 목록</p>
        </div>
        <div><strong data-newsletter-subscriber-count>—</strong></div>
      </li>
      <li class="admin-list-row">
        <div>
          <p class="admin-item-title">마지막 발송</p>
          <p class="admin-item-meta">수동·자동 발송 공통</p>
        </div>
        <div><span data-newsletter-last-sent>—</span></div>
      </li>
    </ul>
    <div class="admin-actions-row" style="align-items: center;">
      <button type="button" class="admin-btn primary" data-newsletter-send>지금 발송</button>
      <span class="admin-help">Supabase Function <code>weekly-newsletter</code> 및 Resend·SITE_URL 시크릿이 필요합니다.</span>
    </div>
    <p class="admin-inline-note" data-newsletter-message hidden></p>
  </section>

  <section class="admin-card pad-lg" style="margin-top: 1.25rem;">
    <div class="admin-actions-row">
      <div>
        <h2 class="admin-section-title">주간 리포트</h2>
        <p class="admin-section-desc">
          매주 월요일 08:00(KST) 전후에 <code>admin_profiles</code>의 <strong>owner</strong> 중 리포트 수신이 켜진 계정으로 운영 요약 메일을 보냅니다. Supabase Function <code>admin-weekly-report</code>·Resend·<code>SITE_URL</code>이 필요합니다.
        </p>
      </div>
    </div>
    <div class="admin-field full" style="margin: 0.75rem 0 1rem;" data-report-owner-only hidden>
      <label class="admin-label" style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
        <input type="checkbox" data-report-receive />
        <span>owner 리포트 이메일 수신</span>
      </label>
      <span class="admin-help">끄면 자동·수동 발송 모두에서 제외됩니다.</span>
    </div>
    <p class="admin-help" data-report-non-owner-note hidden style="margin: 0.75rem 0 1rem;">
      리포트는 <strong>owner</strong> 역할 계정으로만 발송됩니다.
    </p>
    <ul class="admin-list" style="margin: 0 0 1rem;">
      <li class="admin-list-row">
        <div>
          <p class="admin-item-title">마지막 발송</p>
          <p class="admin-item-meta">수동·자동 공통</p>
        </div>
        <div><span data-report-last-sent>—</span></div>
      </li>
    </ul>
    <div class="admin-actions-row" style="align-items: center;">
      <button type="button" class="admin-btn primary" data-report-send>지금 리포트 발송</button>
    </div>
    <p class="admin-inline-note" data-report-message hidden></p>
  </section>

  <section class="admin-card pad-lg" style="margin-top: 1.25rem;">
    <h2 class="admin-section-title">운영자 관리</h2>
    <p class="admin-section-desc">
      <code>admin_profiles</code>에 등록된 관리자입니다. 역할 변경과 프로필 삭제는 owner만 할 수 있습니다.
    </p>
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>이메일</th>
            <th>역할</th>
            <th>등록일</th>
            <th>작업</th>
          </tr>
        </thead>
        <tbody data-admin-operators-tbody>
          <tr>
            <td colspan="4"><p class="admin-help">세션 준비 후 목록을 불러옵니다.</p></td>
          </tr>
        </tbody>
      </table>
    </div>
    <p class="admin-inline-note" data-admin-operators-message hidden></p>
  </section>

  <script>
    import { createClient } from '@supabase/supabase-js';
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    const form = document.querySelector('[data-admin-settings-form]');
    const message = document.querySelector('[data-admin-settings-message]');
    const previewTitle = document.querySelector('[data-settings-preview-title]');
    const previewDescription = document.querySelector('[data-settings-preview-description]');
    const previewFeatured = document.querySelector('[data-settings-preview-featured]');
    const previewOg = document.querySelector('[data-settings-preview-og]');
    const socialPreview = document.querySelector('[data-settings-social-preview]');
    const validationList = document.querySelector('[data-settings-validation]');
    const validationSummary = document.querySelector('[data-settings-validation-summary]');
    const historyList = document.querySelector('[data-settings-history]');
    const featuredSlugCurrentEl = document.querySelector('[data-admin-featured-slug-current]');
    const operatorsTbody = document.querySelector('[data-admin-operators-tbody]');
    const operatorsMessage = document.querySelector('[data-admin-operators-message]');
    const newsletterSubscriberCount = document.querySelector('[data-newsletter-subscriber-count]');
    const newsletterLastSent = document.querySelector('[data-newsletter-last-sent]');
    const newsletterSendBtn = document.querySelector('[data-newsletter-send]');
    const newsletterMessage = document.querySelector('[data-newsletter-message]');
    const reportReceiveCb = document.querySelector('[data-report-receive]');
    const reportOwnerOnly = document.querySelector('[data-report-owner-only]');
    const reportNonOwnerNote = document.querySelector('[data-report-non-owner-note]');
    const reportLastSent = document.querySelector('[data-report-last-sent]');
    const reportSendBtn = document.querySelector('[data-report-send]');
    const reportMessage = document.querySelector('[data-report-message]');
    const disclaimersPanelList = document.querySelector('[data-admin-disclaimers-list]');
    const disclaimersMessage = document.querySelector('[data-admin-disclaimers-message]');
    const disclaimersRefreshBtn = document.querySelector('[data-admin-disclaimers-refresh]');
    let featuredPickerPosts = [];
    let featuredSlugPickerInitialized = false;
    let operatorRows = [];
    let operatorsUiBound = false;
    const getCurrentRole = () => document.body.dataset.adminRole || '';

    const setOperatorsMessage = (text, state = 'info') => {
      if (!operatorsMessage) return;
      if (!text) {
        operatorsMessage.hidden = true;
        operatorsMessage.textContent = '';
        return;
      }
      operatorsMessage.hidden = false;
      operatorsMessage.textContent = text;
      operatorsMessage.dataset.state = state;
    };

    const countOwners = () => operatorRows.filter((r) => r.role === 'owner').length;

    const renderOperatorsTable = () => {
      if (!operatorsTbody) return;
      const myId = document.body.dataset.adminUserId || '';
      const oc = countOwners();

      if (!operatorRows.length) {
        operatorsTbody.innerHTML =
          '<tr><td colspan="4"><p class="admin-help">등록된 운영자가 없습니다.</p></td></tr>';
        return;
      }

      operatorsTbody.innerHTML = operatorRows
        .map((row) => {
          const onlyOwner = row.role === 'owner' && oc <= 1;
          const disableMutate = onlyOwner ? ' disabled' : '';
          return `
            <tr data-admin-op-row data-op-id="${escapeHtml(row.id)}">
              <td>${escapeHtml(row.email)}</td>
              <td>
                <select class="admin-select" data-admin-op-role${disableMutate} aria-label="역할">
                  <option value="owner" ${row.role === 'owner' ? 'selected' : ''}>owner</option>
                  <option value="editor" ${row.role === 'editor' ? 'selected' : ''}>editor</option>
                </select>
              </td>
              <td>${formatDate(row.created_at)}</td>
              <td>
                <button type="button" class="admin-btn admin-btn-sm" data-admin-op-delete${disableMutate}>삭제</button>
                ${row.id === myId ? '<span class="admin-cell-subtle">(나)</span>' : ''}
              </td>
            </tr>
          `;
        })
        .join('');
    };

    const loadOperators = async (supabaseClient) => {
      if (!supabaseClient || !operatorsTbody) return;
      setOperatorsMessage('');
      const { data, error } = await supabaseClient
        .from('admin_profiles')
        .select('id, email, role, created_at')
        .order('created_at', { ascending: true });

      if (error) {
        setOperatorsMessage(error.message, 'error');
        operatorsTbody.innerHTML = `<tr><td colspan="4"><p class="admin-help admin-help-error">${escapeHtml(error.message)}</p></td></tr>`;
        return;
      }

      operatorRows = data || [];
      renderOperatorsTable();
    };

    const syncFeaturedSlugPickerFromInput = () => {
      const picker = document.querySelector('[data-featured-slug-picker]');
      if (!picker || !form || !featuredPickerPosts.length) return;
      const v = String(form.elements.featured_slug.value || '').trim();
      picker.value = featuredPickerPosts.some((p) => p.id === v) ? v : '';
    };

    const initFeaturedSlugPicker = () => {
      if (featuredSlugPickerInitialized) return;
      const dataEl = document.getElementById('admin-featured-post-picker-data');
      const picker = document.querySelector('[data-featured-slug-picker]');
      if (!dataEl || !picker || !form) return;
      featuredSlugPickerInitialized = true;
      try {
        featuredPickerPosts = JSON.parse(dataEl.textContent || '[]');
      } catch {
        featuredPickerPosts = [];
        return;
      }
      picker.replaceChildren();
      const optEmpty = document.createElement('option');
      optEmpty.value = '';
      optEmpty.textContent = '— 선택 —';
      picker.appendChild(optEmpty);
      featuredPickerPosts.forEach(({ id, title }) => {
        const o = document.createElement('option');
        o.value = id;
        o.textContent = `${id} — ${title}`;
        picker.appendChild(o);
      });
      picker.addEventListener('change', () => {
        if (picker.value) {
          form.elements.featured_slug.value = picker.value;
        }
        renderPreview();
      });
    };

    const setMessage = (text, state = 'info') => {
      if (!message) return;
      message.hidden = false;
      message.textContent = text;
      message.dataset.state = state;
    };

    const parseJson = (value) => {
      if (!value.trim()) return {};
      return JSON.parse(value);
    };

    const escapeHtml = (value) =>
      String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');

    const setDisclaimersMessage = (text, state = 'info') => {
      if (!disclaimersMessage) return;
      if (!text) {
        disclaimersMessage.hidden = true;
        disclaimersMessage.textContent = '';
        return;
      }
      disclaimersMessage.hidden = false;
      disclaimersMessage.textContent = text;
      disclaimersMessage.dataset.state = state;
    };

    const disclaimerCategoryLabel = (c) =>
      ({
        general: '일반 (fallback · general)',
        ai: 'AI / Academy (ai)',
        legal: '법률 (legal)',
      })[c] || c;

    const disclaimersAuthHeaders = async (sb) => {
      const h = {};
      if (!sb) return h;
      const {
        data: { session },
      } = await sb.auth.getSession();
      if (session?.access_token) h['Authorization'] = `Bearer ${session.access_token}`;
      return h;
    };

    const renderDisclaimersList = (rows) => {
      if (!disclaimersPanelList) return;
      if (!rows?.length) {
        disclaimersPanelList.innerHTML =
          '<p class="admin-help">등록된 면책 고지가 없습니다. Supabase에 <code>supabase/disclaimers.sql</code>을 적용했는지 확인하세요.</p>';
        return;
      }
      disclaimersPanelList.innerHTML = rows
        .map(
          (row) => `
        <div class="admin-card pad-md" style="margin-bottom: 1rem;border:1px solid var(--admin-border);" data-disclaimer-id="${escapeHtml(row.id)}">
          <div class="admin-actions-row" style="align-items:center;margin-bottom:0.35rem;">
            <h3 class="admin-section-title" style="margin:0;font-size:1rem;">${escapeHtml(disclaimerCategoryLabel(row.category))}</h3>
            <code class="admin-cell-subtle">${escapeHtml(row.category)}</code>
          </div>
          <p class="admin-item-meta" style="margin:0 0 0.5rem;">갱신: ${escapeHtml(row.updated_at || '-')}</p>
          <label class="admin-label" style="display:flex;align-items:center;gap:0.4rem;cursor:pointer;font-size:0.9rem;">
            <input type="checkbox" data-disclaimer-active ${row.is_active ? 'checked' : ''} />
            활성
          </label>
          <textarea class="admin-textarea" data-disclaimer-body style="min-height:120px;margin-top:0.45rem;width:100%;box-sizing:border-box;">${escapeHtml(row.body)}</textarea>
          <button type="button" class="admin-btn admin-btn-sm primary" data-disclaimer-save style="margin-top:0.5rem;">저장</button>
        </div>
      `,
        )
        .join('');
    };

    const loadDisclaimers = async (sb) => {
      if (!disclaimersPanelList || !sb) return;
      disclaimersPanelList.innerHTML = '<p class="admin-help">불러오는 중…</p>';
      setDisclaimersMessage('');
      try {
        const res = await fetch('/api/admin/disclaimers', { headers: await disclaimersAuthHeaders(sb) });
        const payload = await res.json().catch(() => ({}));
        if (!res.ok) {
          disclaimersPanelList.innerHTML = `<p class="admin-help admin-help-error">${escapeHtml(payload.error || res.statusText)}</p>`;
          return;
        }
        renderDisclaimersList(payload.data || []);
      } catch (e) {
        disclaimersPanelList.innerHTML = `<p class="admin-help admin-help-error">${escapeHtml(String(e?.message || e))}</p>`;
      }
    };

    const saveDisclaimerRow = async (sb, card) => {
      if (!sb || !(card instanceof HTMLElement)) return;
      const id = card.getAttribute('data-disclaimer-id');
      const ta = card.querySelector('[data-disclaimer-body]');
      const cb = card.querySelector('[data-disclaimer-active]');
      const saveBtn = card.querySelector('[data-disclaimer-save]');
      if (!id || !(ta instanceof HTMLTextAreaElement) || !(cb instanceof HTMLInputElement)) return;
      if (saveBtn instanceof HTMLButtonElement) saveBtn.disabled = true;
      setDisclaimersMessage('저장 중…', 'info');
      try {
        const res = await fetch('/api/admin/disclaimers', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', ...(await disclaimersAuthHeaders(sb)) },
          body: JSON.stringify({ id, body: ta.value, is_active: cb.checked }),
        });
        const payload = await res.json().catch(() => ({}));
        if (!res.ok) {
          setDisclaimersMessage(payload.error || '저장 실패', 'error');
          return;
        }
        setDisclaimersMessage('저장되었습니다.', 'success');
        await loadDisclaimers(sb);
      } catch (e) {
        setDisclaimersMessage(String(e?.message || e), 'error');
      } finally {
        if (saveBtn instanceof HTMLButtonElement) saveBtn.disabled = false;
      }
    };

    const isProbablyUrl = (value) => /^https?:\/\//i.test(String(value || '').trim()) || String(value || '').trim().startsWith('/');

    const normalizeSocialLinks = (value) => {
      const parsed = parseJson(value);
      if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {
        throw new Error('소셜 링크 JSON은 key/value object여야 합니다.');
      }

      return Object.fromEntries(
        Object.entries(parsed)
          .map(([key, url]) => [String(key || '').trim().toLowerCase(), String(url || '').trim()])
          .filter(([key, url]) => key && url),
      );
    };

    const renderValidation = ({ siteTitle, siteDescription, featuredSlug, defaultOgImage, aboutIntro, socialLinks }) => {
      if (!validationList) return;

      const items = [
        {
          title: siteTitle ? '사이트 제목 준비됨' : '사이트 제목 필요',
          meta: siteTitle ? 'Topbar, footer, SEO title에 반영됩니다.' : '브랜드 제목이 비어 있습니다.',
          state: siteTitle ? 'success' : 'warn',
        },
        {
          title: siteDescription ? '기본 설명 준비됨' : '기본 설명 필요',
          meta: siteDescription ? '기본 메타 description으로 사용됩니다.' : 'RSS/기본 SEO 설명이 비어 있습니다.',
          state: siteDescription ? 'success' : 'warn',
        },
        {
          title: featuredSlug ? '홈 featured 지정됨' : '홈 featured 미지정',
          meta: featuredSlug ? `${featuredSlug}가 홈 메인 카드 우선 후보입니다.` : '최신 글 기준 기본 featured를 사용합니다.',
          state: featuredSlug ? 'success' : 'muted',
        },
        {
          title: defaultOgImage ? '기본 OG 이미지 준비됨' : '기본 OG 이미지 미설정',
          meta: defaultOgImage ? '개별 글 썸네일이 없을 때 fallback으로 사용됩니다.' : '공유 이미지 fallback이 없습니다.',
          state: defaultOgImage ? 'success' : 'warn',
        },
        {
          title: aboutIntro ? 'About 소개문 준비됨' : 'About 소개문 미설정',
          meta: aboutIntro ? 'About 상단 소개문에 바로 반영됩니다.' : '기본 소개문 fallback을 사용합니다.',
          state: aboutIntro ? 'success' : 'muted',
        },
        {
          title: Object.keys(socialLinks).length ? '소셜 링크 준비됨' : '소셜 링크 없음',
          meta: Object.keys(socialLinks).length ? `${Object.keys(socialLinks).length}개 링크가 footer/About에 노출됩니다.` : '푸터 소셜 영역이 비어 있습니다.',
          state: Object.keys(socialLinks).length ? 'success' : 'muted',
        },
      ];

      const warnCount = items.filter((i) => i.state === 'warn').length;
      const okCount = items.filter((i) => i.state === 'success').length;
      if (validationSummary) validationSummary.textContent = `✓${okCount} ⚠${warnCount}`;

      validationList.innerHTML = items
        .map(
          (item) => `
            <li class="admin-list-row">
              <div>
                <p class="admin-item-title">${escapeHtml(item.title)}</p>
                <p class="admin-item-meta">${escapeHtml(item.meta)}</p>
              </div>
              <span class="admin-status ${item.state === 'success' ? 'ready' : item.state === 'warn' ? 'warn' : 'draft'}">
                ${item.state}
              </span>
            </li>
          `,
        )
        .join('');
    };

    const renderPreview = () => {
      if (!form) return null;

      let socialLinks = {};
      try {
        socialLinks = normalizeSocialLinks(String(form.elements.social_links.value || ''));
      } catch {
        socialLinks = {};
      }

      const siteTitle = String(form.elements.site_title.value || '').trim();
      const siteDescription = String(form.elements.site_description.value || '').trim();
      const featuredSlug = String(form.elements.featured_slug.value || '').trim();
      const defaultOgImage = String(form.elements.default_og_image.value || '').trim();
      const aboutIntro = String(form.elements.about_intro.value || '').trim();

      if (previewTitle) previewTitle.textContent = siteTitle || '사이트 제목이 비어 있습니다.';
      if (previewDescription) previewDescription.textContent = siteDescription || '기본 메타 설명이 비어 있습니다.';
      if (previewFeatured) previewFeatured.textContent = featuredSlug ? `featured: ${featuredSlug}` : 'featured: 자동 선택';
      if (previewOg) previewOg.textContent = defaultOgImage ? `OG: ${defaultOgImage}` : 'OG: 미설정';

      if (featuredSlugCurrentEl) {
        featuredSlugCurrentEl.textContent = featuredSlug
          ? featuredSlug
          : '(비어 있음 — 홈은 클리닉 최신 글을 피처드로 사용)';
      }
      syncFeaturedSlugPickerFromInput();

      if (socialPreview) {
        const entries = Object.entries(socialLinks);
        socialPreview.innerHTML = entries.length
          ? entries
              .map(
                ([key, url]) => `
                  <a class="admin-chip" href="${escapeHtml(url)}" target="_blank" rel="noreferrer">
                    ${escapeHtml(key)}
                  </a>
                `,
              )
              .join('')
          : '<span class="admin-chip muted">등록된 소셜 링크가 없습니다.</span>';
      }

      renderValidation({ siteTitle, siteDescription, featuredSlug, defaultOgImage, aboutIntro, socialLinks });
      return { siteTitle, siteDescription, featuredSlug, defaultOgImage, aboutIntro, socialLinks };
    };

    const applySnapshotToForm = (snapshot) => {
      if (!form || !snapshot) return;
      form.elements.site_title.value = snapshot.site_meta?.title || '';
      form.elements.site_description.value = snapshot.site_meta?.description || '';
      form.elements.default_og_image.value = snapshot.site_meta?.default_og_image || '';
      form.elements.featured_slug.value = snapshot.homepage?.featured_slug || '';
      form.elements.about_intro.value = snapshot.about_page?.intro || '';
      form.elements.social_links.value = JSON.stringify(snapshot.social_links || {}, null, 2);
      renderPreview();
    };

    const formatDate = (value) => {
      if (!value) return '-';
      return new Intl.DateTimeFormat('ko-KR', {
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
      }).format(new Date(value));
    };

    const setNewsletterMessage = (text, state = 'info') => {
      if (!newsletterMessage) return;
      if (!text) {
        newsletterMessage.hidden = true;
        newsletterMessage.textContent = '';
        return;
      }
      newsletterMessage.hidden = false;
      newsletterMessage.textContent = text;
      newsletterMessage.dataset.state = state;
    };

    const loadNewsletterPanel = async (sb) => {
      if (!sb) return;
      if (newsletterSubscriberCount) {
        const { count, error } = await sb.from('lab_waitlist').select('*', { count: 'exact', head: true });
        newsletterSubscriberCount.textContent = error ? '오류' : String(count ?? 0);
      }
      if (newsletterLastSent) {
        const { data, error } = await sb.from('site_settings').select('value_json').eq('key', 'newsletter').maybeSingle();
        if (error || !data?.value_json?.last_sent_at) {
          newsletterLastSent.textContent = '아직 없음';
        } else {
          newsletterLastSent.textContent = formatDate(data.value_json.last_sent_at);
        }
      }
    };

    const setReportMessage = (text, state = 'info') => {
      if (!reportMessage) return;
      if (!text) {
        reportMessage.hidden = true;
        reportMessage.textContent = '';
        return;
      }
      reportMessage.hidden = false;
      reportMessage.textContent = text;
      reportMessage.dataset.state = state;
    };

    const loadWeeklyReportPanel = async (sb) => {
      if (!sb) return;
      const uid = document.body.dataset.adminUserId || '';
      const isOwner = getCurrentRole() === 'owner';
      if (reportOwnerOnly instanceof HTMLElement) reportOwnerOnly.hidden = !isOwner;
      if (reportNonOwnerNote instanceof HTMLElement) reportNonOwnerNote.hidden = isOwner;

      if (isOwner && uid && reportReceiveCb instanceof HTMLInputElement) {
        const { data, error } = await sb.from('admin_profiles').select('receive_report').eq('id', uid).maybeSingle();
        if (!error && data && typeof data.receive_report === 'boolean') {
          reportReceiveCb.checked = data.receive_report;
        } else {
          reportReceiveCb.checked = true;
        }
      }

      if (reportLastSent) {
        const { data, error } = await sb
          .from('site_settings')
          .select('value_json')
          .eq('key', 'admin_weekly_report')
          .maybeSingle();
        if (error || !data?.value_json?.last_sent_at) {
          reportLastSent.textContent = '아직 없음';
        } else {
          reportLastSent.textContent = formatDate(data.value_json.last_sent_at);
        }
      }
    };

    const loadHistory = async (supabase) => {
      if (!historyList) return;
      const { data, error } = await supabase
        .from('audit_logs')
        .select('id, created_at, actor_id, after_json')
        .eq('action', 'settings_updated')
        .eq('resource_type', 'site_settings')
        .order('created_at', { ascending: false })
        .limit(6);

      if (error) {
        historyList.innerHTML = `<p class="admin-help admin-help-error">${escapeHtml(error.message)}</p>`;
        return;
      }

      if (!data?.length) {
        historyList.innerHTML = '<p class="admin-help">이력이 없습니다.</p>';
        return;
      }

      const shortDate = (value) => {
        if (!value) return '-';
        return new Intl.DateTimeFormat('ko-KR', {
          month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: false,
        }).format(new Date(value));
      };

      historyList.innerHTML = data.map((row) => {
        const snapshot = row.after_json?.snapshot || null;
        const keyCount = Array.isArray(row.after_json?.keys) ? row.after_json.keys.length : '?';
        const actor8 = (row.actor_id || '-').slice(0, 8);
        return `
          <div class="admin-change-row">
            <span class="admin-cell-subtle" title="${escapeHtml(row.actor_id || '')}">키 ${keyCount}개 · ${escapeHtml(actor8)}</span>
            <span class="admin-cell-date admin-cell-subtle">${shortDate(row.created_at)}</span>
            <a class="admin-btn admin-btn-sm" href="/admin/settings/detail?audit=${encodeURIComponent(row.id)}">상세</a>
            ${snapshot ? `<button type="button" class="admin-btn admin-btn-sm" data-settings-restore='${escapeHtml(JSON.stringify(snapshot))}'>복원</button>` : '<span></span>'}
          </div>
        `;
      }).join('');
    };

    const upsertSetting = async (supabase, key, valueJson, userId) => {
      return supabase.from('site_settings').upsert({
        key,
        value_json: valueJson,
        updated_by: userId,
      }, { onConflict: 'key' });
    };

    if (!supabaseUrl || !supabaseKey) {
      setMessage('Supabase 환경 변수가 없어 settings를 초기화할 수 없습니다.', 'error');
    } else {
      let currentUserId = null;
      document.addEventListener('admin:session-ready', ({ detail }) => {
        currentUserId = detail.userId;
      });

      let supabase = null;

      document.addEventListener('admin:session-ready', async () => {
        supabase = window.__adminSupabase;
        initFeaturedSlugPicker();
        const { data, error } = await supabase
          .from('site_settings')
          .select('key, value_json')
          .in('key', ['site_meta', 'homepage', 'about_page', 'social_links']);

        if (error) {
          setMessage(error.message, 'error');
        } else {
          const map = new Map((data ?? []).map((item) => [item.key, item.value_json || {}]));
          const siteMeta = map.get('site_meta') || {};
          const homepage = map.get('homepage') || {};
          const aboutPage = map.get('about_page') || {};
          const socialLinks = map.get('social_links') || {};

          form.elements.site_title.value = siteMeta.title || '';
          form.elements.site_description.value = siteMeta.description || '';
          form.elements.default_og_image.value = siteMeta.default_og_image || '';
          form.elements.featured_slug.value = homepage.featured_slug || '';
          form.elements.about_intro.value = aboutPage.intro || '';
          form.elements.social_links.value = JSON.stringify(socialLinks, null, 2);
          renderPreview();
          loadHistory(supabase);
        }

        await loadOperators(supabase);
        await loadNewsletterPanel(supabase);
        await loadWeeklyReportPanel(supabase);
        await loadDisclaimers(supabase);

        disclaimersRefreshBtn?.addEventListener('click', () => loadDisclaimers(supabase));
        disclaimersPanelList?.addEventListener('click', (e) => {
          const btn = e.target.closest('[data-disclaimer-save]');
          if (!btn || !supabase) return;
          const card = btn.closest('[data-disclaimer-id]');
          if (card instanceof HTMLElement) void saveDisclaimerRow(supabase, card);
        });

        reportReceiveCb?.addEventListener('change', async () => {
          if (getCurrentRole() !== 'owner') return;
          const uid = document.body.dataset.adminUserId;
          if (!supabase || !uid || !(reportReceiveCb instanceof HTMLInputElement)) return;
          const on = reportReceiveCb.checked;
          const { error } = await supabase.from('admin_profiles').update({ receive_report: on }).eq('id', uid);
          if (error) {
            setReportMessage(error.message, 'error');
            reportReceiveCb.checked = !on;
            return;
          }
          setReportMessage(on ? '리포트 수신을 켰습니다.' : '리포트 수신을 껐습니다.', 'success');
        });

        reportSendBtn?.addEventListener('click', async () => {
          if (!getCurrentRole()) {
            setReportMessage('관리자 권한이 확인된 뒤에 발송할 수 있습니다.', 'error');
            return;
          }
          if (!supabase) return;
          setReportMessage('리포트 발송 중…', 'info');
          if (reportSendBtn instanceof HTMLButtonElement) reportSendBtn.disabled = true;
          try {
            const {
              data: { session },
            } = await supabase.auth.getSession();
            if (!session?.access_token) {
              setReportMessage('세션이 없습니다. 다시 로그인해 주세요.', 'error');
              return;
            }
            const fnUrl = `${supabaseUrl.replace(/\/$/, '')}/functions/v1/admin-weekly-report`;
            const res = await fetch(fnUrl, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                Authorization: `Bearer ${session.access_token}`,
                apikey: supabaseKey,
              },
              body: '{}',
            });
            const payload = await res.json().catch(() => ({}));
            if (!res.ok) {
              setReportMessage(payload?.error || `발송 실패 (${res.status})`, 'error');
              return;
            }
            if (payload.skipped === 'no_recipients') {
              setReportMessage(String(payload.message || '수신자가 없습니다. owner·수신 설정을 확인하세요.'), 'info');
            } else {
              setReportMessage(`발송 완료: 수신 ${payload.sentTo ?? 0}명`, 'success');
            }
            await loadWeeklyReportPanel(supabase);
          } catch (e) {
            setReportMessage(e instanceof Error ? e.message : '요청 실패', 'error');
          } finally {
            if (reportSendBtn instanceof HTMLButtonElement) reportSendBtn.disabled = false;
          }
        });

        newsletterSendBtn?.addEventListener('click', async () => {
          if (!getCurrentRole()) {
            setNewsletterMessage('관리자 권한이 확인된 뒤에 발송할 수 있습니다.', 'error');
            return;
          }
          if (!supabase) return;
          setNewsletterMessage('발송 요청 중…', 'info');
          if (newsletterSendBtn instanceof HTMLButtonElement) newsletterSendBtn.disabled = true;
          try {
            const {
              data: { session },
            } = await supabase.auth.getSession();
            if (!session?.access_token) {
              setNewsletterMessage('세션이 없습니다. 다시 로그인해 주세요.', 'error');
              return;
            }
            const fnUrl = `${supabaseUrl.replace(/\/$/, '')}/functions/v1/weekly-newsletter`;
            const res = await fetch(fnUrl, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                Authorization: `Bearer ${session.access_token}`,
                apikey: supabaseKey,
              },
              body: '{}',
            });
            const payload = await res.json().catch(() => ({}));
            if (!res.ok) {
              setNewsletterMessage(payload?.error || `발송 실패 (${res.status})`, 'error');
              return;
            }
            if (payload.skipped === 'no_posts') {
              setNewsletterMessage('지난 7일간 발행된 글이 없어 메일을 보내지 않았습니다.', 'info');
            } else if (payload.skipped === 'no_subscribers') {
              setNewsletterMessage('구독자가 없어 메일을 보내지 않았습니다.', 'info');
            } else {
              setNewsletterMessage(
                `발송 완료: 수신자 약 ${payload.sent ?? 0}명, 글 ${payload.posts ?? 0}편`,
                'success',
              );
            }
            await loadNewsletterPanel(supabase);
          } catch (e) {
            setNewsletterMessage(e instanceof Error ? e.message : '요청 실패', 'error');
          } finally {
            if (newsletterSendBtn instanceof HTMLButtonElement) newsletterSendBtn.disabled = false;
          }
        });

        if (!operatorsUiBound && operatorsTbody) {
          operatorsUiBound = true;

          operatorsTbody.addEventListener('change', async (event) => {
            const sel = event.target.closest('[data-admin-op-role]');
            if (!sel || sel.disabled) return;
            const tr = sel.closest('[data-admin-op-row]');
            const id = tr?.dataset.opId;
            const sb = window.__adminSupabase;
            if (!id || !sb) return;

            const prev = operatorRows.find((r) => r.id === id);
            const nextRole = sel.value;
            if (!prev || prev.role === nextRole) return;

            if (prev.role === 'owner' && nextRole === 'editor' && countOwners() <= 1) {
              setOperatorsMessage('유일한 owner는 editor로 바꿀 수 없습니다.', 'error');
              sel.value = 'owner';
              return;
            }

            setOperatorsMessage('역할을 저장하는 중입니다…', 'info');
            const { error: upErr } = await sb.from('admin_profiles').update({ role: nextRole }).eq('id', id);
            if (upErr) {
              setOperatorsMessage(upErr.message, 'error');
              sel.value = prev.role;
              return;
            }

            prev.role = nextRole;
            setOperatorsMessage('역할을 반영했습니다.', 'success');
            renderOperatorsTable();
          });

          operatorsTbody.addEventListener('click', async (event) => {
            const btn = event.target.closest('[data-admin-op-delete]');
            if (!btn || btn.disabled) return;
            const tr = btn.closest('[data-admin-op-row]');
            const id = tr?.dataset.opId;
            const sb = window.__adminSupabase;
            if (!id || !sb) return;

            const prev = operatorRows.find((r) => r.id === id);
            if (!prev) return;
            if (prev.role === 'owner' && countOwners() <= 1) {
              setOperatorsMessage('유일한 owner 계정은 삭제할 수 없습니다.', 'error');
              return;
            }

            if (!confirm(`${prev.email} 운영자 프로필을 삭제할까요? (Auth 사용자는 Supabase 콘솔에서 별도 관리할 수 있습니다.)`)) {
              return;
            }

            setOperatorsMessage('삭제하는 중입니다…', 'info');
            const { error: delErr } = await sb.from('admin_profiles').delete().eq('id', id);
            if (delErr) {
              setOperatorsMessage(delErr.message, 'error');
              return;
            }

            operatorRows = operatorRows.filter((r) => r.id !== id);
            setOperatorsMessage('프로필을 삭제했습니다.', 'success');
            renderOperatorsTable();
          });
        }

        form?.addEventListener('input', () => {
          renderPreview();
        });

        historyList?.addEventListener('click', (event) => {
          const button = event.target.closest('[data-settings-restore]');
          if (!button) return;
          try {
            const snapshot = JSON.parse(button.dataset.settingsRestore || '{}');
            applySnapshotToForm(snapshot);
            setMessage('선택한 settings 스냅샷을 폼에 복원했습니다. 저장하면 현재 설정이 덮어써집니다.', 'info');
          } catch {
            setMessage('settings 스냅샷 복원에 실패했습니다.', 'error');
          }
        });

        form?.addEventListener('submit', async (event) => {
          event.preventDefault();
          if (getCurrentRole() !== 'owner') {
            setMessage('settings 저장은 owner 계정만 실행할 수 있습니다.', 'error');
            return;
          }
          setMessage('settings를 저장하는 중입니다...', 'info');

          const formData = new FormData(form);
          let socialLinks;
          try {
            socialLinks = normalizeSocialLinks(String(formData.get('social_links') || ''));
          } catch (error) {
            setMessage(error instanceof Error ? error.message : '소셜 링크 JSON 형식이 올바르지 않습니다.', 'error');
            return;
          }

          const defaultOgImage = String(formData.get('default_og_image') || '').trim();
          if (defaultOgImage && !isProbablyUrl(defaultOgImage)) {
            setMessage('기본 OG 이미지는 절대 URL 또는 `/path` 형식이어야 합니다.', 'error');
            return;
          }

          const tasks = [
            upsertSetting(supabase, 'site_meta', {
              title: String(formData.get('site_title') || '').trim(),
              description: String(formData.get('site_description') || '').trim(),
              default_og_image: String(formData.get('default_og_image') || '').trim(),
            }, currentUserId),
            upsertSetting(supabase, 'homepage', {
              featured_slug: String(formData.get('featured_slug') || '').trim(),
            }, currentUserId),
            upsertSetting(supabase, 'about_page', {
              intro: String(formData.get('about_intro') || '').trim(),
            }, currentUserId),
            upsertSetting(supabase, 'social_links', socialLinks, currentUserId),
          ];

          const results = await Promise.all(tasks);
          const failed = results.find((result) => result.error);
          if (failed?.error) {
            setMessage(failed.error.message, 'error');
            return;
          }

          await supabase.from('audit_logs').insert({
            actor_id: currentUserId,
            action: 'settings_updated',
            resource_type: 'site_settings',
            after_json: {
              keys: ['site_meta', 'homepage', 'about_page', 'social_links'],
              snapshot: {
                site_meta: {
                  title: String(formData.get('site_title') || '').trim(),
                  description: String(formData.get('site_description') || '').trim(),
                  default_og_image: String(formData.get('default_og_image') || '').trim(),
                },
                homepage: {
                  featured_slug: String(formData.get('featured_slug') || '').trim(),
                },
                about_page: {
                  intro: String(formData.get('about_intro') || '').trim(),
                },
                social_links: socialLinks,
              },
            },
          });

          setMessage('settings가 저장되었습니다.', 'success');
          loadHistory(supabase);
        });
      });
    }
  </script>
</AdminLayout>
