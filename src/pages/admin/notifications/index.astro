---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const TYPE_TABS: { value: string; label: string }[] = [
  { value: '', label: '전체' },
  { value: 'new_comment', label: '댓글' },
  { value: 'new_report', label: '신고' },
  { value: 'publish_failed', label: '발행 실패' },
  { value: 'publish_success', label: '발행 완료' },
  { value: 'new_subscriber', label: '구독' },
];
---

<AdminLayout
  title="알림 센터"
  pageTitle="알림 센터"
  pageDescription="운영 이벤트 알림을 확인하고 정리합니다. 읽음 처리는 헤더의 「모두 읽음」에서 일괄 적용됩니다."
  status="Live Ops"
>
  <div class="admin-grid">
  <section class="admin-card pad-lg span-12">
    <div class="admin-actions-row" style="margin-bottom: 1rem;">
      <div>
        <h2 class="admin-section-title" style="margin: 0;">알림 목록</h2>
        <p class="admin-section-desc" style="margin: 0.35rem 0 0;">
          페이지당 20건 · 30일 지난 알림은 아래 정리 기능으로 삭제할 수 있습니다.
        </p>
      </div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
        <button type="button" class="admin-btn admin-btn-sm" data-admin-notif-purge>
          30일 지난 알림 삭제
        </button>
        <button type="button" class="admin-btn admin-btn-sm" data-admin-notif-delete-all>
          전체 삭제
        </button>
      </div>
    </div>

    <p class="admin-inline-note" data-admin-notif-msg hidden></p>

    <ul class="admin-notif-type-tabs" data-admin-notif-tabs>
      {TYPE_TABS.map((t) => (
        <li>
          <a
            href={t.value ? `/admin/notifications?type=${encodeURIComponent(t.value)}` : '/admin/notifications'}
            data-notif-type={t.value || 'all'}
          >
            {t.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="admin-table-wrap" style="overflow-x: auto;">
      <table class="admin-table" style="width: 100%; border-collapse: collapse; font-size: 0.86rem;">
        <thead>
          <tr>
            <th style="text-align: left; padding: 0.5rem;">유형</th>
            <th style="text-align: left; padding: 0.5rem;">제목</th>
            <th style="text-align: left; padding: 0.5rem;">시간</th>
            <th style="text-align: left; padding: 0.5rem;">읽음</th>
            <th style="text-align: right; padding: 0.5rem;">작업</th>
          </tr>
        </thead>
        <tbody data-admin-notif-tbody>
          <tr>
            <td colspan="5" style="padding: 1rem;">로그인 후 목록을 불러옵니다.</td>
          </tr>
        </tbody>
      </table>
    </div>

    <div class="admin-notif-pagination" data-admin-notif-pagination hidden>
      <span data-admin-notif-page-info></span>
      <a class="admin-btn admin-btn-sm" data-admin-notif-prev href="#">이전</a>
      <a class="admin-btn admin-btn-sm" data-admin-notif-next href="#">다음</a>
    </div>
  </section>
  </div>

  <script>
    import type { SupabaseClient } from '@supabase/supabase-js';

    const PAGE_SIZE = 20;
    const TYPE_ICON: Record<string, string> = {
      new_comment: '💬',
      new_report: '⚠️',
      publish_failed: '❌',
      new_subscriber: '📧',
      publish_success: '✅',
    };

    const escapeHtml = (value: string) =>
      String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const formatDate = (value: string | null) => {
      if (!value) return '—';
      return new Intl.DateTimeFormat('ko-KR', {
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
      }).format(new Date(value));
    };

    const tbody = document.querySelector('[data-admin-notif-tbody]');
    const msg = document.querySelector('[data-admin-notif-msg]');
    const pagWrap = document.querySelector('[data-admin-notif-pagination]');
    const pageInfo = document.querySelector('[data-admin-notif-page-info]');
    const prevLink = document.querySelector('[data-admin-notif-prev]') as HTMLAnchorElement | null;
    const nextLink = document.querySelector('[data-admin-notif-next]') as HTMLAnchorElement | null;
    const purgeBtn = document.querySelector('[data-admin-notif-purge]');
    const deleteAllBtn = document.querySelector('[data-admin-notif-delete-all]');

    const readState = () => {
      const params = new URLSearchParams(window.location.search);
      const type = params.get('type')?.trim() || '';
      const page = Math.max(1, parseInt(params.get('page') || '1', 10) || 1);
      return { type, page };
    };

    const syncTabsActive = () => {
      const { type } = readState();
      document.querySelectorAll('[data-admin-notif-tabs] a').forEach((a) => {
        const el = a as HTMLAnchorElement;
        const v = el.dataset.notifType;
        const active = (v === 'all' && !type) || v === type;
        el.classList.toggle('is-active', Boolean(active));
      });
    };

    const setMsg = (text: string, kind: 'error' | 'info' | '') => {
      if (!msg) return;
      if (!text) {
        msg.hidden = true;
        msg.textContent = '';
        msg.removeAttribute('data-state');
        return;
      }
      msg.hidden = false;
      msg.textContent = text;
      if (kind) msg.dataset.state = kind;
      else msg.removeAttribute('data-state');
    };

    type NotifRow = {
      id: string;
      type: string;
      title: string;
      body: string | null;
      resource_slug: string | null;
      is_read: boolean;
      created_at: string;
    };

    const renderRows = (rows: NotifRow[]) => {
      if (!tbody) return;
      if (!rows.length) {
        tbody.innerHTML =
          '<tr><td colspan="5" style="padding:1rem;">표시할 알림이 없습니다.</td></tr>';
        return;
      }
      tbody.innerHTML = rows
        .map((r) => {
          const icon = TYPE_ICON[r.type] ?? '📌';
          const slug = r.resource_slug?.trim();
          const titleCell = slug
            ? `<a class="admin-table-link" href="/admin/posts/edit?slug=${encodeURIComponent(slug)}">${escapeHtml(r.title)}</a>`
            : escapeHtml(r.title);
          return `<tr data-notif-id="${escapeHtml(r.id)}">
            <td style="padding:0.5rem;">${icon} <code style="font-size:0.75rem;">${escapeHtml(r.type)}</code></td>
            <td style="padding:0.5rem;">${titleCell}</td>
            <td style="padding:0.5rem;">${escapeHtml(formatDate(r.created_at))}</td>
            <td style="padding:0.5rem;">${r.is_read ? '읽음' : '미읽음'}</td>
            <td style="padding:0.5rem;text-align:right;">
              <button type="button" class="admin-btn admin-btn-sm" data-admin-notif-delete="${escapeHtml(r.id)}">삭제</button>
            </td>
          </tr>`;
        })
        .join('');
    };

    const loadPage = async (supabase: SupabaseClient) => {
      const { type, page } = readState();
      syncTabsActive();
      setMsg('', '');

      let q = supabase
        .from('admin_notifications')
        .select('id,type,title,body,resource_slug,is_read,created_at', { count: 'exact' })
        .order('created_at', { ascending: false });
      if (type) q = q.eq('type', type);
      const from = (page - 1) * PAGE_SIZE;
      const to = from + PAGE_SIZE - 1;
      const { data, error, count } = await q.range(from, to);

      if (error) {
        setMsg(`목록을 불러오지 못했습니다: ${error.message}`, 'error');
        renderRows([]);
        if (pagWrap) pagWrap.hidden = true;
        return;
      }

      renderRows((data ?? []) as NotifRow[]);
      const total = count ?? 0;
      const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
      if (pagWrap && pageInfo && prevLink && nextLink) {
        pagWrap.hidden = total === 0;
        pageInfo.textContent = `${page} / ${totalPages} 페이지 · 총 ${total}건`;
        const base = type ? `/admin/notifications?type=${encodeURIComponent(type)}&` : `/admin/notifications?`;
        prevLink.hidden = page <= 1;
        nextLink.hidden = page >= totalPages;
        prevLink.href = `${base}page=${page - 1}`;
        nextLink.href = `${base}page=${page + 1}`;
      }
    };

    document.addEventListener('admin:session-ready', async () => {
      const supabase = (window as Window & { __adminSupabase?: SupabaseClient }).__adminSupabase;
      if (!supabase) return;
      await loadPage(supabase);

      tbody?.addEventListener('click', async (e) => {
        const t = (e.target as HTMLElement).closest('[data-admin-notif-delete]');
        if (!t || !supabase) return;
        const id = t.getAttribute('data-admin-notif-delete');
        if (!id || !confirm('이 알림을 삭제할까요?')) return;
        const { error } = await supabase.from('admin_notifications').delete().eq('id', id);
        if (error) {
          setMsg(error.message, 'error');
          return;
        }
        await loadPage(supabase);
      });

      purgeBtn?.addEventListener('click', async () => {
        if (!supabase) return;
        if (!confirm('30일이 지난 알림을 모두 삭제할까요?')) return;
        const { data, error } = await supabase.rpc('purge_old_admin_notifications');
        if (error) {
          setMsg(`정리 실패: ${error.message} (DB에 purge_old_admin_notifications 함수·마이그레이션 적용 여부 확인)`, 'error');
          return;
        }
        setMsg(`삭제된 행 수: ${data ?? 0}`, 'info');
        await loadPage(supabase);
      });

      deleteAllBtn?.addEventListener('click', async () => {
        if (!supabase) return;
        if (!confirm('모든 알림을 삭제할까요? 이 작업은 되돌릴 수 없습니다.')) return;
        const { error } = await supabase
          .from('admin_notifications')
          .delete()
          .gte('created_at', '1970-01-01T00:00:00Z');
        if (error) {
          setMsg(error.message, 'error');
          return;
        }
        window.history.replaceState({}, '', '/admin/notifications');
        await loadPage(supabase);
      });
    });
  </script>
</AdminLayout>
