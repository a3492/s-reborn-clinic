---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getCollection } from 'astro:content';

const localDrafts = await getCollection('blog', ({ data }) => data.draft === true);
const draftPreviews = localDrafts.map(post => {
  const words = (post.body ?? '')
    .replace(/^#+\s+/gm, '')
    .replace(/[*_`\[\]()#>~\-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()
    .split(' ')
    .filter(Boolean)
    .slice(0, 3)
    .join(' ');
  return { title: post.data.title, slug: post.id, preview: words };
});
---

<AdminLayout
  title="Dashboard"
  pageTitle="Dashboard"
  pageDescription="에스리본 클리닉 관리자 패널의 핵심 상태를 빠르게 확인합니다."
  status="Live Ops"
>
  <div class="admin-grid">
    <section class="admin-card pad-lg span-12">
      <h2 class="admin-section-title">사이트 현황</h2>
      <p class="admin-section-desc">
        Supabase 기준 실시간에 가까운 집계입니다. 숫자는 로그인 후 불러옵니다.
        <a href="/admin/calendar/" class="admin-table-link" style="margin-left: 0.35rem;">발행 캘린더</a>
      </p>
    </section>

    <section class="admin-card pad-lg span-4 admin-stat-card">
      <div class="admin-stat-card-inner">
        <span class="admin-stat-icon" aria-hidden="true">📚</span>
        <div class="admin-stat-body">
          <strong class="admin-kpi-value" data-admin-stat-published-total>—</strong>
          <span class="admin-kpi-label">전체 발행 글</span>
        </div>
      </div>
    </section>

    <section class="admin-card pad-lg span-4 admin-stat-card">
      <div class="admin-stat-card-inner">
        <span class="admin-stat-icon" aria-hidden="true">📅</span>
        <div class="admin-stat-body">
          <strong class="admin-kpi-value" data-admin-stat-published-month>—</strong>
          <span class="admin-kpi-label">이번 달 발행</span>
        </div>
      </div>
    </section>

    <section class="admin-card pad-lg span-4 admin-stat-card">
      <div class="admin-stat-card-inner">
        <span class="admin-stat-icon" aria-hidden="true">✏️</span>
        <div class="admin-stat-body">
          <strong class="admin-kpi-value" data-admin-stat-drafts>—</strong>
          <span class="admin-kpi-label">초안(draft)</span>
        </div>
      </div>
    </section>

    <section class="admin-card pad-lg span-4 admin-stat-card">
      <div class="admin-stat-card-inner">
        <span class="admin-stat-icon" aria-hidden="true">👁</span>
        <div class="admin-stat-body">
          <strong class="admin-kpi-value" data-admin-stat-views-today>—</strong>
          <span class="admin-kpi-label">누적 조회(합계)</span>
        </div>
      </div>
    </section>

    <section class="admin-card pad-lg span-4 admin-stat-card">
      <div class="admin-stat-card-inner">
        <span class="admin-stat-icon" aria-hidden="true">💬</span>
        <div class="admin-stat-body">
          <strong class="admin-kpi-value" data-admin-stat-reactions>—</strong>
          <span class="admin-kpi-label">전체 반응 수</span>
        </div>
      </div>
    </section>

    <section class="admin-card pad-lg span-4 admin-stat-card">
      <div class="admin-stat-card-inner">
        <span class="admin-stat-icon" aria-hidden="true">⏳</span>
        <div class="admin-stat-body">
          <strong class="admin-kpi-value" data-admin-stat-jobs>—</strong>
          <span class="admin-kpi-label">대기·처리 중 배포</span>
        </div>
      </div>
    </section>

    <section class="admin-card pad-lg span-4 admin-stat-card">
      <div class="admin-stat-card-inner">
        <span class="admin-stat-icon" aria-hidden="true">📆</span>
        <div class="admin-stat-body">
          <strong class="admin-kpi-value" data-admin-stat-week-scheduled>—</strong>
          <span class="admin-kpi-label">이번 주 예정</span>
        </div>
      </div>
      <p class="admin-help" style="margin: 0.65rem 0 0; font-size: 0.78rem;">
        <code>scheduled_at</code>이 이번 주(월~일)에 있고 아직 발행 전인 글
      </p>
    </section>

    <section class="admin-card pad-lg span-4 admin-stat-card">
      <a href="/admin/posts/?filter=needs_review" class="admin-stat-card-inner" style="text-decoration: none; color: inherit; display: block;">
        <span class="admin-stat-icon" aria-hidden="true">🔄</span>
        <div class="admin-stat-body">
          <strong class="admin-kpi-value" data-admin-stat-needs-review>—</strong>
          <span class="admin-kpi-label">검토 필요</span>
        </div>
      </a>
      <p class="admin-help" style="margin: 0.65rem 0 0; font-size: 0.78rem;">
        의료 정보 주기 검토로 표시된 글 수 · 클릭 시 해당 목록으로 이동
      </p>
    </section>

    <section class="admin-card pad-lg span-12">
      <h2 class="admin-section-title">최근 발행 글</h2>
      <p class="admin-section-desc">published 상태 기준 최신 5건 · 편집으로 이동합니다.</p>
      <ul class="admin-list" data-admin-recent-published>
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">—</p>
            <p class="admin-item-meta">불러오는 중…</p>
          </div>
        </li>
      </ul>
    </section>

    {draftPreviews.length > 0 && (
      <section class="admin-card pad-lg span-12">
        <h2 class="admin-section-title">Local Draft Files</h2>
        <p class="admin-section-desc">로컬 마크다운에만 있고 아직 Supabase에 미등록된 비공개 글</p>
        <ul class="admin-list">
          {draftPreviews.map(p => (
            <li class="admin-list-row">
              <div>
                <p class="admin-item-title">{p.title}</p>
                <p class="admin-item-meta">{p.slug} · {p.preview} ...</p>
              </div>
              <span class="admin-status draft">local draft</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="admin-card pad-lg span-7">
      <div class="admin-actions-row">
        <div>
          <h2 class="admin-section-title">Recent Drafts</h2>
          <p class="admin-section-desc">Supabase에 저장된 draft · 최근 수정 순</p>
        </div>
        <span class="admin-live-badge" data-admin-dashboard-live>Auto refresh</span>
      </div>
      <p class="admin-inline-note" data-admin-dashboard-message hidden></p>
      <ul class="admin-list" data-admin-dashboard-drafts>
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">불러오는 중...</p>
            <p class="admin-item-meta">Supabase에서 최근 글을 가져옵니다.</p>
          </div>
        </li>
      </ul>
    </section>

    <section class="admin-card pad-lg span-5">
      <h2 class="admin-section-title">최근 상담 신청</h2>
      <p class="admin-section-desc">
        최근 접수 5건 · 대기 <strong data-admin-kpi-consults>—</strong>건
      </p>
      <ul class="admin-list" data-admin-dashboard-consults>
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">불러오는 중...</p>
          </div>
        </li>
      </ul>
      <div style="margin-top:1rem;">
        <a href="/admin/consults" class="admin-btn">상담 관리 보기</a>
      </div>
    </section>

    <section class="admin-card pad-lg span-12" data-admin-vitals>
      <h2 class="admin-section-title">Core Web Vitals</h2>
      <p class="admin-section-desc">
        최근 7일 샘플 집계 · 공개 페이지 방문자 브라우저에서 수집됩니다. LCP 기준 좋음 &lt; 2.5s, CLS &lt; 0.1, FCP &lt; 1.8s.
      </p>
      <p class="admin-inline-note" data-admin-vitals-message hidden></p>
      <div class="admin-vitals-body" data-admin-vitals-body>
        <p class="admin-item-meta">로그인 후 불러옵니다…</p>
      </div>
    </section>
  </div>

  <script>
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

    const statPublishedTotal = document.querySelector('[data-admin-stat-published-total]');
    const statPublishedMonth = document.querySelector('[data-admin-stat-published-month]');
    const statDrafts = document.querySelector('[data-admin-stat-drafts]');
    const statViewsToday = document.querySelector('[data-admin-stat-views-today]');
    const statReactions = document.querySelector('[data-admin-stat-reactions]');
    const statJobs = document.querySelector('[data-admin-stat-jobs]');
    const statWeekScheduled = document.querySelector('[data-admin-stat-week-scheduled]');
    const statNeedsReview = document.querySelector('[data-admin-stat-needs-review]');
    const recentPublishedList = document.querySelector('[data-admin-recent-published]');
    const consultsKpi = document.querySelector('[data-admin-kpi-consults]');
    const draftList = document.querySelector('[data-admin-dashboard-drafts]');
    const consultList = document.querySelector('[data-admin-dashboard-consults]');
    const message = document.querySelector('[data-admin-dashboard-message]');
    let refreshTimer = null;

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');

    const formatDate = (value) => {
      if (!value) return '—';
      return new Intl.DateTimeFormat('ko-KR', {
        year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit'
      }).format(new Date(value));
    };

    const setStat = (el, value) => {
      if (!el) return;
      el.textContent = value === null || value === undefined ? '—' : String(value);
    };

    const startOfLocalMonthIso = () => {
      const d = new Date();
      const start = new Date(d.getFullYear(), d.getMonth(), 1, 0, 0, 0, 0);
      return start.toISOString();
    };

    /** 이번 주 월요일 00:00 로컬 → ISO */
    const startOfWeekMonday = (d) => {
      const x = new Date(d.getFullYear(), d.getMonth(), d.getDate(), 0, 0, 0, 0);
      const day = x.getDay();
      const diff = day === 0 ? -6 : 1 - day;
      x.setDate(x.getDate() + diff);
      return x;
    };

    const endOfWeekMondayExclusive = (d) => {
      const s = startOfWeekMonday(d);
      const e = new Date(s);
      e.setDate(e.getDate() + 7);
      return e;
    };

    const renderDrafts = (rows) => {
      if (!draftList) return;
      if (!rows.length) {
        draftList.innerHTML = '<li class="admin-list-row"><div><p class="admin-item-title">저장된 draft가 없습니다.</p><p class="admin-item-meta">/admin/posts/new 에서 첫 글을 만들어 보세요.</p></div></li>';
        return;
      }
      draftList.innerHTML = rows.map((row) => `
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title"><a class="admin-table-link" href="/admin/posts/edit?slug=${encodeURIComponent(row.slug)}">${escapeHtml(row.title)}</a></p>
            <p class="admin-item-meta">${escapeHtml(row.slug)} · ${formatDate(row.updated_at)}</p>
          </div>
          <span class="admin-status ${escapeHtml(row.status)}">${escapeHtml(row.status)}</span>
        </li>
      `).join('');
    };

    const renderRecentPublished = (rows) => {
      if (!recentPublishedList) return;
      if (!rows.length) {
        recentPublishedList.innerHTML = '<li class="admin-list-row"><div><p class="admin-item-title">발행된 글이 없습니다.</p><p class="admin-item-meta">posts에서 status를 published로 바꾸면 여기에 표시됩니다.</p></div></li>';
        return;
      }
      recentPublishedList.innerHTML = rows.map((row) => `
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title"><a class="admin-table-link" href="/admin/posts/edit?slug=${encodeURIComponent(row.slug)}">${escapeHtml(row.title)}</a></p>
            <p class="admin-item-meta">${escapeHtml(row.slug)} · ${formatDate(row.published_at)}</p>
          </div>
          <a class="admin-btn admin-btn-sm" href="/admin/posts/edit?slug=${encodeURIComponent(row.slug)}">편집</a>
        </li>
      `).join('');
    };

    const renderConsults = (rows) => {
      if (!consultList) return;
      if (!rows.length) {
        consultList.innerHTML = '<li class="admin-list-row"><div><p class="admin-item-title">접수된 상담 요청이 없습니다.</p></div></li>';
        return;
      }
      consultList.innerHTML = rows.map((row) => `
        <li class="admin-list-row">
          <div>
            <p class="admin-item-title">${escapeHtml(row.name)} · ${escapeHtml(row.phone)}</p>
            <p class="admin-item-meta">${formatDate(row.created_at)}${row.interest ? ` · ${escapeHtml(row.interest)}` : ''}</p>
          </div>
          <span class="admin-status ${row.status === 'pending' ? 'warn' : 'ready'}">${escapeHtml(row.status)}</span>
        </li>
      `).join('');
    };

    const vitalsBody = document.querySelector('[data-admin-vitals-body]');
    const vitalsMessage = document.querySelector('[data-admin-vitals-message]');

    const fmtMs = (v) => (v === null || v === undefined || Number.isNaN(v) ? '—' : `${Math.round(v)}ms`);
    const fmtCls = (v) => (v === null || v === undefined || Number.isNaN(v) ? '—' : Number(v).toFixed(3));
    const fmtPct = (n) => `${Math.round(n * 10) / 10}%`;

    const avgForName = (rows, name) => {
      const vals = rows.filter((r) => r.name === name).map((r) => Number(r.value));
      if (!vals.length) return null;
      return vals.reduce((a, b) => a + b, 0) / vals.length;
    };

    const lcpSlowPagesTop5 = (rows) => {
      const lcp = rows.filter((r) => r.name === 'LCP');
      const byPage = new Map();
      for (const r of lcp) {
        const p = String(r.page || '/');
        if (!byPage.has(p)) byPage.set(p, []);
        byPage.get(p).push(Number(r.value));
      }
      return [...byPage.entries()]
        .map(([page, vals]) => ({
          page,
          avg: vals.reduce((a, b) => a + b, 0) / vals.length,
        }))
        .sort((a, b) => b.avg - a.avg)
        .slice(0, 5);
    };

    const ratingShares = (rows) => {
      const g = { good: 0, 'needs-improvement': 0, poor: 0 };
      for (const r of rows) {
        if (g[r.rating] !== undefined) g[r.rating]++;
      }
      const t = rows.length || 1;
      return {
        good: (g.good / t) * 100,
        mid: (g['needs-improvement'] / t) * 100,
        poor: (g.poor / t) * 100,
        total: rows.length,
      };
    };

    const renderWebVitals = (rows, errText) => {
      if (!vitalsBody) return;
      if (errText) {
        vitalsBody.innerHTML = `<p class="admin-item-meta">${escapeHtml(errText)}</p>`;
        return;
      }
      if (!rows.length) {
        vitalsBody.innerHTML =
          '<p class="admin-item-meta">최근 7일 Vitals 데이터가 없습니다. <code>supabase/web_vitals.sql</code> 적용 및 공개 페이지 트래픽을 확인하세요.</p>';
        return;
      }

      const lcpAvg = avgForName(rows, 'LCP');
      const clsAvg = avgForName(rows, 'CLS');
      const fcpAvg = avgForName(rows, 'FCP');
      const ttfbAvg = avgForName(rows, 'TTFB');
      const inpAvg = avgForName(rows, 'INP');
      const shares = ratingShares(rows);
      const slow = lcpSlowPagesTop5(rows);

      const lcpClass =
        lcpAvg === null ? '' : lcpAvg <= 2500 ? ' admin-vitals-metric--good' : lcpAvg <= 4000 ? ' admin-vitals-metric--mid' : ' admin-vitals-metric--poor';
      const clsClass =
        clsAvg === null ? '' : clsAvg <= 0.1 ? ' admin-vitals-metric--good' : clsAvg <= 0.25 ? ' admin-vitals-metric--mid' : ' admin-vitals-metric--poor';
      const fcpClass =
        fcpAvg === null ? '' : fcpAvg <= 1800 ? ' admin-vitals-metric--good' : fcpAvg <= 3000 ? ' admin-vitals-metric--mid' : ' admin-vitals-metric--poor';

      vitalsBody.innerHTML = `
        <div class="admin-vitals-grid">
          <div class="admin-vitals-metric">
            <span class="admin-vitals-metric-label">LCP 평균</span>
            <strong class="admin-vitals-metric-val${lcpClass}">${fmtMs(lcpAvg)}</strong>
            <span class="admin-vitals-metric-hint">페이지·리소스별 상이</span>
          </div>
          <div class="admin-vitals-metric">
            <span class="admin-vitals-metric-label">CLS 평균</span>
            <strong class="admin-vitals-metric-val${clsClass}">${fmtCls(clsAvg)}</strong>
          </div>
          <div class="admin-vitals-metric">
            <span class="admin-vitals-metric-label">FCP 평균</span>
            <strong class="admin-vitals-metric-val${fcpClass}">${fmtMs(fcpAvg)}</strong>
          </div>
          <div class="admin-vitals-metric">
            <span class="admin-vitals-metric-label">TTFB 평균</span>
            <strong class="admin-vitals-metric-val">${fmtMs(ttfbAvg)}</strong>
          </div>
          <div class="admin-vitals-metric">
            <span class="admin-vitals-metric-label">INP 평균</span>
            <strong class="admin-vitals-metric-val">${fmtMs(inpAvg)}</strong>
          </div>
        </div>
        <p class="admin-vitals-rating-title">샘플 기준 rating 비율 <span class="admin-vitals-n">(${shares.total}건)</span></p>
        <div class="admin-vitals-rating-bar" role="img" aria-label="good, needs improvement, poor 비율">
          <span class="admin-vitals-rating-seg" style="width:${shares.good}%;background:var(--admin-success)"></span>
          <span class="admin-vitals-rating-seg" style="width:${shares.mid}%;background:var(--admin-warn)"></span>
          <span class="admin-vitals-rating-seg" style="width:${shares.poor}%;background:var(--admin-danger)"></span>
        </div>
        <ul class="admin-vitals-legend">
          <li><span class="admin-vitals-dot" style="background:var(--admin-success)"></span> 좋음 ${fmtPct(shares.good)}</li>
          <li><span class="admin-vitals-dot" style="background:var(--admin-warn)"></span> 개선 필요 ${fmtPct(shares.mid)}</li>
          <li><span class="admin-vitals-dot" style="background:var(--admin-danger)"></span> 나쁨 ${fmtPct(shares.poor)}</li>
        </ul>
        <h3 class="admin-vitals-subtitle">LCP 느린 페이지 TOP 5 <span class="admin-item-meta">(경로별 평균)</span></h3>
        ${
          slow.length
            ? `<ul class="admin-list admin-vitals-slow-list">
                ${slow.map((s) => `
                  <li class="admin-list-row">
                    <div>
                      <p class="admin-item-title"><code>${escapeHtml(s.page)}</code></p>
                      <p class="admin-item-meta">평균 LCP ${fmtMs(s.avg)}</p>
                    </div>
                  </li>`).join('')}
              </ul>`
            : '<p class="admin-item-meta">LCP 샘플이 없습니다.</p>'
        }
      `;
    };

    const loadWebVitals = async (sb) => {
      if (!vitalsBody) return;
      const sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
      const { data, error } = await sb
        .from('web_vitals')
        .select('name, value, rating, page')
        .gte('created_at', sevenDaysAgo)
        .order('created_at', { ascending: false })
        .limit(8000);
      if (error) {
        if (vitalsMessage) {
          vitalsMessage.hidden = false;
          vitalsMessage.textContent = 'web_vitals 테이블을 읽지 못했습니다. SQL 마이그레이션·RLS를 확인하세요.';
          vitalsMessage.dataset.state = 'warn';
        }
        renderWebVitals([], error.message || '조회 실패');
        return;
      }
      if (vitalsMessage) {
        vitalsMessage.hidden = true;
        vitalsMessage.textContent = '';
        vitalsMessage.removeAttribute('data-state');
      }
      renderWebVitals(data ?? [], null);
    };

    if (!supabaseUrl || !supabaseKey) {
      if (message) {
        message.hidden = false;
        message.textContent = 'Supabase 환경 변수가 없어 대시보드를 불러올 수 없습니다.';
        message.dataset.state = 'error';
      }
      if (vitalsBody) {
        vitalsBody.innerHTML =
          '<p class="admin-item-meta">Supabase 환경 변수가 없어 Core Web Vitals 집계를 불러올 수 없습니다.</p>';
      }
      renderDrafts([]);
      renderConsults([]);
      renderRecentPublished([]);
    } else {
      let supabase = null;

      const loadDashboard = async (silent = false) => {
        const monthStart = startOfLocalMonthIso();
        const weekStartIso = startOfWeekMonday(new Date()).toISOString();
        const weekEndIso = endOfWeekMondayExclusive(new Date()).toISOString();

        const [
          pubTotalRes,
          pubMonthRes,
          draftRes,
          viewsRes,
          reactionsRes,
          jobsRes,
          weekScheduledRes,
          needsReviewRes,
          recentPubRes,
          draftsRes,
          consultsRes,
          consultPendingRes,
        ] = await Promise.all([
          supabase.from('posts').select('*', { count: 'exact', head: true }).eq('status', 'published'),
          supabase.from('posts').select('*', { count: 'exact', head: true }).eq('status', 'published').gte('published_at', monthStart),
          supabase.from('posts').select('*', { count: 'exact', head: true }).eq('status', 'draft'),
          supabase.from('post_views').select('view_count'),
          supabase.from('post_reactions').select('*', { count: 'exact', head: true }),
          supabase.from('publish_jobs').select('*', { count: 'exact', head: true }).in('status', ['pending', 'processing']),
          supabase
            .from('posts')
            .select('*', { count: 'exact', head: true })
            .not('scheduled_at', 'is', null)
            .gte('scheduled_at', weekStartIso)
            .lt('scheduled_at', weekEndIso)
            .in('status', ['draft', 'review', 'scheduled']),
          supabase.from('posts').select('*', { count: 'exact', head: true }).eq('needs_review', true),
          supabase.from('posts').select('slug, title, published_at').eq('status', 'published').order('published_at', { ascending: false, nullsFirst: false }).limit(5),
          supabase.from('posts').select('id, title, slug, status, updated_at').eq('status', 'draft').order('updated_at', { ascending: false }).limit(5),
          supabase.from('consult_requests').select('id, name, phone, interest, status, created_at').order('created_at', { ascending: false }).limit(5),
          supabase.from('consult_requests').select('*', { count: 'exact', head: true }).eq('status', 'pending'),
        ]);

        setStat(statPublishedTotal, pubTotalRes.error ? null : pubTotalRes.count ?? 0);
        setStat(statPublishedMonth, pubMonthRes.error ? null : pubMonthRes.count ?? 0);
        setStat(statDrafts, draftRes.error ? null : draftRes.count ?? 0);

        if (viewsRes.error) {
          setStat(statViewsToday, null);
        } else {
          const sumAll = (viewsRes.data ?? []).reduce((s, r) => s + Number(r.view_count ?? 0), 0);
          setStat(statViewsToday, sumAll);
        }

        setStat(statReactions, reactionsRes.error ? null : reactionsRes.count ?? 0);
        setStat(statJobs, jobsRes.error ? null : jobsRes.count ?? 0);
        setStat(statWeekScheduled, weekScheduledRes.error ? null : weekScheduledRes.count ?? 0);
        setStat(statNeedsReview, needsReviewRes.error ? null : needsReviewRes.count ?? 0);

        if (recentPubRes.error) {
          renderRecentPublished([]);
        } else {
          renderRecentPublished(recentPubRes.data ?? []);
        }

        if (draftsRes.error) {
          renderDrafts([]);
        } else {
          renderDrafts(draftsRes.data ?? []);
        }

        if (!consultsRes.error) {
          renderConsults(consultsRes.data ?? []);
        } else {
          renderConsults([]);
        }
        setStat(consultsKpi, consultPendingRes.error ? null : consultPendingRes.count ?? 0);

        if (!silent && message) {
          const errs = [pubTotalRes.error, pubMonthRes.error, draftRes.error, viewsRes.error, reactionsRes.error, jobsRes.error, weekScheduledRes.error, needsReviewRes.error, recentPubRes.error, draftsRes.error, consultsRes.error, consultPendingRes.error].filter(Boolean);
          if (errs.length) {
            message.hidden = false;
            message.textContent = '일부 지표를 불러오지 못했습니다. 테이블·RLS·마이그레이션을 확인하세요.';
            message.dataset.state = 'warn';
          } else {
            message.hidden = true;
            message.textContent = '';
            message.removeAttribute('data-state');
          }
        }
      };

      document.addEventListener('admin:session-ready', async () => {
        supabase = window.__adminSupabase;
        await loadDashboard();
        await loadWebVitals(supabase);
        refreshTimer = window.setInterval(() => {
          if (!document.hidden) loadDashboard(true);
        }, 30000);
      });
    }
  </script>

