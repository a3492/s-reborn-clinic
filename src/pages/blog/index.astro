---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SITE_TITLE } from '../../consts';
import { BLOG_PILLAR_NAV, blogPillarLabel } from '../../data/blog-nav';
import { isAcademyBlogPost, postPermalink } from '../../lib/academy';
import { blogTagPageHref } from '../../lib/blog-tag-url';
import { seriesHubPath } from '../../lib/blog-series';
import ContentImage from '../../components/ContentImage.astro';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .filter((p) => !isAcademyBlogPost(p))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const pillarLabels = Object.fromEntries(BLOG_PILLAR_NAV.map((p) => [p.id, p.label]));
const categoryLabels = Object.fromEntries(CATEGORIES.map((c) => [c.id, c.label]));

const blogSearchFocus = Boolean((Astro.url.searchParams.get('q') ?? '').trim());
---

<Layout title="블로그" description="에스리본 클리닉 블로그 — 시술 안내, 건강 정보, 원장 칼럼">
  <div class:list={['blog-layout', { 'blog-layout--search': blogSearchFocus }]}>
    <Sidebar blogSearchFocus={blogSearchFocus} tagCloudPosts={allPosts} />

    <section class="blog-main" aria-labelledby="blog-page-title">
      <div class="blog-header">
        <h1 class="blog-header-title" id="blog-page-title">블로그</h1>

        <p id="blog-meta-search" class="blog-search-meta" hidden>
          <span class="blog-search-mode-label">키워드 검색 결과만 표시 중입니다.</span>
          총 <span id="blog-count-search">0</span>개 ·
          <a href="/blog/" class="js-blog-merge" data-blog-merge={JSON.stringify({ q: null })}>검색 지우기</a>
          <span class="blog-meta-sep"> · </span>
          <a href="/blog/">필터·검색 전체 초기화</a>
        </p>
        <p id="blog-meta-filter" class="blog-cat-meta" hidden>
          <span id="blog-meta-filter-chips"></span>
          <span id="blog-count-filter" class="blog-filter-count"></span>
          <a href="/blog/" class="blog-filter-reset">필터 초기화</a>
        </p>
      </div>

      {
        allPosts.length === 0 ? (
          <div class="blog-empty">
            <p>아직 공개된 글이 없습니다.</p>
          </div>
        ) : (
          <>
            <div id="blog-no-matches" class="blog-empty" hidden>
              <p>필터에 맞는 글이 없습니다.</p>
              <p id="blog-no-matches-hint" class="blog-empty-hint" hidden />
              <a href="/blog/" class="btn btn-outline btn-sm">
                전체 글 보기
              </a>
            </div>
            <div class="blog-grid" id="blog-grid">
              {allPosts.map((post) => (
                <article
                  class="blog-post-card"
                  data-blog-card
                  data-blog-slug={post.id}
                  data-category={post.data.category ?? ''}
                  data-pillar={post.data.pillar ?? ''}
                  data-title={post.data.title}
                  data-description={post.data.description ?? ''}
                  data-tags={(post.data.tags ?? []).join(' ')}
                  data-series={post.data.series ?? ''}
                >
                  <a href={postPermalink(post)} class="blog-post-card-main">
                    {post.data.thumbnail && (
                      <div class="blog-post-card-thumb">
                        <ContentImage
                          src={post.data.thumbnail}
                          alt={post.data.title}
                          width={640}
                          height={360}
                          loading="lazy"
                          decoding="async"
                        />
                      </div>
                    )}
                    <div class="blog-post-card-body">
                      <div class="blog-post-card-badges">
                        {post.data.pillar && (
                          <span class="blog-post-card-pillar">{blogPillarLabel(post.data.pillar)}</span>
                        )}
                        {post.data.category && (
                          <span class="blog-post-card-cat">
                            {CATEGORIES.find((c) => c.id === post.data.category)?.label ?? post.data.category}
                          </span>
                        )}
                        {post.data.series && (
                          <a
                            href={seriesHubPath(post.data.series)}
                            class="blog-post-card-series-badge"
                            aria-label={`「${post.data.series}」 시리즈 글 목록으로 이동`}
                          >
                            시리즈
                          </a>
                        )}
                        <span class="blog-post-card-views" data-blog-card-views aria-label="조회수">—</span>
                      </div>
                      <h2 class="blog-post-card-title">{post.data.title}</h2>
                      <p class="blog-post-card-desc">{post.data.description}</p>
                    </div>
                  </a>
                  <div class="blog-post-card-footer">
                    <time class="blog-post-card-date" datetime={post.data.date.toISOString()}>
                      {
                        new Intl.DateTimeFormat('ko-KR', {
                          year: 'numeric',
                          month: 'short',
                          day: 'numeric',
                        }).format(post.data.date)
                      }
                    </time>
                    {post.data.tags &&
                      post.data.tags.slice(0, 4).map((tag) => (
                        <a href={blogTagPageHref(tag)} class="blog-post-card-tag">
                          #{tag}
                        </a>
                      ))}
                  </div>
                </article>
              ))}
            </div>
          </>
        )
      }
    </section>
  </div>
</Layout>

<script is:inline define:vars={{ pillarLabels, categoryLabels, siteTitle: SITE_TITLE }}>
  const PROCEDURES_CATS = ['procedures', 'faq', 'myth', 'before-after', 'patient-story'];
  const LIFESTYLE_CATS = ['health-tips', 'doctor-column', 'clinic-news'];
  const TRACK_LABELS = { procedures: '시술 정보', lifestyle: '건강·라이프' };

  function readBlogState() {
    const p = new URLSearchParams(location.search);
    return {
      category: p.get('category') || '',
      pillar: p.get('pillar') || '',
      q: p.get('q') || '',
      track: p.get('track') || '',
    };
  }

  function titleFor(state) {
    const pl = state.pillar ? pillarLabels[state.pillar] : '';
    const cl = state.category ? categoryLabels[state.category] : '';
    const qt = state.q.trim();
    if (qt) return `"${qt}" 검색 결과`;
    if (state.pillar && state.category && pl && cl) return `${pl} · ${cl}`;
    if (state.pillar && pl) return `${pl} — 심화·글 모음`;
    if (state.category && cl) return cl;
    if (state.track && TRACK_LABELS[state.track]) return TRACK_LABELS[state.track];
    return '블로그';
  }

  function mergeBlogHrefFromSearch(search, patch) {
    const p = new URLSearchParams(search);
    for (const [key, v] of Object.entries(patch)) {
      if (v === null || v === '') p.delete(key);
      else p.set(key, String(v));
    }
    const s = p.toString();
    return s ? `/blog/?${s}` : '/blog/';
  }

  function applyMergeLinks() {
    document.querySelectorAll('a.js-blog-merge[data-blog-merge]').forEach((a) => {
      let patch = {};
      try {
        patch = JSON.parse(a.getAttribute('data-blog-merge') || '{}');
      } catch (_) {}
      a.setAttribute('href', mergeBlogHrefFromSearch(location.search, patch));
    });
  }

  function setPillAndSidebarActive(state) {
    // Track tabs
    document.querySelectorAll('[data-blog-track]').forEach((el) => {
      const want = el.getAttribute('data-blog-track') ?? '';
      el.classList.toggle('is-active', want === (state.track || ''));
    });

    // Show/hide sidebar sections based on track
    document.querySelectorAll('[data-sidebar-track]').forEach((el) => {
      const sectionTrack = el.getAttribute('data-sidebar-track');
      const visible = !state.track || state.track === sectionTrack;
      if (visible) {
        el.removeAttribute('hidden');
        el.classList.add('is-mobile-open');
      } else {
        el.setAttribute('hidden', '');
        el.classList.remove('is-mobile-open');
      }
    });

    // Pillar links
    document.querySelectorAll('[data-blog-pillar]').forEach((el) => {
      const want = el.getAttribute('data-blog-pillar') ?? '';
      el.classList.toggle('is-active', want === (state.pillar || ''));
    });

    // Category links
    document.querySelectorAll('[data-blog-cat]').forEach((el) => {
      const want = el.getAttribute('data-blog-cat') ?? '';
      el.classList.toggle('is-active', want === (state.category || ''));
    });
  }

  function applyBlogFilters() {
    applyMergeLinks();

    const state = readBlogState();
    const ql = state.q.trim().toLowerCase();
    let n = 0;

    document.querySelectorAll('[data-blog-card]').forEach((el) => {
      let show = true;
      const dc = el.getAttribute('data-category') || '';
      const dp = el.getAttribute('data-pillar') || '';

      if (ql) {
        const t = (el.getAttribute('data-title') || '').toLowerCase();
        const d = (el.getAttribute('data-description') || '').toLowerCase();
        const tags = (el.getAttribute('data-tags') || '').toLowerCase();
        if (!t.includes(ql) && !d.includes(ql) && !tags.includes(ql)) show = false;
      } else {
        // Track filter
        if (state.track === 'procedures') {
          if (dc && !PROCEDURES_CATS.includes(dc)) show = false;
        } else if (state.track === 'lifestyle') {
          if (dc && !LIFESTYLE_CATS.includes(dc)) show = false;
        }
        // Category filter
        if (state.category && dc !== state.category) show = false;
        // Pillar filter — pillar 미지정 글은 어떤 영역 필터에서도 노출 유지
        if (state.pillar) {
          if (dp !== '' && dp !== state.pillar) show = false;
        }
      }
      el.classList.toggle('is-filter-hidden', !show);
      if (show) n++;
    });

    const pageTitle = titleFor(state);
    const titleEl = document.getElementById('blog-page-title');
    if (titleEl) titleEl.textContent = pageTitle;
    document.title = `${pageTitle} | ${siteTitle}`;

    const metaSearch = document.getElementById('blog-meta-search');
    const metaFilter = document.getElementById('blog-meta-filter');
    const countSearch = document.getElementById('blog-count-search');
    const chips = document.getElementById('blog-meta-filter-chips');
    const countFilter = document.getElementById('blog-count-filter');
    const noMatches = document.getElementById('blog-no-matches');
    const noHint = document.getElementById('blog-no-matches-hint');
    const grid = document.getElementById('blog-grid');

    const hasQ = !!state.q.trim();
    const hasPC = !!(state.pillar || state.category || state.track);

    if (metaSearch) {
      metaSearch.hidden = !hasQ;
      if (countSearch) countSearch.textContent = String(n);
    }
    if (metaFilter) {
      metaFilter.hidden = hasQ || !hasPC;
      if (chips && countFilter) {
        const parts = [];
        if (state.track && TRACK_LABELS[state.track]) {
          parts.push(`<span class="blog-filter-chip">${TRACK_LABELS[state.track]}</span>`);
        }
        if (state.pillar && pillarLabels[state.pillar]) {
          if (state.track) parts.push('<span class="blog-filter-sep">·</span>');
          parts.push(`<span class="blog-filter-chip">${pillarLabels[state.pillar]}</span>`);
        }
        if (state.category && categoryLabels[state.category]) {
          if (state.track || state.pillar) parts.push('<span class="blog-filter-sep">·</span>');
          parts.push(`<span class="blog-filter-chip">${categoryLabels[state.category]}</span>`);
        }
        chips.innerHTML = parts.join(' ');
        countFilter.textContent = `${n}개`;
      }
    }

    if (noMatches && grid) {
      const empty = n === 0;
      noMatches.hidden = !empty;
      grid.classList.toggle('is-grid-empty', empty);
      if (noHint) {
        if (empty && ql) {
          noHint.innerHTML = `이 검색어에 맞는 글이 없습니다. 다른 키워드를 써 보시거나 <a href="/blog/" class="js-blog-merge" data-blog-merge='${JSON.stringify({ q: null })}'>검색 지우기</a> 후 목록을 둘러보세요.`;
          noHint.hidden = false;
          applyMergeLinks();
        } else if (empty && state.pillar && pillarLabels[state.pillar]) {
          const id = state.pillar;
          noHint.innerHTML = `이 영역의 심화 글·FAQ는 순차적으로 올릴 예정입니다. <a href="/procedures/#${id}">${pillarLabels[state.pillar]} 시술 안내 보기</a>`;
          noHint.hidden = false;
        } else {
          noHint.innerHTML = '';
          noHint.hidden = true;
        }
      }
    }

    const side = document.getElementById('blog-sidebar');
    const layout = document.querySelector('.blog-layout');
    if (side) {
      side.hidden = hasQ;
      if (hasQ) side.setAttribute('aria-hidden', 'true');
      else side.removeAttribute('aria-hidden');
    }
    layout?.classList.toggle('blog-layout--search', hasQ);

    setPillAndSidebarActive(state);
  }

  applyBlogFilters();
  window.addEventListener('popstate', applyBlogFilters);
</script>

<style>
  .blog-layout {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
    padding: 1.5rem 0 3rem;
  }

  .blog-layout--search {
    gap: 0;
  }

  .blog-layout--search .blog-main {
    max-width: 920px;
    margin-inline: auto;
    width: 100%;
  }

  .blog-main {
    flex: 1;
    min-width: 0;
  }

  .blog-header {
    margin-bottom: 1.5rem;
  }

  .blog-header-title {
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 0 0 0.75rem;
  }

  .blog-search-meta,
  .blog-cat-meta {
    margin: 0;
    font-size: 0.88rem;
    color: var(--t3);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.6rem;
  }

  .blog-search-mode-label {
    flex: 1 0 100%;
    font-weight: 700;
    color: var(--text);
    font-size: 0.9rem;
    margin-bottom: 0.15rem;
  }

  .blog-meta-sep {
    color: var(--t3);
  }

  .blog-search-meta a,
  .blog-filter-reset {
    color: var(--accent-dark);
    font-weight: 700;
    text-decoration: none;
  }

  .blog-filter-chip {
    font-weight: 700;
    color: var(--text);
  }

  .blog-filter-sep {
    color: var(--t3);
  }

  .blog-filter-count {
    color: var(--t3);
  }

  .blog-empty {
    padding: 3rem 0;
    text-align: center;
    color: var(--t3);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .blog-empty[hidden],
  #blog-no-matches[hidden] {
    display: none !important;
    pointer-events: none !important;
  }

  .blog-empty-hint {
    margin: 0;
    max-width: 28rem;
    line-height: 1.6;
    font-size: 0.9rem;
  }

  .blog-empty-hint a {
    color: var(--accent-dark);
    font-weight: 700;
    text-decoration: none;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .blog-grid.is-grid-empty {
    display: none;
  }

  .blog-post-card.is-filter-hidden {
    display: none !important;
  }

  .blog-post-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--rule);
    border-radius: 18px;
    overflow: hidden;
    background: var(--surface);
    color: inherit;
    -webkit-tap-highlight-color: rgba(184, 138, 94, 0.15);
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }

  .blog-post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 24px rgba(28, 24, 20, 0.07);
  }

  .blog-post-card-main {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .blog-post-card-thumb {
    height: 180px;
    overflow: hidden;
    background: var(--bg2);
  }

  .blog-post-card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .blog-post-card:hover .blog-post-card-thumb img,
  .blog-post-card-main:hover .blog-post-card-thumb img {
    transform: scale(1.03);
  }

  .blog-post-card-body {
    padding: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
    min-height: 0;
  }

  .blog-post-card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
  }

  .blog-post-card-pillar {
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--text);
    background: var(--bg2);
    padding: 0.2rem 0.45rem;
    border-radius: 6px;
    border: 1px solid var(--rule);
  }

  .blog-post-card-cat {
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--accent-dark);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .blog-post-card-series-badge {
    font-size: 0.68rem;
    font-weight: 800;
    color: var(--text);
    background: rgba(184, 149, 106, 0.2);
    padding: 0.2rem 0.45rem;
    border-radius: 6px;
    border: 1px solid var(--rule);
    text-decoration: none;
  }

  .blog-post-card-series-badge:hover {
    border-color: var(--accent);
    color: var(--accent-dark);
  }

  .blog-post-card-views {
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--t2);
    background: rgba(184, 149, 106, 0.1);
    padding: 0.2rem 0.45rem;
    border-radius: 999px;
    border: 1px solid var(--rule);
    font-variant-numeric: tabular-nums;
    margin-left: auto;
  }

  .blog-post-card-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.4;
  }

  .blog-post-card-desc {
    margin: 0;
    font-size: 0.84rem;
    color: var(--t2);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .blog-post-card-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 1.1rem 1.1rem;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .blog-post-card-date {
    font-size: 0.76rem;
    color: var(--t3);
  }

  .blog-post-card-tag {
    font-size: 0.72rem;
    color: var(--t3);
    background: var(--bg2);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    border: 1px solid transparent;
  }

  .blog-post-card-tag:hover {
    color: var(--accent-dark);
    border-color: var(--rule);
  }

  @media (max-width: 900px) {
    .blog-layout {
      flex-direction: column;
      gap: 0.75rem;
    }

    .blog-layout--search .blog-main {
      max-width: 100%;
    }
  }
</style>

<script>
  import { createClient } from '@supabase/supabase-js';
  import { fetchViewCountsMap, formatViewCount } from '../../lib/blog-post-views';

  const url = import.meta.env.PUBLIC_SUPABASE_URL;
  const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  async function fillBlogGridViews() {
    if (!url || !key) return;
    const grid = document.getElementById('blog-grid');
    if (!grid) return;
    const cards = grid.querySelectorAll('[data-blog-slug]');
    const slugs = [...cards]
      .map((el) => (el instanceof HTMLElement ? el.dataset.blogSlug?.trim() : ''))
      .filter(Boolean);
    if (!slugs.length) return;
    const supabase = createClient(url, key);
    const map = await fetchViewCountsMap(supabase, slugs);
    cards.forEach((card) => {
      if (!(card instanceof HTMLElement)) return;
      const slug = card.dataset.blogSlug?.trim() ?? '';
      const badge = card.querySelector('[data-blog-card-views]');
      if (!slug || !badge) return;
      const n = map.get(slug) ?? 0;
      badge.textContent = `조회 ${formatViewCount(n)}`;
    });
  }

  fillBlogGridViews();
</script>
