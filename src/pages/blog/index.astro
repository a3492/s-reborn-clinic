---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../consts';

const category = Astro.url.searchParams.get('category') ?? '';
const q = Astro.url.searchParams.get('q') ?? '';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

let filteredPosts = allPosts;
if (category) {
  filteredPosts = filteredPosts.filter(p => p.data.category === category);
}
if (q) {
  const ql = q.toLowerCase();
  filteredPosts = filteredPosts.filter(p =>
    p.data.title.toLowerCase().includes(ql) ||
    p.data.description?.toLowerCase().includes(ql) ||
    (p.data.tags ?? []).some(t => t.toLowerCase().includes(ql))
  );
}

const currentCatLabel = CATEGORIES.find(c => c.id === category)?.label;
const pageTitle = q ? `"${q}" 검색 결과` : currentCatLabel ? currentCatLabel : '블로그';
---

<Layout title={pageTitle} description="에스리본 클리닉 블로그 — 시술 안내, 건강 정보, 원장 칼럼">
  <div class="blog-layout">
    <Sidebar />

    <div class="blog-main">
      <div class="blog-header">
        <h1 class="blog-header-title">{pageTitle}</h1>
        {q && (
          <p class="blog-search-meta">
            총 {filteredPosts.length}개의 결과 · <a href="/blog">검색 지우기</a>
          </p>
        )}
        {category && !q && (
          <p class="blog-cat-meta">
            {filteredPosts.length}개의 글
          </p>
        )}
      </div>

      {filteredPosts.length === 0 ? (
        <div class="blog-empty">
          <p>아직 작성된 글이 없거나 검색 결과가 없습니다.</p>
          {(q || category) && <a href="/blog" class="btn btn-outline btn-sm">전체 글 보기</a>}
        </div>
      ) : (
        <div class="blog-grid">
          {filteredPosts.map(post => (
            <a href={`/blog/${post.id}/`} class="blog-post-card">
              {post.data.thumbnail && (
                <div class="blog-post-card-thumb">
                  <img src={post.data.thumbnail} alt={post.data.title} loading="lazy" />
                </div>
              )}
              <div class="blog-post-card-body">
                {post.data.category && (
                  <span class="blog-post-card-cat">
                    {CATEGORIES.find(c => c.id === post.data.category)?.label ?? post.data.category}
                  </span>
                )}
                <h2 class="blog-post-card-title">{post.data.title}</h2>
                <p class="blog-post-card-desc">{post.data.description}</p>
                <div class="blog-post-card-footer">
                  <time class="blog-post-card-date" datetime={post.data.date.toISOString()}>
                    {new Intl.DateTimeFormat('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' }).format(post.data.date)}
                  </time>
                  {post.data.tags && post.data.tags.slice(0, 2).map(tag => (
                    <span class="blog-post-card-tag">#{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .blog-layout {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    padding: 1.5rem 0 3rem;
  }

  .blog-main {
    flex: 1;
    min-width: 0;
  }

  .blog-header {
    margin-bottom: 1.75rem;
  }

  .blog-header-title {
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 0 0 0.35rem;
  }

  .blog-search-meta,
  .blog-cat-meta {
    margin: 0;
    font-size: 0.88rem;
    color: var(--t3);
  }

  .blog-search-meta a {
    color: var(--accent-dark);
    font-weight: 700;
    text-decoration: none;
  }

  .blog-empty {
    padding: 3rem 0;
    text-align: center;
    color: var(--t3);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .blog-post-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--rule);
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none;
    background: var(--surface);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .blog-post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 24px rgba(28, 24, 20, 0.07);
  }

  .blog-post-card-thumb {
    height: 180px;
    overflow: hidden;
    background: var(--bg2);
  }

  .blog-post-card-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .blog-post-card:hover .blog-post-card-thumb img {
    transform: scale(1.03);
  }

  .blog-post-card-body {
    padding: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }

  .blog-post-card-cat {
    font-size: 0.74rem;
    font-weight: 700;
    color: var(--accent-dark);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .blog-post-card-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.4;
  }

  .blog-post-card-desc {
    margin: 0;
    font-size: 0.84rem;
    color: var(--t2);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .blog-post-card-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
    flex-wrap: wrap;
  }

  .blog-post-card-date {
    font-size: 0.76rem;
    color: var(--t3);
  }

  .blog-post-card-tag {
    font-size: 0.72rem;
    color: var(--t3);
    background: var(--bg2);
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
  }

  @media (max-width: 900px) {
    .blog-layout {
      flex-direction: column;
    }
  }
</style>
