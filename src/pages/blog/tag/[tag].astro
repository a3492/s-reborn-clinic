---
import Layout from '../../../layouts/Layout.astro';
import Sidebar from '../../../components/Sidebar.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../../consts';
import { BLOG_PILLAR_NAV, blogPillarLabel } from '../../../data/blog-nav';
import { isAcademyBlogPost, postPermalink } from '../../../lib/academy';
import { blogTagPageHref } from '../../../lib/blog-tag-url';

export async function getStaticPaths() {
	const internalTagRe = /^작성-\d{6,}/;
	const posts = (await getCollection('blog', ({ data }) => !data.draft)).filter((p) => !isAcademyBlogPost(p));
	const seen = new Set<string>();
	for (const p of posts) {
		for (const raw of p.data.tags ?? []) {
			const t = String(raw || '').trim();
			if (t && !internalTagRe.test(t)) seen.add(t);
		}
	}
	// Astro 링크 크롤러는 UTF-8 경로(예: /blog/tag/의사칼럼/)로 요청하므로
	// params는 인코딩하지 않은 태그 문자열과 일치시킨다.
	return [...seen].map((tag) => ({
		params: { tag },
	}));
}

const param = Astro.params.tag ?? '';
let decodedTag = '';
try {
	decodedTag = decodeURIComponent(param);
} catch {
	decodedTag = param;
}

const allClinic = (await getCollection('blog', ({ data }) => !data.draft))
	.filter((p) => !isAcademyBlogPost(p))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const matched = allClinic.filter((p) => (p.data.tags ?? []).some((t) => String(t).trim() === decodedTag));

const titleBase = decodedTag ? `#${decodedTag} 관련 글 ${matched.length}개` : '태그';
---

<Layout title={decodedTag ? `${decodedTag} 태그` : '태그'} description={`에스리본 클리닉 블로그 — ${decodedTag} 태그 글 모음`}>
	<div class="blog-layout">
		<Sidebar tagCloudPosts={allClinic} />

		<div class="blog-main">
			<div class="blog-header">
				<h1 class="blog-header-title">{titleBase}</h1>
				<p class="blog-tag-meta">
					<a href="/blog/" class="blog-tag-back">← 블로그 전체</a>
				</p>
			</div>

			{
				matched.length === 0 ? (
					<div class="blog-empty">
						<p>이 태그에 해당하는 글이 없습니다.</p>
						<a href="/blog/" class="btn btn-outline btn-sm">
							블로그로 돌아가기
						</a>
					</div>
				) : (
					<div class="blog-grid">
						{matched.map((post) => (
							<article class="blog-post-card">
								<a href={postPermalink(post)} class="blog-post-card-main">
									{post.data.thumbnail && (
										<div class="blog-post-card-thumb">
											<img src={post.data.thumbnail} alt={post.data.title} loading="lazy" />
										</div>
									)}
									<div class="blog-post-card-body">
										<div class="blog-post-card-badges">
											{post.data.pillar && (
												<span class="blog-post-card-pillar">{blogPillarLabel(post.data.pillar)}</span>
											)}
											{post.data.category && (
												<span class="blog-post-card-cat">
													{CATEGORIES.find((c) => c.id === post.data.category)?.label ?? post.data.category}
												</span>
											)}
										</div>
										<h2 class="blog-post-card-title">{post.data.title}</h2>
										<p class="blog-post-card-desc">{post.data.description}</p>
									</div>
								</a>
								<div class="blog-post-card-footer">
									<time class="blog-post-card-date" datetime={post.data.date.toISOString()}>
										{
											new Intl.DateTimeFormat('ko-KR', {
												year: 'numeric',
												month: 'short',
												day: 'numeric',
											}).format(post.data.date)
										}
									</time>
									{post.data.tags &&
										post.data.tags
											.filter((tag) => !/^작성-\d{6,}/.test(String(tag).trim()))
											.slice(0, 4)
											.map((tag) => (
												<a
													href={blogTagPageHref(tag)}
													class:list={[
														'blog-post-card-tag',
														String(tag).trim() === decodedTag && 'is-current-tag',
													]}
												>
													#{tag}
												</a>
											))}
								</div>
							</article>
						))}
					</div>
				)
			}
		</div>
	</div>
</Layout>

<style>
	.blog-layout {
		display: flex;
		gap: 2rem;
		align-items: flex-start;
		padding: 1.5rem 0 3rem;
	}

	.blog-main {
		flex: 1;
		min-width: 0;
	}

	.blog-header {
		margin-bottom: 1.5rem;
	}

	.blog-header-title {
		font-size: 1.6rem;
		font-weight: 800;
		letter-spacing: -0.02em;
		color: var(--text);
		margin: 0 0 0.5rem;
	}

	.blog-tag-meta {
		margin: 0;
		font-size: 0.88rem;
		color: var(--t3);
	}

	.blog-tag-meta a {
		color: var(--accent-dark);
		font-weight: 700;
		text-decoration: none;
	}

	.blog-tag-meta a:hover {
		text-decoration: underline;
	}

	.blog-tag-meta-sep {
		margin: 0 0.35rem;
	}

	.blog-empty {
		padding: 3rem 0;
		text-align: center;
		color: var(--t3);
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: center;
	}

	.blog-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
		gap: 1.25rem;
	}

	.blog-post-card {
		display: flex;
		flex-direction: column;
		border: 1px solid var(--rule);
		border-radius: 18px;
		overflow: hidden;
		background: var(--surface);
		color: inherit;
		transition:
			transform 0.2s,
			box-shadow 0.2s;
	}

	.blog-post-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 10px 24px rgba(28, 24, 20, 0.07);
	}

	.blog-post-card-main {
		display: flex;
		flex-direction: column;
		flex: 1;
		min-height: 0;
		text-decoration: none;
		color: inherit;
		cursor: pointer;
	}

	.blog-post-card-thumb {
		height: 180px;
		overflow: hidden;
		background: var(--bg2);
	}

	.blog-post-card-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s ease;
	}

	.blog-post-card:hover .blog-post-card-thumb img,
	.blog-post-card-main:hover .blog-post-card-thumb img {
		transform: scale(1.03);
	}

	.blog-post-card-body {
		padding: 1.1rem;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		flex: 1;
		min-height: 0;
	}

	.blog-post-card-badges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
		align-items: center;
	}

	.blog-post-card-pillar {
		font-size: 0.68rem;
		font-weight: 700;
		color: var(--text);
		background: var(--bg2);
		padding: 0.2rem 0.45rem;
		border-radius: 6px;
		border: 1px solid var(--rule);
	}

	.blog-post-card-cat {
		font-size: 0.74rem;
		font-weight: 700;
		color: var(--accent-dark);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.blog-post-card-title {
		margin: 0;
		font-size: 1rem;
		font-weight: 700;
		color: var(--text);
		line-height: 1.4;
	}

	.blog-post-card-desc {
		margin: 0;
		font-size: 0.84rem;
		color: var(--t2);
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		flex: 1;
	}

	.blog-post-card-footer {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0 1.1rem 1.1rem;
		flex-wrap: wrap;
		margin-top: auto;
	}

	.blog-post-card-date {
		font-size: 0.76rem;
		color: var(--t3);
	}

	.blog-post-card-tag {
		font-size: 0.72rem;
		color: var(--t3);
		background: var(--bg2);
		padding: 0.15rem 0.5rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
		border: 1px solid transparent;
	}

	.blog-post-card-tag:hover {
		color: var(--accent-dark);
		border-color: var(--rule);
	}

	.blog-post-card-tag.is-current-tag {
		background: rgba(184, 138, 94, 0.16);
		color: var(--accent-dark);
		border-color: var(--accent);
	}

	@media (max-width: 900px) {
		.blog-layout {
			flex-direction: column;
			gap: 0.75rem;
		}
	}
</style>
