---
import '../styles/design.css';
import '../styles/global.css';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import { CATEGORIES, SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string };

const { title, description, date, thumbnail, category, tags } = Astro.props;
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');

const pageUrl = Astro.url.href;
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(title);

const shareLinks = {
  twitter: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
  kakao: null,
};

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
---

<html lang="ko">
  <head>
    <BaseHead title={title} description={description} image={thumbnail} siteTitle={SITE_TITLE} />
  </head>

  <body class="blog-post-shell">
    <div class="site-wrap">
      <Header />

      <div class="site-main blog-with-sidebar" style="display:flex;gap:2rem;padding-top:1.5rem;">
        <Sidebar />

        <main class="blog-content blog-post-main" style="flex:1;min-width:0;">
          <article class="blog-post-article">
            {thumbnail && (
              <div class="blog-post-hero">
                <img src={thumbnail} alt={title} />
              </div>
            )}
            <div class="blog-post-prose prose">
              <div class="blog-post-title title">
                <div class="blog-post-meta meta">
                  {category && (
                    <span class="blog-post-category category-badge">
                      {CATEGORIES.find(c => c.id === category)?.label ?? category}
                    </span>
                  )}
                  {date && (
                    <time datetime={date.toISOString()}>
                      {new Intl.DateTimeFormat('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }).format(date)}
                    </time>
                  )}
                </div>
                <h1>{title}</h1>
                {tags && tags.length > 0 && (
                  <div class="blog-post-tags tags">
                    {tags.map((tag) => <span class="blog-post-tag tag">#{tag}</span>)}
                  </div>
                )}
                <hr />
              </div>
              <slot />

              <!-- 상담 CTA -->
              <div class="blog-post-consult-cta">
                <div class="consult-cta-inner">
                  <p class="consult-cta-text">이 시술에 관심이 있으신가요?</p>
                  <p class="consult-cta-sub">전문 의료진이 맞춤 상담을 도와드립니다.</p>
                  <a href="/consult" class="btn btn-primary">무료 온라인 상담 신청</a>
                </div>
              </div>

              <div class="blog-post-share-section share-section">
                <p>이 글이 도움이 됐다면 공유해 주세요.</p>
                <div class="blog-post-share-buttons share-buttons">
                  <a
                    href={shareLinks.twitter}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="blog-post-share-btn share-btn twitter"
                  >
                    𝕏 트위터
                  </a>
                  <button
                    id="copy-link-btn"
                    class="blog-post-share-btn share-btn copy"
                    type="button"
                  >
                    링크 복사
                  </button>
                </div>
                <p id="share-feedback" class="blog-post-share-feedback" aria-live="polite"></p>
              </div>
            </div>
          </article>
        </main>
      </div>

      <Footer />
    </div>

    <style>
      .blog-post-consult-cta {
        margin: 2rem 0;
        padding: 2rem;
        background: linear-gradient(135deg, var(--color-pink-light), var(--color-gold-light));
        border: 1px solid var(--color-pink);
        border-radius: 20px;
        text-align: center;
      }

      .consult-cta-text {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--text);
        margin: 0 0 0.5rem;
      }

      .consult-cta-sub {
        color: var(--t2);
        font-size: 0.95rem;
        margin: 0 0 1.25rem;
      }
    </style>

    <script define:vars={{ pageUrl }}>
      const copyButton = document.getElementById('copy-link-btn');
      const feedback = document.getElementById('share-feedback');

      copyButton?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(pageUrl);
          if (copyButton) {
            copyButton.textContent = '복사됨!';
            setTimeout(() => { copyButton.textContent = '링크 복사'; }, 2000);
          }
          if (feedback) feedback.textContent = '현재 글 링크를 클립보드에 복사했습니다.';
        } catch {
          if (feedback) feedback.textContent = '링크 복사에 실패했습니다.';
        }
      });
    </script>
  </body>
</html>
