---
import '../styles/design.css';
import '../styles/global.css';
import '../styles/blog-print.css';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import AnalyticsScripts from '../components/AnalyticsScripts.astro';
import Header from '../components/Header.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import TagCloud from '../components/TagCloud.astro';
import ContentImage from '../components/ContentImage.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
import BookmarkButton from '../components/BookmarkButton.astro';
import Poll from '../components/Poll.astro';
import WebVitalsCollector from '../components/WebVitalsCollector.astro';
import { CATEGORIES, SITE_TITLE } from '../consts';
import { ACADEMY_CONTENT_ID_PREFIX, ACADEMY_PUBLIC_PATH } from '../lib/academy-constants';
import { buildArticlePageGraph } from '../lib/structured-data';
import { isAcademyBlogPost, postPermalink } from '../lib/academy';
import { blogTagPageHref } from '../lib/blog-tag-url';
import { entryIsAcademyBlogId, sortSeriesPosts, seriesHubPath } from '../lib/blog-series';
import { getActiveDisclaimerBodyForCategory } from '../lib/disclaimers';
import type { BlogTocItem } from '../lib/blog-post-toc';

type Props = CollectionEntry<'blog'>['data'] & {
	slug?: string;
	/** URI 인코딩된 전체 MD(frontmatter+body) — article data-markdown 에만 사용 */
	encodedDownloadMarkdown?: string;
	/** 마크다운 본문 — 서버에서 읽기 시간·목차 계산용 */
	body?: string;
	tocItems?: BlogTocItem[];
};

const {
	title,
	description,
	date,
	thumbnail,
	category,
	tags,
	series: postSeries,
	encodedDownloadMarkdown = '',
	body: rawMarkdownBody = '',
	tocItems = [],
} = Astro.props;

const readingStrip = (rawMarkdownBody ?? '').replace(/[#*`>\-\[\]()]/g, '').trim();
const readingCharCount = readingStrip.replace(/\s+/g, '').length;
const readingTimeLabel =
	readingCharCount === 0 ? null : readingCharCount < 250 ? '1분 미만' : `읽기 약 ${Math.ceil(readingCharCount / 250)}분`;
const pathNorm = Astro.url.pathname.replace(/\/$/, '');
const slug = pathNorm.startsWith('/blog/')
	? pathNorm.slice('/blog/'.length)
	: pathNorm.startsWith(`${ACADEMY_PUBLIC_PATH}/`)
		? `${ACADEMY_CONTENT_ID_PREFIX}${pathNorm.slice(ACADEMY_PUBLIC_PATH.length + 1)}`
		: pathNorm.replace(/^\//, '');

const pageUrl = Astro.url.href;
const encodedUrl = encodeURIComponent(pageUrl);
const encodedTitle = encodeURIComponent(title);

const shareLinks = {
  twitter: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
  kakao: null,
};

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const clinicPostsForTagCloud = allPosts.filter((p) => !isAcademyBlogPost(p));

const seriesName = (postSeries ?? '').trim();
const onAcademyArticle = entryIsAcademyBlogId(slug);
const seriesSiblings = seriesName
	? allPosts
			.filter((p) => (p.data.series ?? '').trim() === seriesName)
			.filter((p) => (onAcademyArticle ? entryIsAcademyBlogId(p.id) : !entryIsAcademyBlogId(p.id)))
			.sort(sortSeriesPosts)
	: [];
const seriesIndex = seriesName ? seriesSiblings.findIndex((p) => p.id === slug) : -1;
const seriesPosition = seriesIndex >= 0 ? seriesIndex + 1 : 0;
const seriesTotal = seriesSiblings.length;
const seriesPrev = seriesIndex > 0 ? seriesSiblings[seriesIndex - 1] : null;
const seriesNext =
	seriesIndex >= 0 && seriesIndex < seriesSiblings.length - 1 ? seriesSiblings[seriesIndex + 1] : null;

/** pgvector 미적용·임베딩 없음 시 — 같은 카테고리 최신 3개 (클라이언트 폴백용) */
const relatedFallback = category
	? allPosts
			.filter((p) => p.id !== slug)
			.filter((p) => (onAcademyArticle ? isAcademyBlogPost(p) : !isAcademyBlogPost(p)))
			.filter((p) => p.data.category === category)
			.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
			.slice(0, 3)
			.map((p) => ({
				slug: p.id,
				href: postPermalink(p),
				title: p.data.title,
				description: p.data.description ?? '',
				category: p.data.category ?? null,
				published_at: p.data.date.toISOString(),
			}))
	: [];

const categoryLabelRecord = Object.fromEntries(CATEGORIES.map((c) => [c.id, c.label]));

const thumbTrim = thumbnail && String(thumbnail).trim();
const publicR2MediaBase = (import.meta.env.PUBLIC_R2_MEDIA_URL || '').trim().replace(/\/$/, '');
const thumbnailDisplaySrc = thumbTrim
	? publicR2MediaBase
		? (() => {
				const t = thumbTrim;
				const abs = t.startsWith('http') ? t : new URL(t, Astro.site ?? Astro.url).href;
				if (!abs.startsWith(publicR2MediaBase)) return t;
				const j = abs.includes('?') ? '&' : '?';
				return `${abs}${j}width=800&format=webp&quality=85`;
			})()
		: thumbTrim
	: '';
const absoluteThumbnail = thumbTrim
	? thumbTrim.startsWith('http')
		? thumbTrim
		: new URL(thumbTrim, Astro.url).href
	: null;
const ogImageForMeta =
	absoluteThumbnail ?? new URL(`/api/og/${encodeURIComponent(slug)}/`, Astro.site).href;

const articleJsonLd = buildArticlePageGraph(Astro.site, {
	title,
	description,
	url: pageUrl,
	datePublished: date,
	image: ogImageForMeta,
	category,
});

const disclaimerBody = await getActiveDisclaimerBodyForCategory(category);

---

<html lang="ko">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={ogImageForMeta}
      siteTitle={SITE_TITLE}
      ogType="article"
      jsonLd={articleJsonLd}
      rssCategoryId={category ?? null}
      rssCategoryLabel={category ? categoryLabelRecord[category] ?? category : null}
    />
    <!-- PWA: 아이콘은 public/icon-192.png, public/icon-512.png (manifest.json). -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1a1a2e" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <AnalyticsScripts contentId={slug} />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }

      /* 복사 시 출처 자동 추가 */
      document.addEventListener('copy', function (e) {
        var selection = window.getSelection();
        if (!selection || selection.toString().length === 0) return;
        var originalText = selection.toString();
        var attribution =
          '\n\n출처: 에스리본 클리닉\n' +
          'https://s-reborn-clinic.pages.dev/\n' +
          '무단 전재 및 재배포를 금지합니다.';
        if (e.clipboardData) {
          e.clipboardData.setData('text/plain', originalText + attribution);
          e.clipboardData.setData(
            'text/html',
            '<span>' +
              originalText.replace(/\n/g, '<br>') +
              '</span>' +
              '<p style="color:#888;font-size:0.85em;margin-top:8px;">' +
              '출처: <a href="https://s-reborn-clinic.pages.dev/">에스리본 클리닉</a><br>' +
              '무단 전재 및 재배포를 금지합니다.' +
              '</p>'
          );
          e.preventDefault();
        }
      });
    </script>
  </head>

  <body class="blog-post-shell">
    <div class="blog-reading-progress-track" data-reading-progress aria-hidden="true"></div>
    <div
      id="blog-reading-mode-exit"
      class="blog-reading-mode-exit-bar"
      role="button"
      tabindex="0"
      hidden
      aria-label="집중 모드 종료"
    >
      집중 모드 종료 [Esc]
    </div>
    <div class="site-wrap">
      <Header />
      <Topbar />

      <main class="site-main blog-with-sidebar" id="main-content">
        <Sidebar tagCloudPosts={clinicPostsForTagCloud} />

        <div class="blog-content blog-post-main">
          <article
            class="blog-post-article"
            data-download-slug={slug}
            {...(encodedDownloadMarkdown
              ? { 'data-markdown': encodedDownloadMarkdown }
              : {})}
          >
            <div
              id="blog-print-banner"
              class="blog-print-banner"
              aria-hidden="true"
              data-print-site={SITE_TITLE}
              data-print-url={pageUrl}
              data-print-date=""
            />
            {thumbnail && (
              <div class="blog-post-hero">
                <ContentImage src={thumbnailDisplaySrc} alt={title} width={960} height={540} loading="eager" decoding="async" fetchpriority="high" />
              </div>
            )}
            <div class="blog-post-prose prose">
              <div class="blog-post-title title">
                <div class="blog-post-meta meta">
                  {category && (
                    <span class="blog-post-category category-badge">
                      {CATEGORIES.find(c => c.id === category)?.label ?? category}
                    </span>
                  )}
                </div>
                <h1>{title}</h1>
                {(date || readingTimeLabel) && (
                  <div class="blog-post-submeta">
                    {date && (
                      <time datetime={date.toISOString()}>
                        {new Intl.DateTimeFormat('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }).format(date)}
                      </time>
                    )}
                    {date && readingTimeLabel && <span class="blog-post-submeta-sep" aria-hidden="true"> · </span>}
                    {readingTimeLabel && (
                      <span class="blog-post-reading-time">{readingTimeLabel}</span>
                    )}
                  </div>
                )}
                {disclaimerBody && (
                  <aside class="disclaimer" role="note" aria-label="의료 면책 고지">
                    <p>⚕️ {disclaimerBody}</p>
                  </aside>
                )}
                <p class="blog-post-view-line" id="blog-post-view-line" data-post-slug={slug}>
                  조회 <span data-post-view-num>—</span>회
                </p>
                {tags && tags.length > 0 && (
                  <div class="blog-post-tags tags">
                    {tags.map((tag) => (
                      <a class="blog-post-tag tag" href={blogTagPageHref(tag)}>
                        #{tag}
                      </a>
                    ))}
                  </div>
                )}
                <hr />
              </div>

              {seriesName && seriesTotal > 0 && (
                <nav
                  class="blog-post-series"
                  aria-label="시리즈 네비게이션"
                  data-blog-series-nav
                  data-series-current-slug={slug}
                >
                  <div class="blog-post-series-head">
                    <a href={seriesHubPath(seriesName)} class="blog-post-series-hub">
                      {seriesName}
                    </a>
                    <span class="blog-post-series-pos">
                      {seriesPosition} / {seriesTotal}편
                    </span>
                    <p class="blog-post-series-reread" data-series-reread-msg hidden>
                      이전에 읽었습니다
                    </p>
                  </div>
                  <div class="blog-post-series-nav">
                    {seriesPrev ? (
                      <a class="blog-post-series-btn" href={postPermalink(seriesPrev)} data-series-nav-prev={seriesPrev.id}>
                        ← 이전 편
                      </a>
                    ) : (
                      <span class="blog-post-series-btn is-disabled" aria-disabled="true">← 이전 편</span>
                    )}
                    {seriesNext ? (
                      <a
                        class="blog-post-series-btn"
                        href={postPermalink(seriesNext)}
                        data-series-nav-next={seriesNext.id}
                      >
                        다음 편 →
                      </a>
                    ) : (
                      <span class="blog-post-series-btn is-disabled" aria-disabled="true">다음 편 →</span>
                    )}
                  </div>
                  <p class="blog-post-series-next-hint" data-series-next-unread-hint hidden>
                    다음으로 읽을 편 ▶
                  </p>
                  <details class="blog-post-series-details">
                    <summary class="blog-post-series-summary">시리즈 전체 목록</summary>
                    <ol class="blog-post-series-list">
                      {seriesSiblings.map((p, i) => (
                        <li
                          class:list={{ 'is-current': p.id === slug }}
                          data-series-post-slug={p.id}
                        >
                          <a href={postPermalink(p)} class="blog-post-series-list-link">
                            <span class="blog-post-series-item-check" aria-hidden="true"></span>
                            <span class="blog-post-series-item-text">
                              {i + 1}. {p.data.title}
                            </span>
                          </a>
                        </li>
                      ))}
                    </ol>
                  </details>
                </nav>
              )}

              {tocItems.length >= 2 && (
                <nav class="blog-post-toc" aria-label="이 글 목차">
                  <p class="blog-post-toc-heading">목차</p>
                  <ul class="blog-post-toc-list">
                    {tocItems.map((item) => (
                      <li
                        class:list={[
                          'blog-post-toc-item',
                          item.depth === 3 ? 'blog-post-toc-item--depth-3' : 'blog-post-toc-item--depth-2',
                        ]}
                      >
                        <a href={`#${item.id}`} class="blog-post-toc-link" data-toc-link={item.id}>
                          {item.text}
                        </a>
                      </li>
                    ))}
                  </ul>
                </nav>
              )}

              <slot />

              <section
                class="blog-post-related"
                data-blog-related
                aria-labelledby="blog-post-related-heading"
                aria-busy="true"
              >
                <h2 class="blog-post-related-title" id="blog-post-related-heading">이 글과 비슷한 글</h2>
                <p class="blog-post-related-status" data-blog-related-status>불러오는 중…</p>
                <ul class="blog-post-related-list" data-blog-related-list hidden></ul>
              </section>

              <script
                type="application/json"
                id="blog-related-props"
                set:html={JSON.stringify({
                  slug,
                  categoryLabels: categoryLabelRecord,
                  fallback: relatedFallback,
                })}
              />

              <section
                class="blog-post-comments"
                id="blog-post-comments"
                data-blog-comments
                data-post-slug={slug}
                aria-labelledby="blog-post-comments-heading"
                hidden
              >
                <h2 class="blog-post-comments-heading" id="blog-post-comments-heading">
                  댓글 <span data-comments-count>0</span>개
                </h2>
                <ul class="blog-post-comments-list" data-comments-list></ul>
                <p class="blog-post-comments-form-msg" data-comments-form-msg hidden></p>
                <form class="blog-post-comments-form" data-comments-form>
                  <input type="hidden" name="parent_id" value="" data-comments-parent-id />
                  <p class="blog-post-comments-reply-hint" data-comments-reply-hint hidden>
                    답글 작성 중
                    <button type="button" class="blog-post-comments-cancel-reply" data-comments-cancel-reply>
                      취소
                    </button>
                  </p>
                  <label class="blog-post-comments-field">
                    <span class="blog-post-comments-label">이름 <span aria-hidden="true">*</span></span>
                    <input
                      class="blog-post-comments-input"
                      name="author_name"
                      type="text"
                      required
                      maxlength="50"
                      autocomplete="name"
                      placeholder="닉네임 또는 이름"
                    />
                  </label>
                  <label class="blog-post-comments-field">
                    <span class="blog-post-comments-label">이메일 (선택)</span>
                    <input
                      class="blog-post-comments-input"
                      name="author_email"
                      type="email"
                      maxlength="320"
                      autocomplete="email"
                      placeholder="비공개"
                    />
                  </label>
                  <label class="blog-post-comments-field">
                    <span class="blog-post-comments-label">내용 <span aria-hidden="true">*</span></span>
                    <textarea
                      class="blog-post-comments-textarea"
                      name="body"
                      required
                      maxlength="500"
                      rows="4"
                      placeholder="최대 500자"
                      data-comments-body
                    ></textarea>
                    <span class="blog-post-comments-char" data-comments-char>0 / 500</span>
                  </label>
                  <button type="submit" class="blog-post-comments-submit">댓글 등록</button>
                </form>
              </section>

              {tags && tags.length > 0 && (
                <div class="blog-post-tag-cloud-wrap">
                  <TagCloud variant="post" tags={tags} title="이 글의 태그" />
                </div>
              )}

              <Poll slug={slug} />

              <div class="blog-post-reactions" id="blog-post-reactions" data-post-slug={slug}>
                <p class="blog-post-reactions-intro">이 글은 어떠셨나요?</p>
                <div class="blog-post-reaction-buttons" role="group" aria-label="독자 반응">
                  <button type="button" class="blog-post-reaction-btn" data-reaction="helpful" aria-pressed="false">
                    <span class="blog-post-reaction-emoji" aria-hidden="true">👍</span>
                    <span class="blog-post-reaction-label">도움돼요</span>
                    <span class="blog-post-reaction-count" data-reaction-count>0</span>
                  </button>
                  <button type="button" class="blog-post-reaction-btn" data-reaction="like" aria-pressed="false">
                    <span class="blog-post-reaction-emoji" aria-hidden="true">✅</span>
                    <span class="blog-post-reaction-label">유용해요</span>
                    <span class="blog-post-reaction-count" data-reaction-count>0</span>
                  </button>
                  <button type="button" class="blog-post-reaction-btn" data-reaction="bookmark" aria-pressed="false">
                    <span class="blog-post-reaction-emoji" aria-hidden="true">🔖</span>
                    <span class="blog-post-reaction-label">저장할게요</span>
                    <span class="blog-post-reaction-count" data-reaction-count>0</span>
                  </button>
                </div>
              </div>

              <div class="blog-post-share-section share-section">
                <p>이 글이 도움이 됐다면 공유해 주세요.</p>
                <div class="blog-post-share-buttons share-buttons">
                  <a
                    href={shareLinks.twitter}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="blog-post-share-btn share-btn twitter"
                  >
                    𝕏 트위터
                  </a>
                  <button
                    id="copy-link-btn"
                    class="blog-post-share-btn share-btn copy"
                    type="button"
                  >
                    링크 복사
                  </button>
                  <button
                    id="blog-print-btn"
                    class="blog-post-share-btn share-btn print"
                    type="button"
                  >
                    인쇄
                  </button>
                  {encodedDownloadMarkdown ? (
                    <button
                      id="blog-md-download-btn"
                      class="blog-post-share-btn share-btn md-download"
                      type="button"
                    >
                      MD 저장
                    </button>
                  ) : null}
                  <button
                    id="blog-txt-download-btn"
                    class="blog-post-share-btn share-btn txt-download"
                    type="button"
                  >
                    TXT 저장
                  </button>
                  <button
                    id="blog-reading-mode-btn"
                    class="blog-post-share-btn share-btn reading-mode-toggle"
                    type="button"
                  >
                    집중 모드
                  </button>
                  <BookmarkButton slug={slug} />
                </div>
                <p id="share-feedback" class="blog-post-share-feedback" aria-live="polite"></p>
              </div>

              <SubscribeForm source={onAcademyArticle ? 'academy' : 'blog'} />

              <p class="blog-post-report-line">
                <button
                  type="button"
                  class="blog-post-report-link"
                  data-post-report-open
                  aria-haspopup="dialog"
                  aria-expanded="false"
                  aria-controls="post-report-dialog"
                >
                  오류 신고
                </button>
                <span class="blog-post-report-hint">오탈자·내용 오류를 알려 주시면 검토합니다.</span>
              </p>

              <div
                id="post-report-dialog"
                class="post-report-modal-root"
                data-post-report-modal
                hidden
                role="dialog"
                aria-modal="true"
                aria-labelledby="post-report-title"
              >
                <div class="post-report-modal-backdrop" data-post-report-close tabindex="-1" aria-hidden="true"></div>
                <div class="post-report-modal-box">
                  <div class="post-report-modal-head">
                    <h2 id="post-report-title" class="post-report-modal-title">글 오류 신고</h2>
                    <button type="button" class="post-report-modal-x" data-post-report-close aria-label="닫기">
                      ×
                    </button>
                  </div>
                  <form class="post-report-form" data-post-report-form>
                    <fieldset class="post-report-types">
                      <legend class="visually-hidden">신고 유형</legend>
                      <label class="post-report-type-label">
                        <input type="radio" name="report_type" value="typo" required />
                        오탈자
                      </label>
                      <label class="post-report-type-label">
                        <input type="radio" name="report_type" value="factual_error" />
                        사실 오류
                      </label>
                      <label class="post-report-type-label">
                        <input type="radio" name="report_type" value="outdated" />
                        오래된 정보
                      </label>
                      <label class="post-report-type-label">
                        <input type="radio" name="report_type" value="other" />
                        기타
                      </label>
                    </fieldset>
                    <label class="post-report-field">
                      <span class="post-report-field-label">추가 설명 (선택)</span>
                      <textarea
                        name="description"
                        class="post-report-textarea"
                        rows="4"
                        maxlength="4000"
                        placeholder="어느 문단·문장인지 적어 주시면 도움이 됩니다."
                      ></textarea>
                    </label>
                    <label class="post-report-field">
                      <span class="post-report-field-label">이메일 (선택, 답장을 원하실 때)</span>
                      <input
                        type="email"
                        name="reporter_email"
                        class="post-report-input"
                        autocomplete="email"
                        maxlength="320"
                      />
                    </label>
                    <p class="post-report-form-msg" data-post-report-msg hidden></p>
                    <div class="post-report-modal-actions">
                      <button type="button" class="post-report-btn post-report-btn-secondary" data-post-report-close>
                        취소
                      </button>
                      <button type="submit" class="post-report-btn post-report-btn-primary" data-post-report-submit>
                        신고하기
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </article>
        </div>
      </main>

      <Footer />
    </div>

    <script is:inline>
      function mergeBlogHrefFromSearch(search, patch) {
        const p = new URLSearchParams(search.startsWith('?') ? search.slice(1) : search);
        for (const [key, v] of Object.entries(patch)) {
          if (v === null || v === '') p.delete(key);
          else p.set(key, String(v));
        }
        const s = p.toString();
        return s ? `/blog/?${s}` : '/blog/';
      }
      function applyBlogSidebarMergeLinks() {
        document.querySelectorAll('a.js-blog-merge[data-blog-merge]').forEach((a) => {
          let patch = {};
          try {
            patch = JSON.parse(a.getAttribute('data-blog-merge') || '{}');
          } catch (_) {}
          a.setAttribute('href', mergeBlogHrefFromSearch(location.search, patch));
        });
      }
      applyBlogSidebarMergeLinks();
      window.addEventListener('popstate', applyBlogSidebarMergeLinks);
    </script>

    <script>
      import { createClient } from '@supabase/supabase-js';
      import { formatViewCount, trackBlogPostView } from '../lib/blog-post-views';

      const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
      const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

      (async () => {
        const line = document.getElementById('blog-post-view-line');
        const numEl = line?.querySelector('[data-post-view-num]');
        const postSlug = line?.dataset.postSlug?.trim() ?? '';
        if (!line || !numEl || !postSlug) {
          line?.remove();
          return;
        }
        if (!supabaseUrl || !supabaseKey) {
          line.hidden = true;
          return;
        }
        const supabase = createClient(supabaseUrl, supabaseKey);
        const count = await trackBlogPostView(supabase, postSlug);
        if (count === null) {
          numEl.textContent = '—';
        } else {
          numEl.textContent = formatViewCount(count);
        }
      })();
    </script>

    <script>
      import { createClient } from '@supabase/supabase-js';
      import { postHrefFromDbSlug } from '../lib/academy';

      type FallbackItem = {
        slug: string;
        href: string;
        title: string;
        description: string;
        category: string | null;
        published_at: string;
      };

      type RelatedRow = {
        slug: string;
        title: string;
        description: string;
        category: string | null;
        published_at: string | null;
        similarity: number;
      };

      function escapeHtml(s: string): string {
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function normalizeEmbedding(raw: unknown): number[] | null {
        if (Array.isArray(raw) && raw.length > 0 && typeof raw[0] === 'number') {
          return raw as number[];
        }
        if (typeof raw === 'string') {
          try {
            const p = JSON.parse(raw) as unknown;
            if (Array.isArray(p) && p.length > 0 && typeof p[0] === 'number') {
              return p as number[];
            }
          } catch {
            /* fall through */
          }
        }
        return null;
      }

      function formatRelatedDate(iso: string | null | undefined): string {
        if (!iso) return '';
        try {
          return new Intl.DateTimeFormat('ko-KR', { dateStyle: 'medium' }).format(new Date(iso));
        } catch {
          return '';
        }
      }

      function renderRelatedList(
        root: HTMLElement,
        listEl: HTMLUListElement,
        statusEl: HTMLElement,
        items: Array<{
          href: string;
          title: string;
          description: string;
          category: string | null;
          published_at: string | null;
        }>,
        categoryLabels: Record<string, string>,
      ) {
        root.removeAttribute('aria-busy');
        if (!items.length) {
          root.hidden = true;
          statusEl.textContent = '';
          listEl.innerHTML = '';
          listEl.hidden = true;
          return;
        }
        root.hidden = false;
        statusEl.textContent = '';
        listEl.hidden = false;
        listEl.innerHTML = items
          .map((item) => {
            const cat =
              item.category && categoryLabels[item.category]
                ? `<span class="blog-post-related-cat">${escapeHtml(categoryLabels[item.category])}</span>`
                : '';
            const dateLine = formatRelatedDate(item.published_at);
            const meta = [cat, dateLine].filter(Boolean).join(' · ');
            return `<li class="blog-post-related-item">
              <a class="blog-post-related-link" href="${escapeHtml(item.href)}">${escapeHtml(item.title)}</a>
              ${item.description ? `<p class="blog-post-related-desc">${escapeHtml(item.description)}</p>` : ''}
              ${meta ? `<p class="blog-post-related-meta">${meta}</p>` : ''}
            </li>`;
          })
          .join('');
      }

      (async () => {
        const root = document.querySelector('[data-blog-related]');
        const listEl = document.querySelector('[data-blog-related-list]');
        const statusEl = document.querySelector('[data-blog-related-status]');
        const propsEl = document.getElementById('blog-related-props');
        if (!(root instanceof HTMLElement) || !(listEl instanceof HTMLUListElement) || !(statusEl instanceof HTMLElement)) {
          return;
        }

        let props: { slug: string; categoryLabels: Record<string, string>; fallback: FallbackItem[] } = {
          slug: '',
          categoryLabels: {},
          fallback: [],
        };
        try {
          props = JSON.parse(propsEl?.textContent || '{}') as typeof props;
        } catch {
          root.hidden = true;
          root.removeAttribute('aria-busy');
          return;
        }

        const labels = props.categoryLabels ?? {};
        const fallbackItems = (props.fallback ?? []).map((f) => ({
          href: f.href,
          title: f.title,
          description: f.description,
          category: f.category,
          published_at: f.published_at,
        }));

        if (!props.slug) {
          root.hidden = true;
          root.removeAttribute('aria-busy');
          statusEl.textContent = '';
          return;
        }

        const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
        const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
        if (!supabaseUrl || !supabaseKey) {
          renderRelatedList(root, listEl, statusEl, fallbackItems, labels);
          return;
        }

        const supabase = createClient(supabaseUrl, supabaseKey);

        const useFallback = () => renderRelatedList(root, listEl, statusEl, fallbackItems, labels);

        const { data: postRow, error: embErr } = await supabase
          .from('posts')
          .select('embedding')
          .eq('slug', props.slug)
          .maybeSingle();

        if (embErr || !postRow) {
          useFallback();
          return;
        }

        const embedding = normalizeEmbedding(postRow.embedding);
        if (!embedding || embedding.length !== 1536) {
          useFallback();
          return;
        }

        const { data: related, error: rpcErr } = await supabase.rpc('match_posts', {
          query_embedding: embedding,
          match_threshold: 0.7,
          match_count: 3,
          exclude_slug: props.slug,
        });

        if (rpcErr || !related?.length) {
          useFallback();
          return;
        }

        const rows = related as RelatedRow[];
        const items = rows.map((r) => ({
          href: postHrefFromDbSlug(r.slug),
          title: r.title,
          description: r.description ?? '',
          category: r.category,
          published_at: r.published_at,
        }));
        renderRelatedList(root, listEl, statusEl, items, labels);
      })();
    </script>

    <script>
      import { createClient } from '@supabase/supabase-js';

      type CommentRow = {
        id: string;
        slug: string;
        parent_id: string | null;
        author_name: string;
        author_email: string | null;
        body: string;
        is_approved: boolean;
        created_at: string;
      };

      const url = import.meta.env.PUBLIC_SUPABASE_URL;
      const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

      function formatCommentDate(iso: string): string {
        try {
          return new Intl.DateTimeFormat('ko-KR', {
            dateStyle: 'medium',
            timeStyle: 'short',
          }).format(new Date(iso));
        } catch {
          return '';
        }
      }

      (async () => {
        const root = document.querySelector('[data-blog-comments]');
        if (!root || !(root instanceof HTMLElement)) return;
        const postSlug = root.dataset.postSlug?.trim() ?? '';
        if (!postSlug || !url || !key) return;
        root.hidden = false;

        const supabase = createClient(url, key, {
          auth: {
            persistSession: true,
            autoRefreshToken: true,
            detectSessionInUrl: false,
          },
        });
        const listEl = root.querySelector('[data-comments-list]');
        const countEl = root.querySelector('[data-comments-count]');
        const form = root.querySelector('[data-comments-form]');
        const formMsg = root.querySelector('[data-comments-form-msg]');
        const parentInput = root.querySelector('[data-comments-parent-id]');
        const replyHint = root.querySelector('[data-comments-reply-hint]');
        const cancelReplyBtn = root.querySelector('[data-comments-cancel-reply]');
        const bodyTa = root.querySelector('[data-comments-body]');
        const charEl = root.querySelector('[data-comments-char]');

        if (!listEl || !countEl || !form || !(form instanceof HTMLFormElement)) return;

        const updateCount = () => {
          const n = listEl.querySelectorAll('li[data-comment-id]').length;
          countEl.textContent = String(n);
        };

        const showFormMsg = (text: string, isError: boolean) => {
          if (!(formMsg instanceof HTMLElement)) return;
          formMsg.hidden = false;
          formMsg.textContent = text;
          formMsg.dataset.state = isError ? 'error' : 'success';
        };

        const clearFormMsg = () => {
          if (!(formMsg instanceof HTMLElement)) return;
          formMsg.hidden = true;
          formMsg.textContent = '';
          delete formMsg.dataset.state;
        };

        const resetReply = () => {
          if (parentInput instanceof HTMLInputElement) parentInput.value = '';
          if (replyHint instanceof HTMLElement) replyHint.hidden = true;
        };

        const buildCommentLi = (row: CommentRow, isNested: boolean): HTMLLIElement => {
          const li = document.createElement('li');
          li.className = isNested ? 'blog-post-comment-item blog-post-comment-item--reply' : 'blog-post-comment-item';
          li.dataset.commentId = row.id;

          const art = document.createElement('article');
          art.className = 'blog-post-comment-card';

          const head = document.createElement('header');
          head.className = 'blog-post-comment-head';
          const strong = document.createElement('strong');
          strong.className = 'blog-post-comment-author';
          strong.textContent = row.author_name;
          const time = document.createElement('time');
          time.className = 'blog-post-comment-time';
          time.dateTime = row.created_at;
          time.textContent = formatCommentDate(row.created_at);
          head.append(strong, document.createTextNode(' · '), time);

          const p = document.createElement('p');
          p.className = 'blog-post-comment-body';
          p.textContent = row.body;

          art.append(head, p);

          if (!isNested) {
            const repliesUl = document.createElement('ul');
            repliesUl.className = 'blog-post-comment-replies';
            repliesUl.dataset.commentReplies = '';
            const replyBtn = document.createElement('button');
            replyBtn.type = 'button';
            replyBtn.className = 'blog-post-comment-reply-btn';
            replyBtn.textContent = '답글';
            replyBtn.addEventListener('click', () => {
              if (parentInput instanceof HTMLInputElement) parentInput.value = row.id;
              if (replyHint instanceof HTMLElement) replyHint.hidden = false;
              form.querySelector('input[name="author_name"]')?.focus();
            });
            art.append(replyBtn, repliesUl);
          }

          li.append(art);
          return li;
        };

        const renderNewComment = (row: CommentRow) => {
          if (listEl.querySelector(`[data-comment-id="${row.id}"]`)) return;
          if (!row.is_approved) return;

          if (row.parent_id) {
            const parentLi = listEl.querySelector(`:scope > li[data-comment-id="${row.parent_id}"]`);
            const repliesUl = parentLi?.querySelector('[data-comment-replies]');
            if (repliesUl) {
              repliesUl.append(buildCommentLi(row, true));
              updateCount();
            }
            return;
          }

          listEl.append(buildCommentLi(row, false));
          updateCount();
        };

        const renderAll = (rows: CommentRow[]) => {
          listEl.innerHTML = '';
          const byParent = new Map<string | null, CommentRow[]>();
          for (const r of rows) {
            const k = r.parent_id;
            if (!byParent.has(k)) byParent.set(k, []);
            byParent.get(k)!.push(r);
          }
          for (const arr of byParent.values()) {
            arr.sort((a, b) => new Date(a.created_at).getTime() - new Date(b.created_at).getTime());
          }
          const roots = byParent.get(null) ?? [];
          for (const rootRow of roots) {
            const li = buildCommentLi(rootRow, false);
            listEl.append(li);
            const replies = byParent.get(rootRow.id) ?? [];
            const repliesUl = li.querySelector('[data-comment-replies]');
            for (const ch of replies) {
              repliesUl?.append(buildCommentLi(ch, true));
            }
          }
          updateCount();
        };

        const { data, error } = await supabase
          .from('comments')
          .select('*')
          .eq('slug', postSlug)
          .eq('is_approved', true)
          .order('created_at', { ascending: true });

        if (error) {
          root.hidden = true;
          return;
        }
        renderAll((data ?? []) as CommentRow[]);

        const channel = supabase
          .channel('comments:' + postSlug)
          .on(
            'postgres_changes',
            {
              event: 'INSERT',
              schema: 'public',
              table: 'comments',
              filter: `slug=eq.${postSlug}`,
            },
            (payload) => {
              const n = payload.new as CommentRow | null;
              if (n?.is_approved) renderNewComment(n);
            },
          )
          .subscribe();

        window.addEventListener('pagehide', () => {
          void channel.unsubscribe();
        });

        cancelReplyBtn?.addEventListener('click', () => {
          resetReply();
          clearFormMsg();
        });

        if (bodyTa instanceof HTMLTextAreaElement && charEl) {
          const syncChar = () => {
            charEl.textContent = `${bodyTa.value.length} / 500`;
          };
          bodyTa.addEventListener('input', syncChar);
          syncChar();
        }

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          clearFormMsg();
          const fd = new FormData(form);
          const author_name = String(fd.get('author_name') || '').trim();
          const author_emailRaw = String(fd.get('author_email') || '').trim();
          const body = String(fd.get('body') || '').trim();
          let parent_id: string | null = String(fd.get('parent_id') || '').trim() || null;

          if (!author_name || !body) {
            showFormMsg('이름과 내용을 입력해 주세요.', true);
            return;
          }

          if (parent_id) {
            const parentLi = listEl.querySelector(`:scope > li[data-comment-id="${parent_id}"]`);
            if (!parentLi) {
              showFormMsg('답글 대상을 찾을 수 없습니다.', true);
              return;
            }
          }

          const insertPayload: Record<string, unknown> = {
            slug: postSlug,
            author_name,
            body,
            parent_id,
          };
          if (author_emailRaw) insertPayload.author_email = author_emailRaw;

          const { data: authUserData } = await supabase.auth.getUser();
          if (authUserData.user?.id) {
            insertPayload.user_id = authUserData.user.id;
          }

          const { error: insErr } = await supabase.from('comments').insert(insertPayload);

          if (insErr) {
            showFormMsg(insErr.message || '등록에 실패했습니다.', true);
            return;
          }

          showFormMsg('댓글이 등록되었습니다. 검토 후 표시됩니다.', false);
          form.reset();
          resetReply();
          if (bodyTa instanceof HTMLTextAreaElement && charEl) {
            charEl.textContent = '0 / 500';
          }
        });
      })();
    </script>

    <script>
      import { createClient } from '@supabase/supabase-js';
      import {
        fetchMyReactions,
        fetchReactionCounts,
        getReactionIdentity,
        togglePostReaction,
        type ReactionIdentity,
        type ReactionType,
      } from '../lib/blog-post-reactions';

      const reactionUrl = import.meta.env.PUBLIC_SUPABASE_URL;
      const reactionKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

      (async () => {
        const root = document.getElementById('blog-post-reactions');
        if (!root) return;
        const postSlug = root.dataset.postSlug?.trim() ?? '';
        if (!postSlug || !reactionUrl || !reactionKey) {
          root.hidden = true;
          return;
        }
        const supabase = createClient(reactionUrl, reactionKey, {
          auth: {
            persistSession: true,
            autoRefreshToken: true,
            detectSessionInUrl: false,
          },
        });

        let identity: ReactionIdentity = await getReactionIdentity(supabase);
        let counts = await fetchReactionCounts(supabase, postSlug);
        let mine = await fetchMyReactions(supabase, postSlug, identity);
        const buttons = root.querySelectorAll('[data-reaction]');

        const syncUi = () => {
          buttons.forEach((node) => {
            const btn = node as HTMLButtonElement;
            const r = btn.dataset.reaction as ReactionType | undefined;
            if (!r) return;
            const countEl = btn.querySelector('[data-reaction-count]');
            btn.setAttribute('aria-pressed', mine.has(r) ? 'true' : 'false');
            btn.classList.toggle('is-active', mine.has(r));
            if (countEl) countEl.textContent = String(counts[r] ?? 0);
          });
        };

        const refreshAll = async () => {
          identity = await getReactionIdentity(supabase);
          counts = await fetchReactionCounts(supabase, postSlug);
          mine = await fetchMyReactions(supabase, postSlug, identity);
          syncUi();
        };

        syncUi();

        supabase.auth.onAuthStateChange(() => {
          void refreshAll();
        });

        buttons.forEach((node) => {
          const btn = node as HTMLButtonElement;
          btn.addEventListener('click', async () => {
            const r = btn.dataset.reaction as ReactionType | undefined;
            if (!r) return;
            btn.disabled = true;
            identity = await getReactionIdentity(supabase);
            const result = await togglePostReaction(supabase, postSlug, identity, r);
            if (result === 'added') mine.add(r);
            else if (result === 'removed') mine.delete(r);
            globalThis.gtag?.('event', 'reaction', { type: r, slug: postSlug });
            counts = await fetchReactionCounts(supabase, postSlug);
            syncUi();
            btn.disabled = false;
          });
        });
      })();
    </script>

    <script is:inline>
      (function () {
        const banner = document.getElementById('blog-print-banner');
        if (!banner) return;
        window.addEventListener('beforeprint', function () {
          banner.setAttribute(
            'data-print-date',
            new Date().toLocaleString('ko-KR', { dateStyle: 'medium', timeStyle: 'short' }),
          );
        });
      })();
    </script>

    <script define:vars={{ reportPostSlug: slug }}>
      (() => {
        const slug = reportPostSlug;
        const modal = document.querySelector('[data-post-report-modal]');
        const openBtn = document.querySelector('[data-post-report-open]');
        const form = document.querySelector('[data-post-report-form]');
        const msg = document.querySelector('[data-post-report-msg]');
        const submitBtn = document.querySelector('[data-post-report-submit]');
        const closers = () => document.querySelectorAll('[data-post-report-close]');

        const setOpen = (open) => {
          if (!(modal instanceof HTMLElement)) return;
          modal.hidden = !open;
          if (openBtn instanceof HTMLElement) openBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
          if (open) {
            const first = form?.querySelector('input[type="radio"]');
            if (first instanceof HTMLElement) first.focus();
          }
        };

        const showMsg = (text, isError) => {
          if (!(msg instanceof HTMLElement)) return;
          msg.hidden = false;
          msg.textContent = text;
          msg.dataset.state = isError ? 'error' : 'success';
        };

        const resetMsg = () => {
          if (!(msg instanceof HTMLElement)) return;
          msg.hidden = true;
          msg.textContent = '';
          delete msg.dataset.state;
        };

        openBtn?.addEventListener('click', () => {
          resetMsg();
          setOpen(true);
        });

        closers().forEach((el) => {
          el.addEventListener('click', () => setOpen(false));
        });

        modal?.addEventListener('click', (e) => {
          if (e.target === modal) setOpen(false);
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && modal instanceof HTMLElement && !modal.hidden) {
            setOpen(false);
          }
        });

        form?.addEventListener('submit', async (e) => {
          e.preventDefault();
          if (!(form instanceof HTMLFormElement) || !(submitBtn instanceof HTMLButtonElement)) return;
          const fd = new FormData(form);
          const report_type = String(fd.get('report_type') || '');
          const description = String(fd.get('description') || '').trim();
          const reporter_email = String(fd.get('reporter_email') || '').trim();
          if (!report_type) {
            showMsg('신고 유형을 선택해 주세요.', true);
            return;
          }
          resetMsg();
          submitBtn.disabled = true;
          submitBtn.textContent = '전송 중…';
          try {
            const res = await fetch('/api/report', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ slug, report_type, description, reporter_email }),
            });
            const data = await res.json().catch(() => ({}));
            if (!res.ok) {
              showMsg(String(data?.error || '전송에 실패했습니다. 잠시 후 다시 시도해 주세요.'), true);
              return;
            }
            showMsg('소중한 피드백 감사합니다.', false);
            form.reset();
            window.setTimeout(() => setOpen(false), 1200);
          } catch {
            showMsg('네트워크 오류가 발생했습니다.', true);
          } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = '신고하기';
          }
        });
      })();
    </script>

    <script define:vars={{ pageUrl, contentId: slug }}>
      const READING_MODE_LS = 'sreborn_blog_reading_mode_v1';

      function isEditableTarget(el) {
        if (!el || !(el instanceof HTMLElement)) return false;
        const t = el.tagName;
        if (t === 'INPUT' || t === 'TEXTAREA' || t === 'SELECT') return true;
        return el.isContentEditable;
      }

      function reportModalOpen() {
        const modal = document.querySelector('[data-post-report-modal]');
        return modal instanceof HTMLElement && !modal.hidden;
      }

      function setReadingMode(on) {
        document.body.classList.toggle('reading-mode', on);
        const bar = document.getElementById('blog-reading-mode-exit');
        if (bar instanceof HTMLElement) {
          if (on) bar.removeAttribute('hidden');
          else bar.setAttribute('hidden', '');
        }
        try {
          localStorage.setItem(READING_MODE_LS, on ? '1' : '0');
        } catch {
          /* ignore */
        }
      }

      function syncReadingModeFromStorage() {
        let on = false;
        try {
          on = localStorage.getItem(READING_MODE_LS) === '1';
        } catch {
          /* ignore */
        }
        setReadingMode(on);
      }

      syncReadingModeFromStorage();

      const readingExit = document.getElementById('blog-reading-mode-exit');
      readingExit?.addEventListener('click', () => setReadingMode(false));
      readingExit?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          setReadingMode(false);
        }
      });

      document.getElementById('blog-reading-mode-btn')?.addEventListener('click', () => {
        const next = !document.body.classList.contains('reading-mode');
        setReadingMode(next);
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          if (reportModalOpen()) return;
          if (document.body.classList.contains('reading-mode')) {
            e.preventDefault();
            setReadingMode(false);
          }
          return;
        }
        if (e.key === 'f' || e.key === 'F' || e.key === 'r' || e.key === 'R') {
          if (e.ctrlKey || e.metaKey || e.altKey) return;
          if (isEditableTarget(document.activeElement)) return;
          e.preventDefault();
          const next = !document.body.classList.contains('reading-mode');
          setReadingMode(next);
        }
      });

      const tw = document.querySelector('a.blog-post-share-btn.share-btn.twitter');
      tw?.addEventListener('click', () => {
        globalThis.gtag?.('event', 'share', { method: 'twitter', content_id: contentId });
      });

      const copyButton = document.getElementById('copy-link-btn');
      const feedback = document.getElementById('share-feedback');

      document.getElementById('blog-print-btn')?.addEventListener('click', () => {
        window.print();
      });

      function downloadBaseName(article) {
        const raw = article?.getAttribute('data-download-slug') || contentId || 'post';
        return raw.replace(/\//g, '-');
      }

      document.getElementById('blog-md-download-btn')?.addEventListener('click', () => {
        const article = document.querySelector('article.blog-post-article');
        const raw = article?.getAttribute('data-markdown');
        if (!raw) return;
        let markdownContent;
        try {
          markdownContent = decodeURIComponent(raw);
        } catch {
          return;
        }
        const blob = new Blob([markdownContent], { type: 'text/markdown' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${downloadBaseName(article)}.md`;
        a.click();
        URL.revokeObjectURL(url);
        globalThis.gtag?.('event', 'share', { method: 'download_md', content_id: contentId });
      });

      document.getElementById('blog-txt-download-btn')?.addEventListener('click', () => {
        const article = document.querySelector('article.blog-post-article');
        const text = document.querySelector('.prose')?.innerText ?? '';
        const blob = new Blob([text], { type: 'text/plain;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${downloadBaseName(article)}.txt`;
        a.click();
        URL.revokeObjectURL(url);
        globalThis.gtag?.('event', 'share', { method: 'download_txt', content_id: contentId });
      });

      copyButton?.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(pageUrl);
          globalThis.gtag?.('event', 'share', { method: 'copy_link', content_id: contentId });
          if (copyButton) {
            copyButton.textContent = '복사됨!';
            setTimeout(() => { copyButton.textContent = '링크 복사'; }, 2000);
          }
          if (feedback) feedback.textContent = '현재 글 링크를 클립보드에 복사했습니다.';
        } catch {
          if (feedback) feedback.textContent = '링크 복사에 실패했습니다.';
        }
      });
    </script>

    <script is:inline>
      (function () {
        var article = document.querySelector('article.blog-post-article');
        var bar = document.querySelector('[data-reading-progress]');
        if (!article || !bar) return;
        function update() {
          var r = article.getBoundingClientRect();
          var windowH = window.innerHeight;
          var scrolled = Math.max(0, -r.top);
          var total = r.height - windowH;
          var pct = total > 0 ? Math.min(100, (scrolled / total) * 100) : 0;
          bar.style.width = pct + '%';
        }
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update, { passive: true });
        update();
      })();
    </script>

    <script define:vars={{ tocAnchorIds: tocItems.map((t) => t.id) }}>
      (() => {
        if (!tocAnchorIds.length) return;
        const tocLinks = document.querySelectorAll('[data-toc-link]');
        if (!tocLinks.length) return;
        const idSet = new Set(tocAnchorIds);
        const headings = [
          ...document.querySelectorAll('article.blog-post-article h2, article.blog-post-article h3'),
        ].filter((el): el is HTMLElement => el instanceof HTMLElement && idSet.has(el.id));
        if (!headings.length) return;
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const id = entry.target.id;
              tocLinks.forEach((link) => {
                link.classList.toggle('is-active', link.dataset.tocLink === id);
              });
            });
          },
          { rootMargin: '-20% 0px -70% 0px' },
        );
        headings.forEach((h) => observer.observe(h));
      })();
    </script>

    {seriesName && seriesTotal > 0 && (
      <script
        define:vars={{
          seriesReadSlug: slug,
          seriesSiblingIdsJson: JSON.stringify(seriesSiblings.map((p) => p.id)),
        }}
      >
        (() => {
          const READ_PREFIX = 'read:';
          const readKey = (id: string) => READ_PREFIX + id;

          const nav = document.querySelector('[data-blog-series-nav]');
          const rereadEl = document.querySelector('[data-series-reread-msg]');
          const nextHint = document.querySelector('[data-series-next-unread-hint]');
          const nextBtn = document.querySelector('a.blog-post-series-btn[data-series-nav-next]');

          let siblingIds: string[] = [];
          try {
            siblingIds = JSON.parse(seriesSiblingIdsJson || '[]') as string[];
          } catch {
            siblingIds = [];
          }

          function updateSeriesProgress() {
            if (!nav) return;

            const firstUnread = siblingIds.find((id) => localStorage.getItem(readKey(id)) !== 'true');

            document.querySelectorAll('[data-series-post-slug]').forEach((li) => {
              if (!(li instanceof HTMLElement)) return;
              const sid = li.dataset.seriesPostSlug;
              if (!sid) return;
              const read = localStorage.getItem(readKey(sid)) === 'true';
              li.classList.toggle('is-read', read);
              const mark = li.querySelector('.blog-post-series-item-check');
              if (mark) mark.textContent = read ? '✓' : '';
              li.classList.toggle('is-next-unread', Boolean(firstUnread && sid === firstUnread));
            });

            if (rereadEl instanceof HTMLElement) {
              rereadEl.hidden = localStorage.getItem(readKey(seriesReadSlug)) !== 'true';
            }

            if (nextBtn instanceof HTMLAnchorElement) {
              const nextId = nextBtn.getAttribute('data-series-nav-next');
              nextBtn.classList.toggle(
                'blog-post-series-btn--next-unread',
                Boolean(firstUnread && nextId && nextId === firstUnread),
              );
            }

            if (nextHint instanceof HTMLElement) {
              nextHint.hidden = !(
                firstUnread &&
                nextBtn instanceof HTMLAnchorElement &&
                nextBtn.getAttribute('data-series-nav-next') === firstUnread
              );
            }
          }

          const article = document.querySelector('article.blog-post-article');
          if (!article) return;

          const prose = article.querySelector('.blog-post-prose');
          const lastEl = (prose?.lastElementChild ?? article.lastElementChild) as Element | null;
          if (!lastEl) {
            updateSeriesProgress();
            return;
          }

          updateSeriesProgress();

          if (localStorage.getItem(readKey(seriesReadSlug)) === 'true') {
            return;
          }

          const observer = new IntersectionObserver(
            ([entry]) => {
              if (!entry?.isIntersecting) return;
              try {
                localStorage.setItem(readKey(seriesReadSlug), 'true');
              } catch {
                /* ignore quota */
              }
              observer.disconnect();
              updateSeriesProgress();
            },
            { threshold: 0.1 },
          );
          observer.observe(lastEl);
        })();
      </script>
    )}

    <div
      data-highlight-popup
      class="blog-highlight-share-popup"
      hidden
      role="dialog"
      aria-label="선택 인용 공유"
    >
      <button type="button" class="blog-highlight-share-btn" data-share-twitter>X에 인용</button>
      <button type="button" class="blog-highlight-share-btn" data-share-copy>링크 복사</button>
    </div>

    <script define:vars={{ pageUrl, highlightShareTitle: title, highlightContentId: slug }}>
      (() => {
        const popup = document.querySelector('[data-highlight-popup]');
        const btnTw = document.querySelector('[data-share-twitter]');
        const btnCopy = document.querySelector('[data-share-copy]');
        if (!(popup instanceof HTMLElement) || !(btnTw instanceof HTMLButtonElement) || !(btnCopy instanceof HTMLButtonElement)) {
          return;
        }

        const copyDefaultLabel = btnCopy.textContent || '링크 복사';

        let storedSelection = '';

        function hidePopup() {
          storedSelection = '';
          popup.setAttribute('hidden', '');
          popup.removeAttribute('style');
        }

        function proseRoot(): Element | null {
          return document.querySelector('article.blog-post-article .blog-post-prose.prose');
        }

        function selectionInProseOnly(range: Range): boolean {
          const root = proseRoot();
          if (!root) return false;
          const startN = range.startContainer;
          const endN = range.endContainer;
          const startEl =
            startN.nodeType === Node.TEXT_NODE ? (startN.parentElement as Element | null) : (startN as Element);
          const endEl = endN.nodeType === Node.TEXT_NODE ? (endN.parentElement as Element | null) : (endN as Element);
          if (!startEl || !endEl) return false;
          if (!root.contains(startEl) || !root.contains(endEl)) return false;
          if (startEl.closest('input, textarea, button, [data-highlight-popup], .blog-post-comments')) return false;
          return true;
        }

        function showPopup(rect: DOMRectReadOnly, text: string) {
          storedSelection = text;
          popup.removeAttribute('hidden');
          const margin = 8;
          const place = () => {
            const w = popup.offsetWidth || 200;
            const h = popup.offsetHeight || 40;
            const centerX = rect.left + rect.width / 2;
            const halfW = w / 2;
            const leftPx = Math.min(Math.max(centerX, margin + halfW), window.innerWidth - margin - halfW);
            let topPx = rect.top - h - margin;
            if (topPx < margin) {
              topPx = Math.min(rect.bottom + margin, window.innerHeight - h - margin);
            }
            popup.style.left = `${leftPx}px`;
            popup.style.top = `${topPx}px`;
            popup.style.transform = 'translateX(-50%)';
          };
          place();
          requestAnimationFrame(place);
        }

        function handleSelectionDone() {
          const sel = window.getSelection();
          if (!sel || sel.rangeCount === 0) {
            hidePopup();
            return;
          }
          const selected = sel.toString().trim();
          if (!selected || selected.length < 10 || selected.length > 280) {
            hidePopup();
            return;
          }
          let range: Range;
          try {
            range = sel.getRangeAt(0);
          } catch {
            hidePopup();
            return;
          }
          if (!selectionInProseOnly(range)) {
            hidePopup();
            return;
          }
          const r = range.getBoundingClientRect();
          if (r.width === 0 && r.height === 0) {
            hidePopup();
            return;
          }
          showPopup(r, selected);
        }

        document.addEventListener(
          'mouseup',
          () => {
            requestAnimationFrame(handleSelectionDone);
          },
          { passive: true },
        );

        document.addEventListener(
          'touchend',
          () => {
            requestAnimationFrame(handleSelectionDone);
          },
          { passive: true },
        );

        document.addEventListener(
          'mousedown',
          (e) => {
            if (e.target instanceof Node && popup.contains(e.target)) return;
            hidePopup();
          },
          true,
        );

        window.addEventListener(
          'scroll',
          () => {
            hidePopup();
          },
          { passive: true },
        );

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !popup.hasAttribute('hidden')) {
            hidePopup();
          }
        });

        btnTw.addEventListener('click', () => {
          const selected = storedSelection;
          if (!selected) return;
          const quote = `"${selected}" — ${highlightShareTitle}`;
          const url = `https://twitter.com/intent/tweet?text=${encodeURIComponent(quote)}&url=${encodeURIComponent(pageUrl)}`;
          window.open(url, '_blank', 'noopener,noreferrer');
          globalThis.gtag?.('event', 'share', { method: 'twitter_quote', content_id: highlightContentId });
          hidePopup();
        });

        btnCopy.addEventListener('click', async () => {
          const selected = storedSelection;
          if (!selected) return;
          let base: string;
          try {
            const u = new URL(pageUrl);
            u.hash = '';
            base = u.href;
          } catch {
            base = pageUrl.split('#')[0] || pageUrl;
          }
          const fragmentUrl = `${base}#:~:text=${encodeURIComponent(selected)}`;
          try {
            await navigator.clipboard.writeText(fragmentUrl);
            btnCopy.textContent = '복사됨!';
            globalThis.gtag?.('event', 'share', { method: 'highlight_fragment', content_id: highlightContentId });
            window.setTimeout(() => {
              btnCopy.textContent = copyDefaultLabel;
            }, 2000);
            hidePopup();
          } catch {
            btnCopy.textContent = '복사 실패';
            window.setTimeout(() => {
              btnCopy.textContent = copyDefaultLabel;
            }, 2000);
          }
        });
      })();
    </script>

    <WebVitalsCollector />
  </body>
