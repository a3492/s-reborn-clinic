---
import '../styles/design.css';
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getPublicSiteSettings } from '../lib/site-settings';
import { buildOrganizationAndWebSiteJsonLd } from '../lib/structured-data';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { title, description = SITE_DESCRIPTION, image } = Astro.props;
const siteSettings = await getPublicSiteSettings();
const resolvedSiteTitle = siteSettings.siteTitle || SITE_TITLE;
const resolvedDescription = description || siteSettings.siteDescription || SITE_DESCRIPTION;
const jsonLd = buildOrganizationAndWebSiteJsonLd(Astro.site);
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead
      title={title ? `${title} | ${resolvedSiteTitle}` : resolvedSiteTitle}
      description={resolvedDescription}
      image={image || siteSettings.defaultOgImage || undefined}
      siteTitle={resolvedSiteTitle}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <div class="site-wrap">
      <Header />
      <Topbar />
      <main class="site-main">
        <slot />
      </main>
      <Footer siteTitle={resolvedSiteTitle} socialLinks={siteSettings.socialLinks} />
    </div>
  </body>
</html>
