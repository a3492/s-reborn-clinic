---
import '../styles/design.css';
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import AnalyticsScripts from '../components/AnalyticsScripts.astro';
import Header from '../components/Header.astro';
import Topbar from '../components/Topbar.astro';
import Footer from '../components/Footer.astro';
import WebVitalsCollector from '../components/WebVitalsCollector.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getPublicSiteSettings } from '../lib/site-settings';
import { buildOrganizationAndWebSiteJsonLd } from '../lib/structured-data';
import { t, type Locale } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** 오프라인 안내 등 검색 제외 페이지 */
  noindex?: boolean;
}

const { title, description = SITE_DESCRIPTION, image, noindex } = Astro.props;
const siteSettings = await getPublicSiteSettings();
const resolvedSiteTitle = siteSettings.siteTitle || SITE_TITLE;
const resolvedDescription = description || siteSettings.siteDescription || SITE_DESCRIPTION;
const jsonLd = buildOrganizationAndWebSiteJsonLd(Astro.site);

const locale: Locale = Astro.currentLocale === 'en' ? 'en' : 'ko';
const layoutCopyAttributionName = t(locale, 'layout.copy.attributionName');
const layoutCopyAttributionUrl = t(locale, 'layout.copy.attributionUrl');
const layoutCopyNoReprint = t(locale, 'layout.copy.noReprint');
const layoutCopySourceLabel = t(locale, 'layout.copy.sourceLabel');
const layoutMainAria = t(locale, 'layout.mainAria');
---

<!doctype html>
<html lang={locale}>
  <head>
    <BaseHead
      title={title ? `${title} | ${resolvedSiteTitle}` : resolvedSiteTitle}
      description={resolvedDescription}
      image={image || siteSettings.defaultOgImage || undefined}
      siteTitle={resolvedSiteTitle}
      jsonLd={jsonLd}
      noindex={noindex}
    />
    <!-- PWA: 홈 화면 아이콘은 public/icon-192.png, public/icon-512.png 를 추가하세요 (manifest.json 참고). -->
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1a1a2e" />
    <!-- Pretendard: global.css @import 보다 먼저 DNS 연결 -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <AnalyticsScripts />
    <script
      is:inline
      define:vars={{
        layoutCopyAttributionName,
        layoutCopyAttributionUrl,
        layoutCopyNoReprint,
        layoutCopySourceLabel,
      }}
    >
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }

      /* 복사 시 출처 자동 추가 (문구는 i18n layout.copy.*) */
      document.addEventListener('copy', function (e) {
        var selection = window.getSelection();
        if (!selection || selection.toString().length === 0) return;
        var originalText = selection.toString();
        var attribution =
          '\n\n' +
          layoutCopySourceLabel +
          layoutCopyAttributionName +
          '\n' +
          layoutCopyAttributionUrl +
          '\n' +
          layoutCopyNoReprint;
        if (e.clipboardData) {
          e.clipboardData.setData('text/plain', originalText + attribution);
          e.clipboardData.setData(
            'text/html',
            '<span>' +
              originalText.replace(/\n/g, '<br>') +
              '</span>' +
              '<p style="color:#888;font-size:0.85em;margin-top:8px;">' +
              layoutCopySourceLabel +
              '<a href="' +
              layoutCopyAttributionUrl.replace(/"/g, '&quot;') +
              '">' +
              layoutCopyAttributionName.replace(/</g, '&lt;').replace(/>/g, '&gt;') +
              '</a><br>' +
              layoutCopyNoReprint.replace(/</g, '&lt;').replace(/>/g, '&gt;') +
              '</p>'
          );
          e.preventDefault();
        }
      });
    </script>
  </head>
  <body>
    <div class="site-wrap">
      <Header />
      <Topbar />
      <main class="site-main" id="main-content" aria-label={layoutMainAria}>
        <slot />
      </main>
      <Footer siteTitle={resolvedSiteTitle} socialLinks={siteSettings.socialLinks} />
    </div>
    <WebVitalsCollector />
  </body>
</html>
