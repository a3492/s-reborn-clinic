---
import { CLINIC_INFO, SITE_TITLE } from '../consts';
import { t, type Locale } from '../i18n';

interface Props {
  siteTitle?: string;
  socialLinks?: Record<string, string>;
}

const { siteTitle = SITE_TITLE, socialLinks = {} } = Astro.props;
const locale: Locale = Astro.currentLocale === 'en' ? 'en' : 'ko';
const socialEntries = Object.entries(socialLinks).filter(([, value]) => value);
const displayHoursLine = locale === 'en' ? 'See Naver app for current hours' : '진료시간은 네이버 앱 참고';
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="site-footer-top">
      <div>
        <p class="site-footer-brand">{siteTitle}</p>
        <p class="site-footer-legal">
          {t(locale, 'footer.legal')}
          <br />
          <strong>{t(locale, 'footer.legalStrong')}</strong>{t(locale, 'footer.legalSuffix')}
        </p>
        <div class="site-footer-info">
          <p>
            {CLINIC_INFO.name} · {t(locale, 'footer.directorLabel')} {CLINIC_INFO.director}
          </p>
          <p>
            {t(locale, 'footer.addressLabel')}: {CLINIC_INFO.address} {locale === 'ko' ? CLINIC_INFO.addressDetail : '(Mapo-gu, Seoul · 2–3 min walk from Hongdae Station Exit 8/9)'}
          </p>
          <p>
            {t(locale, 'footer.phoneLabel')}: {CLINIC_INFO.phone} | {t(locale, 'footer.officialWebLabel')}:{' '}
            <a href={CLINIC_INFO.website} target="_blank" rel="noopener noreferrer">
              {CLINIC_INFO.website.replace(/^https?:\/\//, '')}
            </a>
          </p>
          <p>{t(locale, 'footer.hoursLabel')}: {displayHoursLine}</p>
        </div>
      </div>

      <div class="site-footer-links">
        <a href={locale === 'en' ? '/en/about/' : '/about/'} class="site-footer-link">{t(locale, 'footer.linkAbout')}</a>
        <a href={locale === 'en' ? '/en/procedures/' : '/procedures/'} class="site-footer-link">{t(locale, 'footer.linkProcedures')}</a>
        <a href={locale === 'en' ? '/en/blog/' : '/blog/'} class="site-footer-link">{t(locale, 'footer.linkBlog')}</a>
        <a href="/newsletter/" class="site-footer-link">{t(locale, 'footer.linkNewsletter')}</a>
<a href={locale === 'en' ? '/en/consult/' : '/consult/'} class="site-footer-link">{t(locale, 'footer.linkConsult')}</a>
        {socialEntries.map(([label, href]) => (
          <a href={href} target="_blank" rel="noreferrer" class="site-footer-link">
            {label}
          </a>
        ))}
      </div>
    </div>

    <div class="site-footer-bottom">
      <span>© {new Date().getFullYear()} {CLINIC_INFO.name}. All rights reserved.</span>
      <div style="display:flex;gap:1rem;">
        <a href="/privacy/" class="site-footer-link">{t(locale, 'footer.linkPrivacy')}</a>
        <a href="/terms/" class="site-footer-link">{t(locale, 'footer.linkTerms')}</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer-legal {
    font-size: 0.8rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.82);
    max-width: 36rem;
    margin: 0 0 0.75rem;
  }

  .site-footer-legal strong {
    color: #fff;
    font-weight: 700;
  }
</style>
