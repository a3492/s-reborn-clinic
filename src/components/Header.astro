---
import { NAV_LINKS, SITE_TITLE } from '../consts';
import { ACADEMY_PUBLIC_PATH } from '../lib/academy-constants';
import { t, type Locale } from '../i18n';

const pathname = Astro.url.pathname;
const locale: Locale = Astro.currentLocale === 'en' ? 'en' : 'ko';

// 영어 페이지에서는 /en/ 접두사를 사용
const enPrefix = locale === 'en' ? '/en' : '';

const navLabelKeyByHref = new Map<string, string>([
  ['/', 'nav.home'],
  ['/procedures/', 'nav.procedures'],
  ['/blog/', 'nav.blog'],
  ['/trending/', 'nav.trending'],
  [`${ACADEMY_PUBLIC_PATH}/`, 'nav.doctorAi'],
  ['/consult/', 'nav.consult'],
  ['/about/', 'nav.about'],
]);

// 영어 전용 지원 경로 (Academy는 /en/ 없음)
const supportedEnPaths = ['/', '/procedures/', '/blog/', '/trending/', '/consult/', '/about/'];

const getLocalizedHref = (href: string): string => {
  if (locale !== 'en') return href;
  if (href === `${ACADEMY_PUBLIC_PATH}/`) return href; // Academy는 영어 버전 없음
  if (supportedEnPaths.includes(href)) {
    return href === '/' ? '/en/' : `/en${href}`;
  }
  return href;
};

const navLabel = (href: string) => {
  const key = navLabelKeyByHref.get(href);
  return key ? t(locale, key) : href;
};
---

<header class="site-header">
  <div class="site-header-inner">
    <a href={locale === 'en' ? '/en/' : '/'} class="site-logo">
      <div class="site-logo-mark" aria-hidden="true">S</div>
      <span class="site-logo-text">{SITE_TITLE}</span>
    </a>

    <nav class="site-nav" aria-label={t(locale, 'header.mainNavAria')}>
      {NAV_LINKS.map((link) => {
        const localizedHref = getLocalizedHref(link.href);
        return (
          <a
            href={localizedHref}
            class:list={[
              'site-nav-link',
              {
                'is-active':
                  pathname === localizedHref ||
                  (localizedHref !== '/' && localizedHref !== '/en/' &&
                    (pathname.startsWith(localizedHref) ||
                      pathname === localizedHref.replace(/\/$/, ''))),
              },
            ]}
          >
            {navLabel(link.href)}
          </a>
        );
      })}
    </nav>

    <button
      type="button"
      class="site-mobile-menu-btn"
      aria-label={t(locale, 'header.menuOpenAria')}
      aria-expanded="false"
      aria-controls="site-mobile-nav-panel"
      data-mobile-menu-toggle
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- 모바일 드롭다운 메뉴 -->
  <div
    class="site-mobile-nav"
    id="site-mobile-nav-panel"
    data-mobile-nav
    hidden
    role="region"
    aria-label={t(locale, 'header.mobileNavAria')}
  >
    <nav aria-label={t(locale, 'header.mobileMainNavAria')}>
      {NAV_LINKS.map((link) => (
        <a href={getLocalizedHref(link.href)} class="site-mobile-nav-link">
          {navLabel(link.href)}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-mobile-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    box-sizing: border-box;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    border-radius: 10px;
  }

  .site-mobile-menu-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .site-mobile-nav {
    position: absolute;
    top: var(--header-height);
    left: 0;
    right: 0;
    background: var(--surface);
    border-bottom: 1px solid var(--rule);
    padding: 1rem max(var(--page-inline), env(safe-area-inset-right, 0px)) 1.5rem
      max(var(--page-inline), env(safe-area-inset-left, 0px));
    box-shadow: var(--shadow-md);
  }

  .site-mobile-nav-link {
    display: block;
    min-height: 44px;
    line-height: 44px;
    padding: 0;
    border-bottom: 1px solid var(--rule);
    color: var(--t2);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    box-sizing: border-box;
  }

  .site-mobile-nav-link:focus-visible {
    outline: 2px solid var(--accent, #b8956a);
    outline-offset: 2px;
  }

  .site-mobile-nav-link:last-of-type {
    border-bottom: none;
  }

  @media (max-width: 480px) {
    .site-mobile-menu-btn {
      display: flex;
    }

    /* 모바일에서 데스크톱 가로 네비 숨김 → 햄버거 메뉴로 대체 */
    .site-nav {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector('[data-mobile-menu-toggle]');
  const nav = document.querySelector('[data-mobile-nav]');

  const isEn = document.documentElement.lang === 'en';
  const setOpen = (open) => {
    if (!nav || !(toggle instanceof HTMLButtonElement)) return;
    if (open) {
      nav.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', isEn ? 'Close menu' : '메뉴 닫기');
    } else {
      nav.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', isEn ? 'Open menu' : '메뉴 열기');
    }
  };

  toggle?.addEventListener('click', () => {
    const open = nav?.hasAttribute('hidden');
    setOpen(Boolean(open));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape' || !nav || nav.hasAttribute('hidden')) return;
    setOpen(false);
    if (toggle instanceof HTMLButtonElement) toggle.focus();
  });
</script>
