---
import { NAV_LINKS, SITE_TITLE } from '../consts';

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="site-logo">
      <div class="site-logo-mark" aria-hidden="true">S</div>
      <span class="site-logo-text">{SITE_TITLE}</span>
    </a>

    <nav class="site-nav" aria-label="주요 메뉴">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'site-nav-link',
            {
              'is-active':
                pathname === link.href ||
                (link.href !== '/' &&
                  (pathname.startsWith(link.href) ||
                    pathname === link.href.replace(/\/$/, ''))),
            },
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <button
      type="button"
      class="site-mobile-menu-btn"
      aria-label="메뉴 열기"
      aria-expanded="false"
      aria-controls="site-mobile-nav-panel"
      data-mobile-menu-toggle
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- 모바일 드롭다운 메뉴 -->
  <div
    class="site-mobile-nav"
    id="site-mobile-nav-panel"
    data-mobile-nav
    hidden
    role="region"
    aria-label="모바일 내비게이션"
  >
    <nav aria-label="모바일 주요 메뉴">
      {NAV_LINKS.map((link) => (
        <a href={link.href} class="site-mobile-nav-link">
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-mobile-menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    box-sizing: border-box;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    border-radius: 10px;
  }

  .site-mobile-menu-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .site-mobile-nav {
    position: absolute;
    top: var(--header-height);
    left: 0;
    right: 0;
    background: var(--surface);
    border-bottom: 1px solid var(--rule);
    padding: 1rem max(var(--page-inline), env(safe-area-inset-right, 0px)) 1.5rem
      max(var(--page-inline), env(safe-area-inset-left, 0px));
    box-shadow: var(--shadow-md);
  }

  .site-mobile-nav-link {
    display: block;
    min-height: 44px;
    line-height: 44px;
    padding: 0;
    border-bottom: 1px solid var(--rule);
    color: var(--t2);
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    box-sizing: border-box;
  }

  .site-mobile-nav-link:focus-visible {
    outline: 2px solid var(--accent, #b8956a);
    outline-offset: 2px;
  }

  .site-mobile-nav-link:last-of-type {
    border-bottom: none;
  }

  @media (max-width: 480px) {
    .site-mobile-menu-btn {
      display: flex;
    }

    /* 모바일에서 데스크톱 가로 네비 숨김 → 햄버거 메뉴로 대체 */
    .site-nav {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector('[data-mobile-menu-toggle]');
  const nav = document.querySelector('[data-mobile-nav]');

  const setOpen = (open) => {
    if (!nav || !(toggle instanceof HTMLButtonElement)) return;
    if (open) {
      nav.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', '메뉴 닫기');
    } else {
      nav.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', '메뉴 열기');
    }
  };

  toggle?.addEventListener('click', () => {
    const open = nav?.hasAttribute('hidden');
    setOpen(Boolean(open));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape' || !nav || nav.hasAttribute('hidden')) return;
    setOpen(false);
    if (toggle instanceof HTMLButtonElement) toggle.focus();
  });
</script>
