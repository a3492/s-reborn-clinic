---
// 클리닉 블로그 상단 검색 + 상담 버튼 바
---

<div class="topbar">
  <div class="topbar-inner">
    <form class="topbar-search" action="/blog" method="get" role="search">
      <input
        class="topbar-search-input"
        type="search"
        name="q"
        placeholder="시술명, 증상, 키워드 검색..."
        aria-label="블로그 검색"
      />
      <button type="submit" class="topbar-search-btn" aria-label="검색">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
    </form>

    <a href="/consult" class="topbar-cta">
      상담 신청하기
    </a>
  </div>
</div>

<style>
  .topbar {
    background: var(--bg2);
    border-bottom: 1px solid var(--rule);
    padding: 0.6rem 0;
  }

  .topbar-inner {
    max-width: var(--max-width, 1200px);
    margin-inline: auto;
    padding-inline: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .topbar-search {
    display: flex;
    align-items: center;
    gap: 0;
    flex: 1;
    max-width: 480px;
    border: 1px solid var(--rule);
    border-radius: 999px;
    background: var(--surface);
    overflow: hidden;
  }

  .topbar-search-input {
    flex: 1;
    padding: 0.55rem 1rem;
    border: none;
    background: transparent;
    font: inherit;
    font-size: 0.9rem;
    color: var(--text);
    outline: none;
  }

  .topbar-search-input::placeholder {
    color: var(--t3);
  }

  .topbar-search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 0.9rem;
    border: none;
    background: transparent;
    color: var(--t3);
    cursor: pointer;
    transition: color 0.15s;
  }

  .topbar-search-btn:hover {
    color: var(--accent);
  }

  .topbar-cta {
    white-space: nowrap;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    background: var(--accent);
    color: white;
    font-size: 0.84rem;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .topbar-cta:hover {
    background: var(--accent-dark);
  }

  @media (max-width: 600px) {
    .topbar-inner {
      padding-inline: 1rem;
    }
  }
</style>
