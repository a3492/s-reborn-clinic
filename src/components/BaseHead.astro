---
import { CLINIC_INFO, SITE_TITLE } from '../consts';
import { ACADEMY_PUBLIC_PATH } from '../lib/academy-constants';
import { RSS_MAIN_FEED_TITLE } from '../lib/rss-feed';

interface Props {
	title: string;
	description: string;
	image?: string;
	siteTitle?: string;
	/** 미지정 시 URL로 추론: `/blog/분류/slug` 형태만 article, 나머지 website */
	ogType?: 'website' | 'article';
	/** schema.org JSON-LD (Organization, BlogPosting 등) */
	jsonLd?: Record<string, unknown>;
	/** 관리자 등 비공개 페이지 — 검색·AI 인덱싱 제외 */
	noindex?: boolean;
	/** false면 테마 FOUC 방지 스크립트 미삽입 (어드민 전용) */
	applyVisitorTheme?: boolean;
	/** 글 페이지 등 — 카테고리별 RSS `<link rel="alternate">` */
	rssCategoryId?: string | null;
	rssCategoryLabel?: string | null;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	image,
	siteTitle = SITE_TITLE,
	ogType: ogTypeProp,
	jsonLd,
	noindex,
	applyVisitorTheme = true,
	rssCategoryId,
	rssCategoryLabel,
} = Astro.props;

const pathNorm = Astro.url.pathname.replace(/\/$/, '') || '/';
const afterBlog = pathNorm.startsWith('/blog/') ? pathNorm.slice(6) : '';
const doctorAiArticle = new RegExp(
	`^${ACADEMY_PUBLIC_PATH.replace(/\//g, '\\/')}\\/[^/]+\\/.+`
).test(pathNorm);
const inferredOgType = afterBlog.includes('/') || doctorAiArticle ? 'article' : 'website';
const ogType = ogTypeProp ?? inferredOgType;

const ogImage = image
	? (image.startsWith('http') ? image : new URL(image, Astro.url).href)
	: new URL('/clinic-og-default.jpg', Astro.url).href;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
{applyVisitorTheme && (
	<script is:inline>
		(function () {
			try {
				var k = 'clinic-theme';
				var d = document.documentElement;
				var s = localStorage.getItem(k);
				var t =
					s === 'light' || s === 'dark'
						? s
						: window.matchMedia('(prefers-color-scheme: dark)').matches
							? 'dark'
							: 'light';
				d.setAttribute('data-theme', t);
			} catch (e) {
				document.documentElement.setAttribute('data-theme', 'light');
			}
		})();
	</script>
)}
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32' width='32' height='32'%3E%3Cdefs%3E%3CclipPath id='shape'%3E%3Crect width='32' height='32' rx='7' ry='7'/%3E%3C/clipPath%3E%3C/defs%3E%3Cg clip-path='url(%23shape)'%3E%3Crect width='16' height='32' fill='%23FDF0E8'/%3E%3Crect x='16' width='16' height='32' fill='%23F4B8CA'/%3E%3C/g%3E%3Ctext x='16' y='21' font-family='-apple-system%2CBlinkMacSystemFont%2CSegoe UI%2CArial%2Csans-serif' font-weight='800' font-size='13' fill='%236B2D45' text-anchor='middle' letter-spacing='-0.5'%3ESC%3C/text%3E%3C/svg%3E" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title={RSS_MAIN_FEED_TITLE} href="/rss.xml" />
{rssCategoryId && (
	<link
		rel="alternate"
		type="application/rss+xml"
		title={`S-Reborn — ${rssCategoryLabel ?? rssCategoryId}`}
		href={`/rss/${rssCategoryId}.xml`}
	/>
)}
<link rel="alternate" type="text/plain" title="LLM · 사이트 요약" href={new URL('llms.txt', Astro.site).href} />
<meta name="generator" content={Astro.generator} />
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
{noindex && <meta name="robots" content="noindex, nofollow" />}
{!noindex && (
	<meta
		name="robots"
		content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
	/>
)}
<meta name="copyright" content={`© ${new Date().getFullYear()} ${CLINIC_INFO.name}. 무단 전재 및 상업적 복제 금지.`} />
<meta name="referrer" content="strict-origin-when-cross-origin" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content="ko_KR" />
<meta property="og:site_name" content={siteTitle} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImage} />

{jsonLd && (
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
)}
