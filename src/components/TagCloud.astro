---
import type { CollectionEntry } from 'astro:content';
import { blogTagPageHref } from '../lib/blog-tag-url';

interface Props {
	/** 전체 클라우드: 글 목록에서 태그 집계 */
	variant?: 'cloud' | 'post';
	posts?: CollectionEntry<'blog'>[];
	/** 글 본문용: 이 태그만 링크 (크기 균일) */
	tags?: string[];
	title?: string;
	/** cloud 변형에서 펼치지 않고 기본 표시할 태그 수 (기본 20) */
	previewCount?: number;
}

const { variant = 'cloud', posts = [], tags: postTags = [], title, previewCount = 20 } = Astro.props;

const cloudTitle = title ?? '태그';

/** 내부 관리용 태그 패턴 — UI에 노출하지 않음 */
const INTERNAL_TAG_RE = /^작성-\d{6,}/;

function aggregateTags(entries: CollectionEntry<'blog'>[]): Map<string, number> {
	const m = new Map<string, number>();
	for (const p of entries) {
		for (const raw of p.data.tags ?? []) {
			const t = String(raw || '').trim();
			if (!t || INTERNAL_TAG_RE.test(t)) continue;
			m.set(t, (m.get(t) ?? 0) + 1);
		}
	}
	return m;
}

let items: { tag: string; count: number; tier: 1 | 2 | 3 }[] = [];

if (variant === 'cloud' && posts.length > 0) {
	const map = aggregateTags(posts);
	const sorted = [...map.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], 'ko'));
	const n = sorted.length;
	items = sorted.map(([tag, count], i) => {
		let tier: 1 | 2 | 3 = 2;
		if (n <= 1) tier = 2;
		else if (i < n / 3) tier = 3;
		else if (i < (2 * n) / 3) tier = 2;
		else tier = 1;
		return { tag, count, tier };
	});
} else if (variant === 'post' && postTags.length > 0) {
	items = [...new Set(postTags.map((t) => String(t || '').trim()).filter(Boolean))].map((tag) => ({
		tag,
		count: 1,
		tier: 2 as const,
	}));
}

/** Fisher-Yates 셔플 (빌드 시 실행 — 배포마다 랜덤) */
function shuffle<T>(arr: T[]): T[] {
	const a = [...arr];
	for (let i = a.length - 1; i > 0; i--) {
		const j = Math.floor(Math.random() * (i + 1));
		[a[i], a[j]] = [a[j], a[i]];
	}
	return a;
}

const isCloud = variant === 'cloud';
const displayItems = isCloud ? shuffle(items) : items;
const previewItems = isCloud ? displayItems.slice(0, previewCount) : items;
const moreItems   = isCloud ? displayItems.slice(previewCount)     : [];
const hasMore     = moreItems.length > 0;
---

{
	items.length > 0 && (
		<div class:list={['tag-cloud', !isCloud && 'tag-cloud--post']}>
			<h2 class="tag-cloud-title">{cloudTitle}</h2>

			{/* 항상 보이는 상위 태그 */}
			<ul class="tag-cloud-list">
				{previewItems.map(({ tag, count, tier }) => (
					<li>
						<a
							href={blogTagPageHref(tag)}
							class:list={['tag-cloud-link', `tag-cloud-link--t${tier}`]}
							title={`「${tag}」 태그가 달린 글 목록`}
						>
							#{tag}
							{isCloud && <span class="tag-cloud-count">{count}</span>}
						</a>
					</li>
				))}
			</ul>

			{/* 더보기 Accordion — cloud 변형에만 */}
			{hasMore && (
				<>
					<ul class="tag-cloud-list tag-cloud-more-list" id="tag-cloud-more" hidden aria-hidden="true">
						{moreItems.map(({ tag, count, tier }) => (
							<li>
								<a
									href={blogTagPageHref(tag)}
									class:list={['tag-cloud-link', `tag-cloud-link--t${tier}`]}
									title={`「${tag}」 태그가 달린 글 목록`}
								>
									#{tag}
									<span class="tag-cloud-count">{count}</span>
								</a>
							</li>
						))}
					</ul>

					<button
						class="tag-cloud-toggle"
						type="button"
						aria-expanded="false"
						aria-controls="tag-cloud-more"
						data-more-label={`태그 더보기 (${moreItems.length}개)`}
						data-less-label="접기"
					>
						태그 더보기 ({moreItems.length}개)
					</button>
				</>
			)}
		</div>
	)
}

<style>
	.tag-cloud {
		margin: 0;
	}

	.tag-cloud-title {
		margin: 0 0 0.5rem;
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--t3);
	}

	.tag-cloud-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 0.5rem;
		align-items: center;
	}

	.tag-cloud-more-list {
		margin-top: 0.35rem;
	}

	.tag-cloud-more-list[hidden] {
		display: none !important;
	}

	.tag-cloud-link {
		display: inline-flex;
		align-items: baseline;
		gap: 0.2rem;
		text-decoration: none;
		font-weight: 700;
		color: var(--accent-dark);
		border-radius: 999px;
		padding: 0.2rem 0.55rem;
		background: var(--bg2);
		border: 1px solid var(--rule);
		transition:
			background 0.15s ease,
			color 0.15s ease,
			border-color 0.15s ease;
		line-height: 1.3;
	}

	.tag-cloud-link:hover {
		background: var(--bg3);
		border-color: var(--accent);
		color: var(--text);
	}

	.tag-cloud-link--t1 {
		font-size: 0.72rem;
	}

	.tag-cloud-link--t2 {
		font-size: 0.82rem;
	}

	.tag-cloud-link--t3 {
		font-size: 0.95rem;
	}

	.tag-cloud--post .tag-cloud-link {
		font-size: 0.8rem;
	}

	.tag-cloud-count {
		font-size: 0.65em;
		font-weight: 800;
		color: var(--t3);
		opacity: 0.9;
	}

	.tag-cloud-link:hover .tag-cloud-count {
		color: var(--t2);
	}

	/* 더보기 토글 버튼 */
	.tag-cloud-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		margin-top: 0.55rem;
		padding: 0.25rem 0.65rem;
		font-size: 0.76rem;
		font-weight: 700;
		color: var(--t3);
		background: transparent;
		border: 1px solid var(--rule);
		border-radius: 999px;
		cursor: pointer;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
		line-height: 1.4;
	}

	.tag-cloud-toggle::after {
		content: '▾';
		font-size: 0.7em;
		transition: transform 0.2s ease;
	}

	.tag-cloud-toggle[aria-expanded='true']::after {
		transform: rotate(180deg);
	}

	.tag-cloud-toggle:hover {
		color: var(--accent-dark);
		border-color: var(--accent);
		background: var(--bg2);
	}

	.tag-cloud-toggle:focus-visible {
		outline: 2px solid var(--accent, #b8956a);
		outline-offset: 2px;
	}
</style>

<script>
	document.querySelectorAll<HTMLButtonElement>('.tag-cloud-toggle').forEach((btn) => {
		btn.addEventListener('click', () => {
			const targetId = btn.getAttribute('aria-controls');
			if (!targetId) return;
			const panel = document.getElementById(targetId);
			if (!panel) return;

			const expanded = btn.getAttribute('aria-expanded') === 'true';
			const nowExpanded = !expanded;

			panel.hidden = !nowExpanded;
			panel.setAttribute('aria-hidden', String(!nowExpanded));
			btn.setAttribute('aria-expanded', String(nowExpanded));
			btn.textContent = nowExpanded
				? (btn.dataset.lessLabel ?? '접기')
				: (btn.dataset.moreLabel ?? '더보기');
		});
	});
</script>
