---
import { CATEGORIES } from '../consts';

const pathname = Astro.url.pathname;
const searchParams = Astro.url.searchParams;
const currentCat = searchParams.get('category') ?? '';
---

<aside class="blog-sidebar">
  <div class="sidebar-widget">
    <h2 class="sidebar-title">카테고리</h2>
    <ul class="sidebar-cat-list">
      <li>
        <a
          href="/blog"
          class:list={['sidebar-cat-link', { 'is-active': pathname === '/blog' && !currentCat }]}
        >
          <span>전체 글</span>
        </a>
      </li>
      {CATEGORIES.map((cat) => (
        <li>
          <a
            href={`/blog?category=${cat.id}`}
            class:list={['sidebar-cat-link', { 'is-active': currentCat === cat.id }]}
            title={cat.description}
          >
            <span>{cat.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="sidebar-widget" style="margin-top:1rem;">
    <div style="text-align:center;">
      <p style="font-size:0.88rem;color:var(--t2);margin:0 0 0.75rem;line-height:1.65;">
        궁금한 점이 있으신가요?<br/>전문 의료진이 답변드립니다.
      </p>
      <a href="/consult" class="btn btn-primary" style="width:100%;justify-content:center;">
        온라인 상담 신청
      </a>
    </div>
  </div>
</aside>

<style>
  .blog-sidebar {
    width: 240px;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .blog-sidebar {
      width: 100%;
    }

    .sidebar-cat-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .sidebar-cat-link {
      padding: 0.4rem 0.8rem;
      border-radius: 999px;
      border: 1px solid var(--rule);
    }
  }
</style>
